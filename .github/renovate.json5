{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    "config:best-practices",
    // Gate every update behind a checkbox on the dashboard -- no auto-PRs
    ":dependencyDashboardApproval",
    ":separateMultipleMajorReleases"
  ],

  "enabledManagers": ["pep621", "npm", "github-actions", "gomod", "cargo"],

  "dependencyDashboardTitle": "Renovate: Dependency Status",
  "dependencyDashboardLabels": ["dependencies"],
  "dependencyDashboardOSVVulnerabilitySummary": ["all"],
  "dependencyDashboardReportAbandonment": true,

  // Surface CVEs on the dashboard
  "osvVulnerabilityAlerts": true,

  // Vuln-fix PRs bypass the approval gate -- keep them off
  "vulnerabilityAlerts": { "enabled": false },

  "ignorePaths": ["common/hogql_parser/**"],

  "packageRules": [
    // Split github-actions pin updates out of the default `renovate/pin-dependencies`
    // bundle so they can be approved on the dashboard independently of the cross-manager
    // pin bundle (which also touches every npm/cargo/pep621/gomod lockfile and is
    // impractical to land in one PR). Approval gate is preserved.
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["pin"],
      "groupName": "github-actions pin"
    }
  ]
}
