{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],

  // Python only
  "enabledManagers": ["pep621"],

  // Disable ALL PRs -- we only want the dashboard
  "packageRules": [
    {
      "matchPackageNames": ["*"],
      "enabled": false
    }
  ],

  // Dashboard config -- the whole point
  "dependencyDashboardTitle": "Renovate: Python Dependency Status",
  "dependencyDashboardLabels": ["dependencies"],
  "dependencyDashboardOSVVulnerabilitySummary": true,

  // Enable vulnerability detection for dashboard visibility (no PRs created)
  "osvVulnerabilityAlerts": true,

  "ignorePaths": [
    "common/hogql_parser/**"
  ]
}
