{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    "config:best-practices",
    ":separateMultipleMajorReleases"
  ],

  "enabledManagers": ["pep621", "npm", "github-actions", "gomod", "cargo"],

  "dependencyDashboardTitle": "Renovate: Dependency Status",
  "dependencyDashboardLabels": ["dependencies"],
  "dependencyDashboardOSVVulnerabilitySummary": ["all"],
  "dependencyDashboardReportAbandonment": true,

  // Wait 14 days before any update is eligible -- gives registries time to
  // pull malicious releases (docs' security recommendation for all ecosystems)
  "minimumReleaseAge": "14 days",

  // Keep PR volume manageable while we ramp up
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10,

  "ignorePaths": ["common/hogql_parser/**"]
}
