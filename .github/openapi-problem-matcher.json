{
    "problemMatcher": [
        {
            "owner": "openapi-schema",
            "severity": "warning",
            "pattern": [
                {
                    "regexp": "^([^:]*):(\\d+): (Warning|Error) \\[([^\\]]+)\\]: (.*)$",
                    "file": 1,
                    "line": 2,
                    "severity": 3,
                    "code": 4,
                    "message": 5
                }
            ]
        }
    ]
}
