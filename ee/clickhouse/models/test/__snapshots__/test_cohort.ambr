                 WHERE and(equals(e.team_id, 99999), lessOrEquals(e.timestamp, toDateTime64('today', 6, 'UTC')), equals(e.event, 'signup'))
                 GROUP BY if(not(empty(e__override.distinct_id)), e__override.person_id, e.person_id)
                 HAVING and(equals(min_timestamp, min_timestamp_with_condition), notEquals(min_timestamp, fromUnixTimestamp(0))))
              GROUP BY actor_id) AS source
