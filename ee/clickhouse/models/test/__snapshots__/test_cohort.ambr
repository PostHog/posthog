        HAVING equals(argMax(person_distinct_id2.is_deleted, person_distinct_id2.version), 0) SETTINGS optimize_aggregation_in_order=1) AS person_distinct_ids
     WHERE in(person_distinct_ids.person_id,
                (SELECT person_static_cohort.person_id AS person_id
                 FROM person_static_cohort
                 WHERE and(equals(person_static_cohort.team_id, 99999), equals(person_static_cohort.cohort_id, 99999))))
     LIMIT 1000000000)
