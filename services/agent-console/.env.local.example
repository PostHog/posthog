# Copy to .env.local and fill in.

# Where PostHog Django is running. Local dev default = 8010.
POSTHOG_BASE_URL=http://localhost:8010

# Where agent-ingress is running. The console proxies /api/agents/v1/* here.
# Local dev default = 3010. (No requests use this prefix yet, but the catch-
# all proxy is ready for it once the chat dock starts talking to the runner.)
POSTHOG_AGENTS_BASE=http://localhost:3010

# Public URL the browser hits the console at. Used to build redirect URIs.
CONSOLE_BASE_URL=http://localhost:3040

# OAuth client provisioned by:
#   python manage.py setup_oauth_for_agent_console
# The command prints these values; paste them here.
POSTHOG_OAUTH_CLIENT_ID=
POSTHOG_OAUTH_CLIENT_SECRET=

# Random 32+ character string. Used to seal the HTTP-only session cookie.
# Rotate it and existing sessions are invalidated.
#   openssl rand -hex 32
OAUTH_COOKIE_SECRET=
