#!/bin/sh
# Apply pending migrations to the agent-runtime queue DB.
#
# Mirrors rust/bin/migrate-cyclotron but for the TypeScript-managed agent_runtime_queue
# schema owned by @posthog/agent-core. Called from bin/migrate --scope=agent_runtime.

set -e

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")

AGENT_RUNTIME_QUEUE_DATABASE_NAME=${AGENT_RUNTIME_QUEUE_DATABASE_NAME:-agent_runtime_queue}
AGENT_RUNTIME_QUEUE_DATABASE_URL=${AGENT_RUNTIME_QUEUE_DATABASE_URL:-postgres://posthog:posthog@localhost:5432/$AGENT_RUNTIME_QUEUE_DATABASE_NAME}

echo "Performing agent-runtime queue migrations for $AGENT_RUNTIME_QUEUE_DATABASE_URL"

cd "$SCRIPT_DIR/.."

AGENT_RUNTIME_QUEUE_DATABASE_URL="$AGENT_RUNTIME_QUEUE_DATABASE_URL" \
    pnpm exec tsx bin/migrate.ts
