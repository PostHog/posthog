{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "definitions": {
        "AIObservabilityGetCostsSchema": {
            "type": "object",
            "properties": {
                "projectId": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                },
                "days": {
                    "type": "number"
                }
            },
            "required": ["projectId"]
        },
        "BusinessKnowledgeUrlSourceCreateSchema": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Short human label for the source. Shown in the settings list and in agent citations."
                },
                "url": {
                    "type": "string",
                    "maxLength": 2048,
                    "format": "uri",
                    "description": "Public HTTP(S) URL to fetch. Private or internal hosts are rejected."
                },
                "source_type": {
                    "default": "url",
                    "description": "Source type. Always \"url\" for this tool.",
                    "type": "string",
                    "const": "url"
                },
                "refresh_interval": {
                    "default": "manual",
                    "description": "How often to auto-refresh this source in the background. Defaults to \"manual\" (no auto-refresh).",
                    "type": "string",
                    "enum": ["manual", "1h", "6h", "24h", "7d"]
                }
            },
            "required": ["name", "url"]
        },
        "DebugMcpUiAppsSchema": {
            "type": "object",
            "properties": {
                "message": {
                    "description": "Optional message to include in the debug data",
                    "type": "string"
                }
            }
        },
        "EmailTemplateDesignPatchSchema": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string",
                    "description": "The email template id to edit."
                },
                "operations": {
                    "minItems": 1,
                    "type": "array",
                    "items": {
                        "oneOf": [
                            {
                                "type": "object",
                                "properties": {
                                    "op": {
                                        "type": "string",
                                        "const": "update_content"
                                    },
                                    "id": {
                                        "type": "string",
                                        "description": "Id of the content block to update."
                                    },
                                    "patch": {
                                        "type": "object",
                                        "propertyNames": {
                                            "type": "string"
                                        },
                                        "additionalProperties": {},
                                        "description": "Partial content-block fields, deep-merged into the existing block; a null leaf deletes that key. e.g. {values: {text: '<p>Hi</p>'}} changes only the block's text."
                                    }
                                },
                                "required": ["op", "id", "patch"]
                            },
                            {
                                "type": "object",
                                "properties": {
                                    "op": {
                                        "type": "string",
                                        "const": "update_column"
                                    },
                                    "id": {
                                        "type": "string",
                                        "description": "Id of the column to update."
                                    },
                                    "patch": {
                                        "type": "object",
                                        "propertyNames": {
                                            "type": "string"
                                        },
                                        "additionalProperties": {},
                                        "description": "Partial column fields, deep-merged; a null leaf deletes that key."
                                    }
                                },
                                "required": ["op", "id", "patch"]
                            },
                            {
                                "type": "object",
                                "properties": {
                                    "op": {
                                        "type": "string",
                                        "const": "update_row"
                                    },
                                    "id": {
                                        "type": "string",
                                        "description": "Id of the row to update."
                                    },
                                    "patch": {
                                        "type": "object",
                                        "propertyNames": {
                                            "type": "string"
                                        },
                                        "additionalProperties": {},
                                        "description": "Partial row fields, deep-merged; a null leaf deletes that key."
                                    }
                                },
                                "required": ["op", "id", "patch"]
                            },
                            {
                                "type": "object",
                                "properties": {
                                    "op": {
                                        "type": "string",
                                        "const": "update_body"
                                    },
                                    "patch": {
                                        "type": "object",
                                        "propertyNames": {
                                            "type": "string"
                                        },
                                        "additionalProperties": {},
                                        "description": "Partial body fields, deep-merged. e.g. {values: {backgroundColor: '#ffffff'}}."
                                    }
                                },
                                "required": ["op", "patch"]
                            },
                            {
                                "type": "object",
                                "properties": {
                                    "op": {
                                        "type": "string",
                                        "const": "add_content"
                                    },
                                    "column_id": {
                                        "type": "string",
                                        "description": "Id of the column to insert the block into."
                                    },
                                    "content": {
                                        "type": "object",
                                        "propertyNames": {
                                            "type": "string"
                                        },
                                        "additionalProperties": {},
                                        "description": "A content block {type, values: {...}}; omit id and values._meta — they are assigned server-side. type is one of text, heading, button, image, divider, html, etc."
                                    },
                                    "index": {
                                        "description": "0-based insert position; omit to append to the end.",
                                        "type": "integer",
                                        "minimum": -9007199254740991,
                                        "maximum": 9007199254740991
                                    }
                                },
                                "required": ["op", "column_id", "content"]
                            },
                            {
                                "type": "object",
                                "properties": {
                                    "op": {
                                        "type": "string",
                                        "const": "remove_content"
                                    },
                                    "id": {
                                        "type": "string",
                                        "description": "Id of the content block to remove."
                                    }
                                },
                                "required": ["op", "id"]
                            },
                            {
                                "type": "object",
                                "properties": {
                                    "op": {
                                        "type": "string",
                                        "const": "move_content"
                                    },
                                    "id": {
                                        "type": "string",
                                        "description": "Id of the content block to move."
                                    },
                                    "column_id": {
                                        "type": "string",
                                        "description": "Id of the destination column."
                                    },
                                    "index": {
                                        "description": "0-based position in the destination column; omit to append.",
                                        "type": "integer",
                                        "minimum": -9007199254740991,
                                        "maximum": 9007199254740991
                                    }
                                },
                                "required": ["op", "id", "column_id"]
                            },
                            {
                                "type": "object",
                                "properties": {
                                    "op": {
                                        "type": "string",
                                        "const": "add_row"
                                    },
                                    "row": {
                                        "type": "object",
                                        "propertyNames": {
                                            "type": "string"
                                        },
                                        "additionalProperties": {},
                                        "description": "A full row {cells, columns: [{contents: [...], values}], values}; ids and Unlayer numbering are assigned server-side for the row and everything nested in it."
                                    },
                                    "index": {
                                        "description": "0-based insert position; omit to append to the end.",
                                        "type": "integer",
                                        "minimum": -9007199254740991,
                                        "maximum": 9007199254740991
                                    }
                                },
                                "required": ["op", "row"]
                            },
                            {
                                "type": "object",
                                "properties": {
                                    "op": {
                                        "type": "string",
                                        "const": "remove_row"
                                    },
                                    "id": {
                                        "type": "string",
                                        "description": "Id of the row to remove."
                                    }
                                },
                                "required": ["op", "id"]
                            }
                        ]
                    },
                    "description": "Ordered edits applied atomically to the template's Unlayer design: the stored design is read, the ops are applied in order, the result is validated and re-rendered to HTML, and saved only if valid — otherwise the template is left unchanged. Reference blocks by id so you never resend the whole design."
                }
            },
            "required": ["id", "operations"]
        },
        "EventDefinitionUpdateInputSchema": {
            "type": "object",
            "properties": {
                "description": {
                    "description": "Description explaining when the event is triggered",
                    "type": "string"
                },
                "tags": {
                    "description": "Tags to organize events by product area (e.g. \"checkout\", \"onboarding\") or user journey stage (e.g. \"acquisition\", \"activation\", \"monetization\", \"retention\")",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "verified": {
                    "description": "Mark as verified to indicate the event is properly instrumented and tracking correctly",
                    "type": "boolean"
                },
                "hidden": {
                    "description": "Mark event as no longer used/captured. Hides it from UI while preserving historical data",
                    "type": "boolean"
                }
            }
        },
        "EventDefinitionUpdateSchema": {
            "type": "object",
            "properties": {
                "eventName": {
                    "type": "string",
                    "description": "The name of the event to update (e.g. \"$pageview\", \"user_signed_up\")"
                },
                "data": {
                    "type": "object",
                    "properties": {
                        "description": {
                            "description": "Description explaining when the event is triggered",
                            "type": "string"
                        },
                        "tags": {
                            "description": "Tags to organize events by product area (e.g. \"checkout\", \"onboarding\") or user journey stage (e.g. \"acquisition\", \"activation\", \"monetization\", \"retention\")",
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "verified": {
                            "description": "Mark as verified to indicate the event is properly instrumented and tracking correctly",
                            "type": "boolean"
                        },
                        "hidden": {
                            "description": "Mark event as no longer used/captured. Hides it from UI while preserving historical data",
                            "type": "boolean"
                        }
                    },
                    "description": "The event definition data to update"
                }
            },
            "required": ["eventName", "data"]
        },
        "ExecuteSQLSchema": {
            "type": "object",
            "properties": {
                "query": {
                    "type": "string",
                    "minLength": 1,
                    "description": "The final SQL query to be executed."
                },
                "truncate": {
                    "default": true,
                    "description": "Whether to truncate large blob/JSON values in results. Defaults to true. Set to false when you need full untruncated results (e.g., for dumping to a file).",
                    "type": "boolean"
                },
                "connectionId": {
                    "description": "Optional id of an external data source (e.g. a Postgres, DuckDB, or MySQL direct-query connection). When set, runs the query against that source instead of the ClickHouse catalog. Use external-data-sources-list to discover available connection ids.",
                    "type": "string"
                }
            },
            "required": ["query"]
        },
        "ExperimentResultsGetSchema": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "number",
                    "description": "The ID of the experiment to get comprehensive results for"
                },
                "refresh": {
                    "default": false,
                    "description": "Force refresh of results instead of using cached values. Defaults to false.",
                    "type": "boolean"
                }
            },
            "required": ["id"]
        },
        "ExternalDataJobsAfterSchema": {
            "type": "string",
            "description": "ISO timestamp — only return jobs created after this date (e.g. \"2025-01-01T00:00:00Z\")."
        },
        "ExternalDataJobsBeforeSchema": {
            "type": "string",
            "description": "ISO timestamp — only return jobs created before this date (e.g. \"2025-12-31T23:59:59Z\")."
        },
        "ExternalDataJobsSchemasSchema": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Filter jobs by table schema names (e.g. [\"users\", \"orders\"]). Only returns jobs for these tables."
        },
        "ExternalDataSourcePayloadSchema": {
            "type": "object",
            "propertyNames": {
                "type": "string"
            },
            "additionalProperties": {},
            "description": "Connection credentials for the source. Keys depend on source_type. For database sources: host, port, database, user, password, schema. For SaaS sources: api_key or OAuth fields. Use external-data-sources-wizard to see required fields per source type."
        },
        "ExternalDataSourceTypeSchema": {
            "type": "string",
            "description": "The source type name (e.g. \"Postgres\", \"MySQL\", \"Stripe\"). Use external-data-sources-wizard to see available types and their required fields."
        },
        "FeedbackSubmitSchema": {
            "type": "object",
            "properties": {
                "summary": {
                    "type": "string",
                    "minLength": 1,
                    "description": "A one-sentence headline naming the problem (e.g. \"query-trends descriptions made it hard to choose between trends and funnels\"). Only submit when something went wrong or was missing — never for positive or \"everything worked\" feedback."
                },
                "sentiment": {
                    "type": "string",
                    "enum": ["negative", "mixed"],
                    "description": "How much the MCP server got in your way for this task. Use \"negative\" if it blocked you, \"mixed\" if it mostly worked but had a concrete problem worth fixing. Do not submit purely positive feedback — only report problems."
                },
                "category": {
                    "type": "string",
                    "enum": [
                        "tool_correctness",
                        "tool_description",
                        "tool_input_schema",
                        "tool_output_format",
                        "missing_tool",
                        "instructions_clarity",
                        "performance",
                        "error_message",
                        "other"
                    ],
                    "description": "The single category that best describes the dominant theme of this feedback. Pick \"missing_tool\" if a capability was absent, \"tool_description\" if the tool docs were unclear, \"tool_input_schema\" if input args were confusing, \"tool_output_format\" if the response was hard to consume, \"instructions_clarity\" if these MCP instructions were unclear, \"tool_correctness\" if a tool returned wrong data, \"error_message\" if an error was unhelpful, \"performance\" if latency was the issue."
                },
                "task_completed": {
                    "type": "boolean",
                    "description": "Were you able to complete the user's task using PostHog MCP tools? Be honest — \"false\" is just as useful as \"true\"."
                },
                "tools_used": {
                    "description": "The tool names you called while working on the user's task (e.g. [\"read-data-schema\", \"query-trends\"]). Helps us correlate feedback to specific tools.",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "friction_points": {
                    "description": "Clear, concise bullet points describing friction with the MCP server itself — what slowed you down or made you guess. Quote the exact tool name, parameter, or error text. Keep it about the MCP, not the user's task or data.",
                    "type": "string"
                },
                "suggested_improvement": {
                    "description": "The single most impactful, concrete change that would fix the problem you hit. Be specific (e.g. \"add a `filters` example to query-funnel's description\"). If you cannot name a specific change, do not submit feedback.",
                    "type": "string"
                },
                "user_request": {
                    "description": "A short, anonymised paraphrase of what the user originally asked you to do. Do not include PII, customer names, or sensitive query content.",
                    "type": "string"
                },
                "details": {
                    "description": "Any additional context about the MCP server that doesn't fit the other fields. Keep it to clear, concise bullet points.",
                    "type": "string"
                }
            },
            "required": ["summary", "sentiment", "category", "task_completed"]
        },
        "InsightQueryInputSchema": {
            "type": "object",
            "properties": {
                "insightId": {
                    "type": "string",
                    "description": "The insight ID or short_id to run."
                },
                "output_format": {
                    "default": "optimized",
                    "description": "Output format. \"optimized\" returns a human-readable summary from server-side formatters (recommended for analysis). \"json\" returns the raw query results as JSON.",
                    "type": "string",
                    "enum": ["optimized", "json"]
                },
                "variables_override": {
                    "description": "Object (or pre-encoded JSON string) to override the insight's HogQL variables for this run only (not persisted). Format: {\"<variable_id>\": {\"code_name\": \"<code_name>\", \"variableId\": \"<variable_id>\", \"value\": <new_value>}}. Each entry must include `code_name` — partial entries are silently dropped. The simplest workflow is to call `insight-get` first, copy the matching entry from the response's query variables, and mutate `value`. Top-level keys replace; nested values are not deep-merged. Ignored when accessed via a sharing token.",
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "object",
                            "propertyNames": {
                                "type": "string"
                            },
                            "additionalProperties": {}
                        }
                    ]
                },
                "filters_override": {
                    "description": "Object (or pre-encoded JSON string) to override the insight's filters for this run only (not persisted). Top-level keys replace; nested values are not deep-merged — pass the complete value for any key you override. Accepts the same keys as the dashboard filters schema (e.g., `date_from`, `date_to`, `properties`). Ignored when accessed via a sharing token.",
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "object",
                            "propertyNames": {
                                "type": "string"
                            },
                            "additionalProperties": {}
                        }
                    ]
                }
            },
            "required": ["insightId"]
        },
        "OrganizationSetActiveSchema": {
            "type": "object",
            "properties": {
                "orgId": {
                    "type": "string"
                }
            },
            "required": ["orgId"]
        },
        "ProjectGetAllSchema": {
            "type": "object",
            "properties": {}
        },
        "ProjectSetActiveSchema": {
            "type": "object",
            "properties": {
                "projectId": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                }
            },
            "required": ["projectId"]
        },
        "PromptListInputSchema": {
            "type": "object",
            "properties": {
                "search": {
                    "description": "Optional substring filter applied to prompt names and prompt content.",
                    "type": "string"
                },
                "content": {
                    "default": "none",
                    "description": "Controls how much prompt content is included in list results. 'full' includes the full prompt, 'preview' includes a short prompt_preview, and 'none' omits prompt content entirely.",
                    "type": "string",
                    "enum": ["full", "preview", "none"]
                }
            }
        },
        "ReadDataSchemaSchema": {
            "type": "object",
            "properties": {
                "query": {
                    "oneOf": [
                        {
                            "type": "object",
                            "properties": {
                                "kind": {
                                    "type": "string",
                                    "const": "events"
                                },
                                "limit": {
                                    "description": "Number of events to return per page.",
                                    "default": 500,
                                    "type": "integer",
                                    "minimum": 1,
                                    "maximum": 500
                                },
                                "offset": {
                                    "description": "Number of events to skip for pagination.",
                                    "default": 0,
                                    "type": "integer",
                                    "minimum": 0,
                                    "maximum": 9007199254740991
                                }
                            },
                            "required": ["kind"]
                        },
                        {
                            "type": "object",
                            "properties": {
                                "kind": {
                                    "type": "string",
                                    "const": "event_properties"
                                },
                                "event_name": {
                                    "type": "string",
                                    "description": "The name of the event that you want to retrieve properties for."
                                }
                            },
                            "required": ["kind", "event_name"]
                        },
                        {
                            "type": "object",
                            "properties": {
                                "kind": {
                                    "type": "string",
                                    "const": "entity_properties"
                                },
                                "entity": {
                                    "type": "string",
                                    "description": "The type of the entity that you want to retrieve properties for."
                                }
                            },
                            "required": ["kind", "entity"]
                        },
                        {
                            "type": "object",
                            "properties": {
                                "kind": {
                                    "type": "string",
                                    "const": "action_properties"
                                },
                                "action_id": {
                                    "type": "integer",
                                    "minimum": -9007199254740991,
                                    "maximum": 9007199254740991,
                                    "description": "The ID of the action that you want to retrieve properties for."
                                }
                            },
                            "required": ["kind", "action_id"]
                        },
                        {
                            "type": "object",
                            "properties": {
                                "kind": {
                                    "type": "string",
                                    "const": "entity_property_values"
                                },
                                "entity": {
                                    "type": "string",
                                    "description": "The type of the entity that you want to retrieve properties for."
                                },
                                "property_name": {
                                    "type": "string",
                                    "description": "Verified property name of an entity."
                                }
                            },
                            "required": ["kind", "entity", "property_name"]
                        },
                        {
                            "type": "object",
                            "properties": {
                                "kind": {
                                    "type": "string",
                                    "const": "event_property_values"
                                },
                                "event_name": {
                                    "type": "string",
                                    "description": "Verified event name"
                                },
                                "property_name": {
                                    "type": "string",
                                    "description": "Verified property name of an event."
                                }
                            },
                            "required": ["kind", "event_name", "property_name"]
                        },
                        {
                            "type": "object",
                            "properties": {
                                "kind": {
                                    "type": "string",
                                    "const": "action_property_values"
                                },
                                "action_id": {
                                    "type": "integer",
                                    "minimum": -9007199254740991,
                                    "maximum": 9007199254740991,
                                    "description": "Verified action ID"
                                },
                                "property_name": {
                                    "type": "string",
                                    "description": "Verified property name of an action."
                                }
                            },
                            "required": ["kind", "action_id", "property_name"]
                        }
                    ],
                    "description": "The data schema query to execute."
                }
            },
            "required": ["query"]
        },
        "ReadDataWarehouseSchemaSchema": {
            "type": "object",
            "properties": {},
            "description": "No input required. Returns core data warehouse schemas."
        },
        "ScoreDefinitionConfigSchema": {
            "anyOf": [
                {
                    "type": "object",
                    "properties": {
                        "options": {
                            "minItems": 1,
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "key": {
                                        "type": "string",
                                        "minLength": 1,
                                        "maxLength": 128,
                                        "description": "Stable option key — lowercase letters, numbers, underscores, hyphens. Sent back when this option is selected."
                                    },
                                    "label": {
                                        "type": "string",
                                        "minLength": 1,
                                        "maxLength": 256,
                                        "description": "Human-readable label shown in the review UI."
                                    }
                                },
                                "required": ["key", "label"]
                            },
                            "description": "Ordered categorical options. Must contain at least one option with unique keys."
                        },
                        "selection_mode": {
                            "description": "Whether reviewers select one option or many. Defaults to \"single\".",
                            "type": "string",
                            "enum": ["single", "multiple"]
                        },
                        "min_selections": {
                            "description": "Minimum selections required. Only valid when selection_mode is \"multiple\".",
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 9007199254740991
                        },
                        "max_selections": {
                            "description": "Maximum selections allowed. Only valid when selection_mode is \"multiple\".",
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 9007199254740991
                        }
                    },
                    "required": ["options"],
                    "additionalProperties": false,
                    "description": "Config shape used when kind is \"categorical\"."
                },
                {
                    "type": "object",
                    "properties": {
                        "min": {
                            "description": "Optional inclusive minimum score.",
                            "type": "number"
                        },
                        "max": {
                            "description": "Optional inclusive maximum score (must be ≥ min).",
                            "type": "number"
                        },
                        "step": {
                            "description": "Optional increment step for numeric input, e.g. 1 or 0.5.",
                            "type": "number",
                            "exclusiveMinimum": 0
                        }
                    },
                    "additionalProperties": false,
                    "description": "Config shape used when kind is \"numeric\"."
                },
                {
                    "type": "object",
                    "properties": {
                        "true_label": {
                            "description": "Optional label shown for the true branch (e.g. \"Yes\").",
                            "type": "string",
                            "minLength": 1
                        },
                        "false_label": {
                            "description": "Optional label shown for the false branch (e.g. \"No\").",
                            "type": "string",
                            "minLength": 1
                        }
                    },
                    "additionalProperties": false,
                    "description": "Config shape used when kind is \"boolean\"."
                }
            ],
            "description": "Immutable scorer configuration. Pick the shape matching the scorer kind: categorical (options + selection_mode), numeric (min/max/step), or boolean (true_label/false_label). The server validates the shape against the kind on the parent scorer and returns 400 on a mismatch."
        },
        "UsageMetricFiltersSchema": {
            "anyOf": [
                {
                    "type": "object",
                    "properties": {
                        "source": {
                            "type": "string",
                            "const": "data_warehouse"
                        },
                        "table_name": {
                            "type": "string",
                            "description": "Name of a synced data warehouse table. Use `external-data-schemas-list` to discover available tables."
