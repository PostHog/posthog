{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "id": {
            "description": "A UUID string identifying this task run.",
            "type": "string"
        },
        "task_id": {
            "pattern": "^[a-z]{1,16}_[0-9A-Za-z]{22}$",
            "type": "string"
        }
    },
    "required": ["id", "task_id"],
    "type": "object"
}
