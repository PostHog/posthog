{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "application_id": {
            "type": "string"
        },
        "args_schema": {
            "additionalProperties": {},
            "propertyNames": {
                "type": "string"
            },
            "type": "object"
        },
        "description": {
            "type": "string"
        },
        "id": {
            "description": "A UUID string identifying this agent revision.",
            "type": "string"
        },
        "projectId": {
            "description": "Override the active project for this single call only. Does not change the active project — use switch-project for a persistent change. Defaults to the active project when omitted. Must be a project the API key can access, or the call returns a permission error.",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991,
            "type": "integer"
        },
        "source": {
            "type": "string"
        },
        "tool_id": {
            "pattern": "^[a-z0-9][a-z0-9_-]*$",
            "type": "string"
        }
    },
    "required": ["application_id", "id", "tool_id", "description", "args_schema", "source"],
    "type": "object"
}
