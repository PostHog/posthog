{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "application_id": {
            "type": "string"
        },
        "args_schema": {
            "additionalProperties": {},
            "propertyNames": {
                "type": "string"
            },
            "type": "object"
        },
        "description": {
            "type": "string"
        },
        "id": {
            "description": "A UUID string identifying this agent revision.",
            "type": "string"
        },
        "source": {
            "type": "string"
        },
        "tool_id": {
            "pattern": "^[a-z0-9][a-z0-9_-]*$",
            "type": "string"
        }
    },
    "required": ["application_id", "id", "tool_id", "description", "args_schema", "source"],
    "type": "object"
}
