{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "MCP-facing request shape: a plain object whose `model` is a nested discriminated union.\n\nStrict MCP clients (the Anthropic API, OpenCode) reject a top-level `anyOf`/`oneOf`,\nso this serializer keeps the request root a plain object and nests the union under\n`model`. It exists alongside ‚Äî not in place of ‚Äî the flat\n`FileDownloadBatchExportOnDemandSerializer` so the public REST `create` wire format is\nunchanged; persistence is delegated to that serializer.",
    "properties": {
        "data_interval_end": {
            "description": "ISO 8601 end of the export interval. The interval must be at most one week.",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
            "type": "string"
        },
        "data_interval_start": {
            "description": "ISO 8601 start of the export interval. The interval must be at most one week.",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
            "type": "string"
        },
        "file": {
            "description": "Typed configuration for a FileDownload batch-export destination.",
            "properties": {
                "compression": {
                    "anyOf": [
                        {
                            "description": "* `brotli` - brotli\n* `gzip` - gzip\n* `lz4` - lz4\n* `snappy` - snappy\n* `zstd` - zstd",
                            "enum": ["brotli", "gzip", "lz4", "snappy", "zstd"],
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "description": "Compress the file with a supported compression format\n\n* `zstd` - zstd\n* `gzip` - gzip\n* `brotli` - brotli\n* `lz4` - lz4\n* `snappy` - snappy"
                },
                "format": {
                    "default": "Parquet",
                    "description": "File format\n\n* `Parquet` - Parquet\n* `JSONLines` - JSONLines",
                    "enum": ["JSONLines", "Parquet"],
                    "type": "string"
                },
                "max_size_mb": {
                    "anyOf": [
                        {
                            "minimum": 0,
                            "type": "number"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "description": "Split download into multiple files of at most this size in MB"
                }
            },
            "type": "object"
        },
        "model": {
            "anyOf": [
                {
                    "description": "Events model, with optional event-name filters.",
                    "properties": {
                        "exclude": {
                            "description": "Event names to exclude from the export.",
                            "items": {
                                "type": "string"
                            },
                            "type": "array"
                        },
                        "include": {
                            "description": "Event names to include in the export.",
                            "items": {
                                "type": "string"
                            },
                            "type": "array"
                        },
                        "type": {
                            "enum": ["events"],
                            "type": "string"
                        }
                    },
                    "required": ["type"],
                    "type": "object"
                },
                {
                    "description": "Persons model.",
                    "properties": {
                        "type": {
                            "enum": ["persons"],
                            "type": "string"
                        }
                    },
                    "required": ["type"],
                    "type": "object"
                },
                {
                    "description": "Sessions model.",
                    "properties": {
                        "type": {
                            "enum": ["sessions"],
                            "type": "string"
                        }
                    },
                    "required": ["type"],
                    "type": "object"
                }
            ],
            "description": "Object selecting the export model via `type`."
        }
    },
    "required": ["file", "model", "data_interval_start", "data_interval_end"],
    "type": "object"
}
