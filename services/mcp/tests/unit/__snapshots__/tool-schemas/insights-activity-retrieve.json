{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "id": {
            "description": "A unique integer value identifying this insight.",
            "type": "number"
        },
        "limit": {
            "description": "Page size. Defaults to 10.",
            "type": "number"
        },
        "page": {
            "description": "1-indexed page number. Defaults to 1.",
            "type": "number"
        }
    },
    "required": ["id"],
    "type": "object"
}
