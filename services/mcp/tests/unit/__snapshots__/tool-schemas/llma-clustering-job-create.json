{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "analysis_level": {
            "description": "* `trace` - trace\n* `generation` - generation\n* `evaluation` - evaluation",
            "enum": ["trace", "generation", "evaluation"],
            "type": "string"
        },
        "enabled": {
            "type": "boolean"
        },
        "event_filters": {},
        "name": {
            "maxLength": 100,
            "type": "string"
        }
    },
    "required": ["name", "analysis_level"],
    "type": "object"
}
