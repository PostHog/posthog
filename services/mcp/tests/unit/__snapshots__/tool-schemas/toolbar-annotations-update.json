{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "annotation_status": {
            "description": "New lifecycle status: 'acknowledged' (picked up), 'resolved' (addressed), or 'dismissed' (won't fix). Leave unset to only update the resolution note.",
            "enum": ["pending", "acknowledged", "resolved", "dismissed"],
            "type": "string"
        },
        "comment": {
            "description": "The annotation note the user wrote about the element.",
            "maxLength": 5000,
            "type": "string"
        },
        "element_chain": {
            "anyOf": [
                {
                    "maxLength": 20000,
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "description": "Serialized autocapture-style element chain from the element up to the document root."
        },
        "element_context": {
            "additionalProperties": {},
            "description": "Structured element metadata (inferred selectors, attributes, component hints).",
            "propertyNames": {
                "type": "string"
            },
            "type": "object"
        },
        "element_text": {
            "anyOf": [
                {
                    "maxLength": 2048,
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "description": "Visible text of the annotated element, if any."
        },
        "host": {
            "description": "Hostname of the page, used to scope annotations to a site.",
            "maxLength": 255,
            "type": "string"
        },
        "id": {
            "description": "A UUID string identifying this toolbar annotation.",
            "type": "string"
        },
        "pathname": {
            "anyOf": [
                {
                    "maxLength": 2048,
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "description": "Path portion of the URL."
        },
        "resolution": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "description": "Note describing what was done about the annotation."
        },
        "screenshot_url": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "description": "URL of an uploaded screenshot captured with the annotation."
        },
        "selector": {
            "description": "CSS selector that locates the annotated element on the page.",
            "maxLength": 4096,
            "type": "string"
        },
        "url": {
            "description": "Full URL of the page the annotation was made on.",
            "maxLength": 2048,
            "type": "string"
        },
        "viewport": {
            "anyOf": [
                {
                    "properties": {
                        "height": {
                            "description": "Viewport height in pixels.",
                            "type": "number"
                        },
                        "width": {
                            "description": "Viewport width in pixels.",
                            "type": "number"
                        }
                    },
                    "type": "object"
                },
                {
                    "type": "null"
                }
            ],
            "description": "Viewport size when the annotation was made, as {width, height}."
        }
    },
    "required": ["id"],
    "type": "object"
}
