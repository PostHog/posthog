{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "report_id": {
            "type": "string"
        },
        "task_id": {
            "anyOf": [
                {
                    "format": "uuid",
                    "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "description": "Task to associate with the report (must belong to this project). Omit to associate the calling agent's own task, derived from the X-PostHog-Task-Id header."
        }
    },
    "required": ["report_id"],
    "type": "object"
}
