{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "group_type_index": {
            "description": "Zero-based index of the group type this metric belongs to.",
            "maximum": 2147483647,
            "minimum": -2147483648,
            "type": "number"
        },
        "id": {
            "description": "A UUID string identifying this group usage metric.",
            "type": "string"
        }
    },
    "required": ["group_type_index", "id"],
    "type": "object"
}
