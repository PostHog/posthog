            "description": "Optional invocation ID for correlation."
        },
        "mock_async_functions": {
            "default": true,
            "description": "When true (default), async functions like fetch() are simulated.",
            "type": "boolean"
        }
    },
    "required": ["id", "configuration"],
    "type": "object"
}
