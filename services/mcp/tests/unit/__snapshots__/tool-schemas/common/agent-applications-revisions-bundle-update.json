{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "application_id": {
            "type": "string"
        },
        "files": {
            "additionalProperties": {
                "type": "string"
            },
            "propertyNames": {
                "type": "string"
            },
            "type": "object"
        },
        "id": {
            "description": "A UUID string identifying this agent revision.",
            "type": "string"
        },
        "mode": {
            "default": "replace",
            "description": "* `replace` - replace\n* `merge` - merge",
            "enum": ["replace", "merge"],
            "type": "string"
        }
    },
    "required": ["application_id", "id", "files"],
    "type": "object"
}
