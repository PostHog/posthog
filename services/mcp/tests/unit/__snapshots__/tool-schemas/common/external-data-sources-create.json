{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Mixin for serializers to add user access control fields",
    "properties": {
        "description": {
            "anyOf": [
                {
                    "maxLength": 400,
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ]
        },
        "job_inputs": {
            "anyOf": [
                {},
                {
                    "type": "null"
                }
            ]
        },
        "prefix": {
            "anyOf": [
                {
                    "maxLength": 100,
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ]
        }
    },
    "type": "object"
}
