{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "external_id": {
            "anyOf": [
                {
                    "maxLength": 400,
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "description": "Identifier for the account in an external system (e.g. CRM ID). Optional."
        },
        "id": {
            "description": "A UUID string identifying this account.",
            "type": "string"
        },
        "name": {
            "description": "Human-readable name of the account.",
            "maxLength": 400,
            "type": "string"
        },
        "properties": {
            "anyOf": [
                {
                    "properties": {
                        "account_executive": {
                            "anyOf": [
                                {
                                    "properties": {
                                        "email": {
                                            "type": "string"
                                        },
                                        "id": {
                                            "type": "number"
                                        }
                                    },
                                    "required": ["id", "email"],
                                    "type": "object"
                                },
                                {
                                    "type": "null"
                                }
                            ]
                        },
                        "account_owner": {
                            "anyOf": [
                                {
                                    "properties": {
                                        "email": {
                                            "type": "string"
                                        },
                                        "id": {
                                            "type": "number"
                                        }
                                    },
                                    "required": ["id", "email"],
                                    "type": "object"
                                },
                                {
                                    "type": "null"
                                }
                            ]
                        },
                        "csm": {
                            "anyOf": [
                                {
                                    "properties": {
                                        "email": {
                                            "type": "string"
                                        },
                                        "id": {
                                            "type": "number"
                                        }
                                    },
                                    "required": ["id", "email"],
                                    "type": "object"
                                },
                                {
                                    "type": "null"
                                }
                            ]
                        },
                        "group_keys": {
                            "items": {
                                "type": "string"
                            },
                            "type": "array"
                        },
                        "group_type_index": {
                            "anyOf": [
                                {
                                    "type": "number"
                                },
                                {
                                    "type": "null"
                                }
                            ]
                        }
                    },
                    "type": "object"
                },
                {
                    "type": "null"
                }
            ],
            "description": "Typed account properties. Pass only the fields you want to change — the server replaces the `properties` object as a whole, so include any existing values you want to preserve. `group_keys` must reference groups of the configured `group_type_index`."
        }
    },
    "required": ["id"],
    "type": "object"
}
