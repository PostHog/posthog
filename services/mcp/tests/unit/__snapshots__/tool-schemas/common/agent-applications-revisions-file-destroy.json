{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "application_id": {
            "type": "string"
        },
        "id": {
            "description": "A UUID string identifying this agent revision.",
            "type": "string"
        },
        "path": {
            "description": "Bundle-relative file path, e.g. `agent.md` or `skills/research.md`.",
            "type": "string"
        }
    },
    "required": ["application_id", "id", "path"],
    "type": "object"
}
