{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "account_id": {
            "type": "string"
        },
        "client_secret": {
            "type": "string"
        },
        "created_via": {
            "description": "How this source was created. Defaults to `api` on create when omitted. `web` for the in-app UI, `api` for direct API callers, `mcp` for agent/MCP tool calls. Ignored on update.\n\n* `web` - web\n* `api` - api\n* `mcp` - mcp",
            "enum": ["web", "api", "mcp"],
            "type": "string"
        },
        "description": {
            "anyOf": [
                {
                    "maxLength": 400,
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ]
        },
        "id": {
            "description": "A UUID string identifying this external data source.",
            "type": "string"
        },
        "job_inputs": {
            "anyOf": [
                {},
                {
                    "type": "null"
                }
            ]
        },
        "prefix": {
            "anyOf": [
                {
                    "maxLength": 100,
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ]
        }
    },
    "required": ["id", "client_secret", "account_id"],
    "type": "object"
}
