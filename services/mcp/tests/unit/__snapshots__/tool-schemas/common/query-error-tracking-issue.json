{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "dateRange": {
            "default": {
                "date_from": "-7d"
            },
            "description": "Scopes the impact counts, latest event context, latest release, and optional sparkline for this issue. Defaults to the last 7 days; widen it when you need counts beyond that window.",
            "properties": {
                "date_from": {
                    "type": "string"
                },
                "date_to": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ]
                }
            },
            "type": "object"
        },
        "filterTestAccounts": {
            "default": true,
            "description": "When true, exclude internal/test account data from results. Defaults to true.",
            "type": "boolean"
        },
        "includeSparkline": {
            "default": false,
            "description": "Set true to include a compact numeric occurrence sparkline. Defaults to false to save tokens.",
            "type": "boolean"
        },
        "issueId": {
            "description": "Error tracking issue ID.",
            "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
            "type": "string"
        },
        "volumeResolution": {
            "default": 0,
            "maximum": 9007199254740991,
            "minimum": 0,
            "type": "integer"
        }
    },
    "required": ["issueId"],
    "type": "object"
}
