{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "query": {
            "description": "The metric query to execute.",
            "properties": {
                "aggregation": {
                    "default": "sum",
                    "description": "Aggregation applied per time bucket.\n\n* `sum` - sum\n* `avg` - avg\n* `count` - count\n* `p95` - p95",
                    "enum": ["sum", "avg", "count", "p95"],
                    "type": "string"
                },
                "dateFrom": {
                    "description": "Lower bound (inclusive) for the query range. ISO 8601.",
                    "format": "date-time",
                    "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
                    "type": "string"
                },
                "dateTo": {
                    "description": "Upper bound (exclusive) for the query range. Defaults to now if omitted.",
                    "format": "date-time",
                    "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
                    "type": "string"
                },
                "metricName": {
                    "description": "Exact metric name to query (e.g. 'http.server.duration').",
                    "maxLength": 255,
                    "type": "string"
                }
            },
            "required": ["metricName", "dateFrom"],
            "type": "object"
        }
    },
    "required": ["query"],
    "type": "object"
}
