{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "description": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "description": "Updated issue description."
        },
        "id": {
            "type": "string"
        },
        "name": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "description": "Updated issue name."
        },
        "status": {
            "description": "Updated issue status.\n\n* `archived` - archived\n* `active` - active\n* `resolved` - resolved\n* `pending_release` - pending_release\n* `suppressed` - suppressed",
            "enum": ["archived", "active", "resolved", "pending_release", "suppressed"],
            "type": "string"
        }
    },
    "required": ["id"],
    "type": "object"
}
