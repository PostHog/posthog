{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "limit": {
            "description": "Number of results to return per page.",
            "type": "number"
        },
        "monitors": {
            "description": "List of monitors to create. All-or-nothing: created atomically.",
            "items": {
                "properties": {
                    "name": {
                        "description": "Human-readable name of the monitor.",
                        "maxLength": 255,
                        "type": "string"
                    },
                    "url": {
                        "description": "HTTP(S) URL to ping every 5 minutes.",
                        "format": "uri",
                        "maxLength": 2048,
                        "type": "string"
                    }
                },
                "required": ["name", "url"],
                "type": "object"
            },
            "type": "array"
        },
        "offset": {
            "description": "The initial index from which to return the results.",
            "type": "number"
        }
    },
    "required": ["monitors"],
    "type": "object"
}
