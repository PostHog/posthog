{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "query": {
            "description": "Bubble-up query parameters.",
            "properties": {
                "dateRange": {
                    "description": "Overall query date range.",
                    "properties": {
                        "date_from": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "null"
                                }
                            ],
                            "description": "Start of the date range. Accepts ISO 8601 timestamps or relative formats: -1h, -6h, -1d, -7d, etc."
                        },
                        "date_to": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "null"
                                }
                            ],
                            "description": "End of the date range. Same format as date_from. Omit or null for \"now\"."
                        }
                    },
                    "type": "object"
                },
                "filterGroup": {
                    "default": [],
                    "items": {
                        "properties": {
                            "key": {
                                "description": "Attribute key. For type \"span\", use built-in fields (trace_id, span_id, duration, name, kind, status_code). For \"span_attribute\"/\"span_resource_attribute\", use the attribute key (e.g. \"http.method\").",
                                "type": "string"
                            },
                            "operator": {
                                "description": "Comparison operator.\n\n* `exact` - exact\n* `is_not` - is_not\n* `icontains` - icontains\n* `not_icontains` - not_icontains\n* `regex` - regex\n* `not_regex` - not_regex\n* `gt` - gt\n* `lt` - lt\n* `is_set` - is_set\n* `is_not_set` - is_not_set",
                                "enum": [
                                    "exact",
                                    "is_not",
                                    "icontains",
                                    "not_icontains",
                                    "regex",
                                    "not_regex",
                                    "gt",
                                    "lt",
                                    "is_set",
                                    "is_not_set"
                                ],
                                "type": "string"
                            },
                            "type": {
                                "description": "\"span\" filters built-in span fields. \"span_attribute\" filters span-level attributes. \"span_resource_attribute\" filters resource-level attributes.\n\n* `span` - span\n* `span_attribute` - span_attribute\n* `span_resource_attribute` - span_resource_attribute",
                                "enum": ["span", "span_attribute", "span_resource_attribute"],
                                "type": "string"
                            },
                            "value": {
                                "anyOf": [
                                    {},
                                    {
                                        "type": "null"
                                    }
                                ],
                                "description": "Value to compare against. String, number, or array of strings. Omit for is_set/is_not_set operators."
                            }
                        },
                        "required": ["key", "type", "operator"],
                        "type": "object"
                    },
                    "type": "array"
                },
                "region": {
                    "description": "Brushed subset to compare against the baseline.",
                    "properties": {
                        "duration_max_nano": {
                            "description": "Maximum duration in nanoseconds (exclusive).",
                            "type": "number"
                        },
                        "duration_min_nano": {
                            "description": "Minimum duration in nanoseconds (inclusive).",
                            "type": "number"
                        },
                        "time_from": {
                            "description": "ISO 8601 start of brushed time range (inclusive).",
                            "type": "string"
                        },
                        "time_to": {
                            "description": "ISO 8601 end of brushed time range (exclusive).",
                            "type": "string"
                        }
                    },
                    "required": ["time_from", "time_to", "duration_min_nano", "duration_max_nano"],
                    "type": "object"
                },
                "rootSpans": {
                    "default": true,
                    "type": "boolean"
                },
                "serviceNames": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "statusCodes": {
                    "items": {
                        "type": "number"
                    },
                    "type": "array"
                }
            },
            "required": ["region"],
            "type": "object"
        }
    },
    "required": ["query"],
    "type": "object"
}
