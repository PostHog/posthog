{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "id": {
            "description": "A unique integer value identifying this cohort.",
            "type": "number"
        },
        "person_ids": {
            "description": "List of person UUIDs to add to the cohort",
            "items": {
                "type": "string"
            },
            "type": "array"
        }
    },
    "required": ["id"],
    "type": "object"
}
