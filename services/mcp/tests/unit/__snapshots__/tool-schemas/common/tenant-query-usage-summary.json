{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "connection_id": {
            "description": "Optional direct Postgres connection ID to filter executions.",
            "type": "string"
        },
        "date_from": {
            "description": "Start timestamp for the execution log search. Defaults to 24 hours before date_to.",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
            "type": "string"
        },
        "date_to": {
            "description": "End timestamp for the execution log search. Defaults to now.",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
            "type": "string"
        },
        "limit": {
            "default": 100,
            "description": "Maximum number of executions or summary rows to return.",
            "maximum": 1000,
            "minimum": 1,
            "type": "number"
        },
        "tenant_value": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "number"
                },
                {
                    "type": "null"
                },
                {
                    "type": "null"
                },
                {
                    "type": "null"
                }
            ],
            "description": "Optional tenant value to filter executions."
        }
    },
    "type": "object"
}
