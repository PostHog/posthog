{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "archived": {
            "default": false,
            "type": "boolean"
        },
        "description": {
            "type": "string"
        },
        "name": {
            "maxLength": 255,
            "type": "string"
        },
        "slug": {
            "maxLength": 63,
            "type": "string"
        }
    },
    "required": ["name", "slug"],
    "type": "object"
}
