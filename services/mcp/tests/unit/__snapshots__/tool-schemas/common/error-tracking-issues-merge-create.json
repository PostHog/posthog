{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "id": {
            "description": "A UUID string identifying this error tracking issue.",
            "type": "string"
        },
        "ids": {
            "description": "IDs of the issues to merge into the current issue.",
            "items": {
                "type": "string"
            },
            "type": "array"
        }
    },
    "required": ["id", "ids"],
    "type": "object"
}
