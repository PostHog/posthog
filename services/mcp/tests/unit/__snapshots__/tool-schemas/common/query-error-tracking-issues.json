{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "assignee": {
            "anyOf": [
                {
                    "properties": {
                        "id": {
                            "anyOf": [
                                {
                                    "maximum": 9007199254740991,
                                    "minimum": -9007199254740991,
                                    "type": "integer"
                                },
                                {
                                    "type": "string"
                                }
                            ]
                        },
                        "type": {
                            "enum": ["user", "role"],
                            "type": "string"
                        }
                    },
                    "required": ["id", "type"],
                    "type": "object"
                },
                {
                    "type": "null"
                }
            ],
            "description": "Filter by assignee."
        },
        "dateRange": {
            "default": {
                "date_from": "-7d"
            },
            "description": "Date range to filter results.",
            "properties": {
                "date_from": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "description": "Start of the date range. Accepts ISO 8601 timestamps (e.g., 2024-01-15T00:00:00Z) or relative formats: -7d (7 days ago), -2w (2 weeks ago), -1m (1 month ago),\n-1h (1 hour ago), -1mStart (start of last month), -1yStart (start of last year)."
                },
                "date_to": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "description": "End of the date range. Same format as date_from. Omit or null for \"now\"."
                },
                "explicitDate": {
                    "anyOf": [
                        {
                            "type": "boolean"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": false,
                    "description": "Whether the date_from and date_to should be used verbatim. Disables rounding to the start and end of period."
                }
            },
            "type": "object"
        },
        "filterTestAccounts": {
            "default": true,
            "description": "Whether to filter out test accounts.",
            "type": "boolean"
        },
        "issueId": {
            "description": "Filter to a specific error tracking issue by ID.",
            "type": "string"
        },
        "kind": {
            "const": "ErrorTrackingQuery",
            "default": "ErrorTrackingQuery",
            "type": "string"
        },
        "limit": {
            "default": 50,
            "maximum": 9007199254740991,
            "minimum": -9007199254740991,
            "type": "integer"
        },
        "offset": {
            "maximum": 9007199254740991,
            "minimum": -9007199254740991,
            "type": "integer"
        },
        "orderBy": {
            "default": "occurrences",
            "description": "Field to sort results by.",
            "enum": ["last_seen", "first_seen", "occurrences", "users", "sessions"],
            "type": "string"
        },
        "orderDirection": {
            "default": "DESC",
            "description": "Sort direction.",
            "enum": ["ASC", "DESC"],
            "type": "string"
        },
        "searchQuery": {
            "description": "Free-text search across exception type, message, and stack frames.",
            "type": "string"
        },
        "status": {
            "anyOf": [
                {
                    "enum": ["archived", "active", "resolved", "pending_release", "suppressed"],
                    "type": "string"
                },
                {
                    "const": "all",
                    "type": "string"
                }
            ],
            "default": "active",
            "description": "Filter by issue status."
        },
        "volumeResolution": {
            "default": 1,
            "description": "Controls volume chart granularity. Use 1 for sparklines, 0 for counts only.",
            "maximum": 9007199254740991,
            "minimum": -9007199254740991,
            "type": "integer"
        }
    },
    "type": "object"
}
