{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "description": {
            "description": "Longer description of the incident, shown publicly.",
            "type": "string"
        },
        "monitor_id": {
            "description": "ID of the monitor this incident is attached to.",
            "type": "string"
        },
        "name": {
            "description": "Short, human-readable incident title.",
            "maxLength": 255,
            "type": "string"
        },
        "resolution_note": {
            "description": "Resolution note. Required when resolved_at is set.",
            "type": "string"
        },
        "resolved_at": {
            "anyOf": [
                {
                    "format": "date-time",
                    "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "description": "When the incident was resolved. Omit or null for an ongoing incident."
        },
        "started_at": {
            "description": "When the incident started. Defaults to the time the incident was created.",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
            "type": "string"
        }
    },
    "required": ["monitor_id", "name"],
    "type": "object"
}
