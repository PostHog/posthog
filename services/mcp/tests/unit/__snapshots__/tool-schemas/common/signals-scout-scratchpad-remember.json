{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Request body for `remember`.",
    "properties": {
        "content": {
            "description": "Prose to write. Read verbatim into future prompts.",
            "maxLength": 50000,
            "type": "string"
        },
        "key": {
            "description": "Agent-chosen semantic key. Re-using a key updates the existing entry in place.",
            "maxLength": 300,
            "type": "string"
        },
        "run_id": {
            "anyOf": [
                {
                    "format": "uuid",
                    "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "description": "Run that authored this memory; persisted as `created_by_run_id` for lineage. Must reference a run on this same project — cross-project run UUIDs are rejected."
        }
    },
    "required": ["key", "content"],
    "type": "object"
}
