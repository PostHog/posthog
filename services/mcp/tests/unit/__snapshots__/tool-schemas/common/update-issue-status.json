{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "issueId": {
            "description": "The ID of the error tracking issue to update",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
            "type": "string"
        },
        "status": {
            "description": "The new status for the issue: active, resolved, archived, suppressed, or pending_release",
            "enum": ["active", "resolved", "archived", "suppressed", "pending_release"],
            "type": "string"
        }
    },
    "required": ["issueId", "status"],
    "type": "object"
}
