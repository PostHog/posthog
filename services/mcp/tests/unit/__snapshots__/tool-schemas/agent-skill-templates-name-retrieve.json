{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "name": {
            "pattern": "^[^/]+$",
            "type": "string"
        },
        "version": {
            "description": "Fetch a specific version. Omit for the current `is_latest=true` row.",
            "type": "number"
        }
    },
    "required": ["name"],
    "type": "object"
}
