                                    "is_cleaned_path_exact",
                                    "flag_evaluates_to",
                                    "semver_eq",
                                    "semver_neq",
                                    "semver_gt",
                                    "semver_gte",
                                    "semver_lt",
                                    "semver_lte",
                                    "semver_tilde",
                                    "semver_caret",
                                    "semver_wildcard",
                                    "icontains_multi",
                                    "not_icontains_multi"
                                ],
                                "type": "string"
                            },
                            "type": {
                                "const": "cohort",
                                "default": "cohort",
                                "type": "string"
                            },
                            "value": {
                                "maximum": 9007199254740991,
                                "minimum": -9007199254740991,
                                "type": "integer"
                            }
