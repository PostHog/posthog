{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "id": {
            "description": "A unique integer value identifying this dashboard.",
            "type": "number"
        },
        "widgets": {
            "description": "Widget tiles to add atomically. Supported widget_type values: error_tracking_list, session_replay_list. Use dashboard-widget-catalog-list for config_schema_hints per type. (1–10 per request).",
            "items": {
                "anyOf": [
                    {
                        "properties": {
                            "config": {
                                "description": "Configuration for the error tracking list widget.",
                                "properties": {
                                    "dateRange": {
                                        "anyOf": [
                                            {
                                                "properties": {
                                                    "date_from": {
                                                        "anyOf": [
                                                            {
                                                                "description": "* `-14d` - -14d\n* `-1h` - -1h\n* `-24h` - -24h\n* `-30d` - -30d\n* `-3h` - -3h\n* `-7d` - -7d\n* `-90d` - -90d",
                                                                "enum": [
                                                                    "-14d",
                                                                    "-1h",
                                                                    "-24h",
                                                                    "-30d",
                                                                    "-3h",
                                                                    "-7d",
                                                                    "-90d"
                                                                ],
                                                                "type": "string"
                                                            },
                                                            {
                                                                "type": "null"
                                                            }
                                                        ],
                                                        "description": "Relative lookback window (for example '-7d'). Omit to use the project default range.\n\n* `-14d` - -14d\n* `-1h` - -1h\n* `-24h` - -24h\n* `-30d` - -30d\n* `-3h` - -3h\n* `-7d` - -7d\n* `-90d` - -90d"
                                                    }
                                                },
                                                "type": "object"
                                            },
                                            {
                                                "type": "null"
                                            }
                                        ],
                                        "description": "Optional relative date range override."
                                    },
                                    "filterTestAccounts": {
                                        "description": "When omitted, follows the project default for filtering test accounts.",
                                        "type": "boolean"
                                    },
                                    "limit": {
                                        "default": 10,
                                        "description": "Maximum number of issues to return.",
                                        "maximum": 25,
                                        "minimum": 1,
                                        "type": "number"
                                    },
                                    "orderBy": {
                                        "default": "occurrences",
                                        "description": "Issue ranking column.\n\n* `first_seen` - first_seen\n* `last_seen` - last_seen\n* `occurrences` - occurrences\n* `sessions` - sessions\n* `users` - users",
                                        "enum": ["last_seen", "first_seen", "occurrences", "users", "sessions"],
                                        "type": "string"
                                    },
                                    "orderDirection": {
                                        "default": "DESC",
                                        "description": "Sort direction for orderBy.\n\n* `ASC` - ASC\n* `DESC` - DESC",
                                        "enum": ["ASC", "DESC"],
                                        "type": "string"
                                    },
                                    "status": {
                                        "default": "active",
                                        "description": "Issue status filter.\n\n* `archived` - archived\n* `active` - active\n* `resolved` - resolved\n* `pending_release` - pending_release\n* `suppressed` - suppressed\n* `all` - all",
                                        "enum": [
                                            "archived",
                                            "active",
                                            "resolved",
                                            "pending_release",
                                            "suppressed",
                                            "all"
                                        ],
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            },
                            "description": {
                                "description": "Optional markdown description shown when show_description is enabled.",
                                "type": "string"
                            },
                            "layouts": {
                                "description": "Optional react-grid-layout positions keyed by breakpoint (sm, xs).",
                                "properties": {
                                    "sm": {
                                        "description": "Layout for the standard (desktop) breakpoint. The grid is 12 columns wide.",
                                        "properties": {
                                            "h": {
                                                "description": "Height in grid rows.",
                                                "type": "number"
                                            },
                                            "w": {
                                                "description": "Width in grid columns. The desktop grid is 12 columns wide.",
                                                "type": "number"
                                            },
                                            "x": {
                                                "description": "Column position in the dashboard grid (0-indexed).",
                                                "type": "number"
                                            },
                                            "y": {
                                                "description": "Row position in the dashboard grid (0-indexed).",
                                                "type": "number"
                                            }
                                        },
                                        "type": "object"
                                    },
                                    "xs": {
                                        "description": "Layout for the small (mobile) breakpoint. The grid is 1 column wide.",
                                        "properties": {
                                            "h": {
                                                "description": "Height in grid rows.",
                                                "type": "number"
                                            },
                                            "w": {
                                                "description": "Width in grid columns. The desktop grid is 12 columns wide.",
                                                "type": "number"
                                            },
                                            "x": {
                                                "description": "Column position in the dashboard grid (0-indexed).",
                                                "type": "number"
                                            },
                                            "y": {
                                                "description": "Row position in the dashboard grid (0-indexed).",
                                                "type": "number"
                                            }
                                        },
                                        "type": "object"
                                    }
                                },
                                "type": "object"
                            },
                            "name": {
                                "anyOf": [
                                    {
                                        "maxLength": 400,
                                        "type": "string"
                                    },
                                    {
                                        "type": "null"
                                    }
                                ],
                                "description": "Optional custom display name for the widget tile."
                            },
                            "show_description": {
                                "description": "Whether to show the description on the dashboard tile.",
                                "type": "boolean"
                            },
                            "widget_type": {
                                "enum": ["error_tracking_list"],
                                "type": "string"
                            }
                        },
                        "required": ["widget_type", "config"],
                        "type": "object"
                    },
                    {
                        "properties": {
                            "config": {
                                "description": "Configuration for the session replay list widget.",
                                "properties": {
                                    "dateRange": {
                                        "anyOf": [
                                            {
                                                "properties": {
                                                    "date_from": {
                                                        "anyOf": [
                                                            {
                                                                "description": "* `-14d` - -14d\n* `-1h` - -1h\n* `-24h` - -24h\n* `-30d` - -30d\n* `-3h` - -3h\n* `-7d` - -7d\n* `-90d` - -90d",
                                                                "enum": [
                                                                    "-14d",
                                                                    "-1h",
                                                                    "-24h",
                                                                    "-30d",
                                                                    "-3h",
                                                                    "-7d",
                                                                    "-90d"
                                                                ],
                                                                "type": "string"
                                                            },
                                                            {
                                                                "type": "null"
                                                            }
                                                        ],
                                                        "description": "Relative lookback window (for example '-7d'). Omit to use the project default range.\n\n* `-14d` - -14d\n* `-1h` - -1h\n* `-24h` - -24h\n* `-30d` - -30d\n* `-3h` - -3h\n* `-7d` - -7d\n* `-90d` - -90d"
                                                    }
                                                },
                                                "type": "object"
                                            },
                                            {
                                                "type": "null"
                                            }
                                        ],
                                        "description": "Optional relative date range override."
                                    },
                                    "filterTestAccounts": {
                                        "description": "When omitted, follows the project default for filtering test accounts.",
                                        "type": "boolean"
                                    },
                                    "limit": {
                                        "default": 10,
                                        "description": "Maximum number of recordings to return.",
                                        "maximum": 25,
                                        "minimum": 1,
                                        "type": "number"
                                    },
                                    "orderBy": {
                                        "default": "start_time",
                                        "description": "Recording ranking column.\n\n* `activity_score` - activity_score\n* `click_count` - click_count\n* `console_error_count` - console_error_count\n* `duration` - duration\n* `recording_duration` - recording_duration\n* `start_time` - start_time",
                                        "enum": [
                                            "activity_score",
                                            "click_count",
                                            "console_error_count",
                                            "duration",
                                            "recording_duration",
                                            "start_time"
                                        ],
                                        "type": "string"
                                    },
                                    "orderDirection": {
                                        "default": "DESC",
                                        "description": "Sort direction for orderBy.\n\n* `ASC` - ASC\n* `DESC` - DESC",
                                        "enum": ["ASC", "DESC"],
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            },
                            "description": {
                                "description": "Optional markdown description shown when show_description is enabled.",
                                "type": "string"
                            },
                            "layouts": {
                                "description": "Optional react-grid-layout positions keyed by breakpoint (sm, xs).",
                                "properties": {
                                    "sm": {
                                        "description": "Layout for the standard (desktop) breakpoint. The grid is 12 columns wide.",
                                        "properties": {
                                            "h": {
                                                "description": "Height in grid rows.",
                                                "type": "number"
                                            },
                                            "w": {
                                                "description": "Width in grid columns. The desktop grid is 12 columns wide.",
                                                "type": "number"
                                            },
                                            "x": {
                                                "description": "Column position in the dashboard grid (0-indexed).",
                                                "type": "number"
                                            },
                                            "y": {
                                                "description": "Row position in the dashboard grid (0-indexed).",
                                                "type": "number"
                                            }
                                        },
                                        "type": "object"
                                    },
                                    "xs": {
                                        "description": "Layout for the small (mobile) breakpoint. The grid is 1 column wide.",
                                        "properties": {
                                            "h": {
                                                "description": "Height in grid rows.",
                                                "type": "number"
                                            },
                                            "w": {
                                                "description": "Width in grid columns. The desktop grid is 12 columns wide.",
                                                "type": "number"
                                            },
                                            "x": {
                                                "description": "Column position in the dashboard grid (0-indexed).",
                                                "type": "number"
                                            },
                                            "y": {
                                                "description": "Row position in the dashboard grid (0-indexed).",
                                                "type": "number"
                                            }
                                        },
                                        "type": "object"
                                    }
                                },
                                "type": "object"
                            },
                            "name": {
                                "anyOf": [
                                    {
                                        "maxLength": 400,
                                        "type": "string"
                                    },
                                    {
                                        "type": "null"
                                    }
                                ],
                                "description": "Optional custom display name for the widget tile."
                            },
                            "show_description": {
                                "description": "Whether to show the description on the dashboard tile.",
                                "type": "boolean"
                            },
                            "widget_type": {
                                "enum": ["session_replay_list"],
                                "type": "string"
                            }
                        },
                        "required": ["widget_type", "config"],
                        "type": "object"
                    }
                ]
            },
            "maxItems": 10,
            "minItems": 1,
            "type": "array"
        }
    },
    "required": ["id", "widgets"],
    "type": "object"
}
