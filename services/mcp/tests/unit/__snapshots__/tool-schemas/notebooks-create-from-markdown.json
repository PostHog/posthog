{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "content": {
            "description": "Notebook markdown. Supports headings, lists, code fences, and <query> blocks for old-style query nodes. Prefer <query> blocks for SQL analysis.",
            "minLength": 1,
            "type": "string"
        },
        "title": {
            "description": "Title for the new notebook.",
            "maxLength": 256,
            "minLength": 1,
            "type": "string"
        }
    },
    "required": ["title", "content"],
    "type": "object"
}
