{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "new_name": {
            "description": "Name for the duplicated skill. Must be unique.",
            "maxLength": 64,
            "type": "string"
        },
        "skill_name": {
            "pattern": "^[^/]+$",
            "type": "string"
        }
    },
    "required": ["skill_name", "new_name"],
    "type": "object"
}
