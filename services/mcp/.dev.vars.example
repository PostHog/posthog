# Cloudflare Worker dev vars. The worker is a region-aware reverse proxy in
# front of the Hono MCP server — most settings now belong to Hono, not here.

# Override the per-region Hono target. Set this when running the worker against
# a local Hono dev server. Leave unset in production so the worker picks
# https://mcp.us.posthog.com / https://mcp.eu.posthog.com from the resolved region.
MCP_HONO_URL=http://localhost:8788

# Used by the worker's token-probe path (POST /api/users/@me) when figuring out
# a user's region. Local dev points both probes at the same backend.
POSTHOG_API_BASE_URL=http://localhost:8010
