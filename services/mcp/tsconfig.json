{
    "compilerOptions": {
        "target": "es2021",
        "lib": ["es2021", "dom", "dom.iterable"],
        "jsx": "react-jsx",
        "module": "es2022",
        "moduleResolution": "Bundler",
        "resolveJsonModule": true,
        "allowJs": true,
        "checkJs": false,
        "noEmit": true,
        "isolatedModules": true,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "skipLibCheck": true,
        "types": ["node", "./worker-configuration.d.ts", "./types.d.ts", "@cloudflare/vitest-pool-workers"],
        "baseUrl": ".",
        "paths": {
            "products/*": ["../../products/*"],
            "@/*": ["src/*", "tests/*"],
            "@shared/*": ["shared/*"],
            "@posthog/mosaic": ["../../common/mosaic/src/index.ts"],
            "@posthog/mosaic/*": ["../../common/mosaic/src/*"],
            "@common/*": ["../../common/*"],
            "lib/hog-charts/*": ["../../frontend/src/lib/hog-charts/*"],
            "lib/charts/types": ["../../frontend/src/lib/charts/types"],
            "react": ["./node_modules/@types/react"],
            "react/*": ["./node_modules/@types/react/*"],
            "d3-array": ["./node_modules/@types/d3-array"],
            "d3-color": ["./node_modules/@types/d3-color"],
            "d3-scale": ["./node_modules/@types/d3-scale"],
            "d3-shape": ["./node_modules/@types/d3-shape"],
            "@floating-ui/react": ["./node_modules/@floating-ui/react"]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "scripts/**/*.ts", "tests/**/*.ts", "worker-configuration.d.ts"],
    "exclude": ["node_modules", "dist"]
}
