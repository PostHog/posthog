{
    "compilerOptions": {
        "module": "CommonJS",
        "target": "ES2022",
        "lib": ["ES2022"],
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "useUnknownInCatchVariables": false,
        "types": ["node", "jest"]
    },
    "include": ["src"],
    "exclude": ["node_modules"]
}
