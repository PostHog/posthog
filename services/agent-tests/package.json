{
    "name": "@posthog/agent-tests",
    "version": "0.1.0",
    "private": true,
    "description": "End-to-end test harness for the agent platform: boots agent-ingress + agent-runner in-process against the local Postgres / queue Postgres / Kafka / ClickHouse stack and validates auth, identity, and runtime flows through real wires.",
    "license": "MIT",
    "author": "PostHog <hey@posthog.com>",
    "repository": "https://github.com/PostHog/posthog",
    "scripts": {
        "typescript:check": "tsc --noEmit -p .",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "jest --runInBand --forceExit"
    },
    "dependencies": {
        "@posthog/agent-core": "workspace:*",
        "@posthog/agent-ingress": "workspace:*",
        "@posthog/agent-runner": "workspace:*",
        "@repo/ass-server": "link:../../../agent-stack/packages/ass-server",
        "pg": "^8.10.0",
        "supertest": "^7.0.0",
        "ultimate-express": "^2.0.9",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint-community/eslint-plugin-eslint-comments": "^4.4.1",
        "@trivago/prettier-plugin-sort-imports": "^5.2.2",
        "@types/jest": "catalog:",
        "@types/node": "catalog:",
        "@types/pg": "^8.15.4",
        "@types/supertest": "^6.0.2",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-no-only-tests": "^3.1.0",
        "jest": "catalog:",
        "prettier": "^3.6.2",
        "ts-jest": "^29.1.0",
        "typescript": "catalog:"
    },
    "engines": {
        "node": ">=24 <25"
    }
}
