{
    "model": "anthropic/claude-sonnet-4-6",
    "reasoning": "low",
    "triggers": [
        {
            "type": "chat",
            "config": {
                "require_auth": false
            }
        }
    ],
    "tools": [
        {
            "kind": "native",
            "id": "@posthog/memory-write",
            "requires_approval": true,
            "approval_policy": {
                "approvers": ["team_admins"],
                "allow_edit": true,
                "ttl_ms": 86400000,
                "allow_agent_approver": false
            }
        },
        { "kind": "native", "id": "@posthog/memory-read" },
        { "kind": "native", "id": "@posthog/memory-search" }
    ],
    "skills": [
        {
            "id": "proposing-changes",
            "path": "skills/proposing-changes.md",
            "description": "How to react when a tool call returns a synthetic queued-approval envelope. Load on the first turn — this agent is built around the gate and the model needs to know how to communicate it."
        }
    ],
    "limits": {
        "max_turns": 10,
        "max_tool_calls": 20,
        "max_wall_seconds": 120
    },
    "auth": { "modes": [{ "type": "public", "acknowledge_public_exposure": true }] }
}
