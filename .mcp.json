{
    "mcpServers": {
        "phrocs": {
            "command": "uv",
            "args": ["run", "python", "tools/phrocs/mcp_server.py"]
        },
        "traffic-sim": {
            "command": "uv",
            "args": ["run", "python", "tools/traffic-sim/mcp_server.py"]
        },
        "playwright": {
            "command": "npx",
            "args": ["-y", "@playwright/mcp@latest"]
        }
    }
}
