{
    "compilerOptions": {
        "target": "es2021",
        "lib": ["es2021", "dom"],
        "jsx": "react-jsx",
        "module": "es2022",
        "moduleResolution": "Bundler",
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@posthog/mosaic": ["src/index.ts"],
            "@posthog/mosaic/*": ["src/*"],
            "@common/*": ["../*"]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "storybook/**/*.ts", "storybook/**/*.tsx"]
}
