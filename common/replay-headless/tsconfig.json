{
    "compilerOptions": {
        "target": "ES2020",
        "module": "esnext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "declaration": false,
        "outDir": "dist",
        "rootDir": "src",
        "lib": ["ES2020", "DOM"]
    },
    "include": ["src"],
    "exclude": ["src/__tests__"]
}
