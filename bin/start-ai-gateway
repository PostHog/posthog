#!/usr/bin/env bash
# Bring up the external Go ai-gateway (github.com/PostHog/ai-gateway) in
# OPEN mode for local dev, so the agent-runner can route model calls
# through it (anonymous principal, no per-request resolver). Idempotent
# apart from another anonymous-team ledger topup.
#
# What it does:
#   1. Verifies the sibling clone exists and has a .env.
#   2. Brings up the gateway's deps (postgres + valkey) via docker compose.
#      NOTE: the gateway's compose.yaml ships ONLY deps — the gateway and
#      billing binaries are run from source, not as compose services. (An
#      older version of this script assumed a `--profile full` that started
#      the binaries; that profile no longer exists.)
#   3. Backgrounds a seeder that waits for /readyz, then tops up the
#      anonymous-principal ledger (team_id = 0) so AI_GATEWAY_AUTH_MODE=open
#      requests pass admission. Without it the gateway 402s on every call.
#   4. Runs the gateway binary in the foreground (mprocs manages it).
#
# Open mode is forced here regardless of the clone's .env, since this entry
# exists for agent-runner routing. For the resolver / real-phs-token flow
# (auth + billing testing) see the gateway repo's docs/local-resolver-dev.md.
#
# Pair with `AGENT_USE_AI_GATEWAY=true` on agent-runner so the runner routes
# through http://localhost:8080/v1. With the flag off the runner uses direct
# providers (ANTHROPIC_API_KEY / OPENAI_API_KEY) and this entry is unused.

set -euo pipefail

# Default to the sibling clone next to this posthog checkout
# (e.g. ~/Code/posthog/ai-gateway alongside ~/Code/posthog/posthog).
POSTHOG_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
AI_GATEWAY_REPO="${AI_GATEWAY_REPO:-$(dirname "$POSTHOG_ROOT")/ai-gateway}"
TOPUP_USD="${AI_GATEWAY_DEV_TOPUP_USD:-100.00}"
GATEWAY_PORT="${AI_GATEWAY_PORT:-8080}"

if [ ! -d "$AI_GATEWAY_REPO" ]; then
    cat >&2 <<EOF
[start-ai-gateway] No sibling clone at $AI_GATEWAY_REPO.

Either clone it:
  git clone git@github.com:PostHog/ai-gateway.git "$AI_GATEWAY_REPO"

Or skip this entry in mprocs and set AGENT_USE_AI_GATEWAY=false on the
agent-runner — the runner falls back to direct providers automatically.

Override the path with AI_GATEWAY_REPO=... if your clone lives elsewhere.
EOF
    exit 1
fi

if [ ! -f "$AI_GATEWAY_REPO/.env" ]; then
    cat >&2 <<EOF
[start-ai-gateway] $AI_GATEWAY_REPO/.env is missing.

Create it (copy .env.example) with at minimum provider keys:
  AI_GATEWAY_ANTHROPIC_API_KEY=sk-ant-...
  AI_GATEWAY_OPENAI_API_KEY=sk-proj-...
EOF
    exit 1
fi

cd "$AI_GATEWAY_REPO"

# Provider keys (+ any other AI_GATEWAY_* config) from the clone's .env.
set -o allexport
# shellcheck disable=SC1091
source "$AI_GATEWAY_REPO/.env"
set +o allexport

echo "[start-ai-gateway] bringing up gateway deps (postgres + valkey)"
docker compose up -d --wait

# Seed the anonymous-team ledger once the gateway is serving. The gateway
# binary applies ledger migrations on startup, so the table only exists
# after it is up — hence the wait, and hence backgrounding this. The budget
# spans the foreground `go run` compile (cold builds can take minutes) plus
# the first catalog/pricing warm-up that /readyz blocks on, so it is sized
# generously: 150 * 2s = 5 min.
(
    for _ in $(seq 1 150); do
        if curl -sf "http://localhost:${GATEWAY_PORT}/readyz" >/dev/null 2>&1; then
            echo "[start-ai-gateway] seeding anonymous-team ledger (team_id=0, +${TOPUP_USD} USD)"
            docker compose exec -T postgres psql -U postgres -d ai_gateway -v ON_ERROR_STOP=1 -c \
                "INSERT INTO ledger_entries (team_id, transaction_type, source, destination, amount_usd) VALUES (0, 'topup', 'funding', 'prepaid', ${TOPUP_USD});" \
                >/dev/null || true
            exit 0
        fi
        sleep 2
    done
    # Loud, because the symptom (every open-mode call 402s on an
    # otherwise-healthy-looking gateway) is otherwise baffling to debug.
    echo "[start-ai-gateway] WARNING: gateway never became ready after 5 min; SKIPPED ledger topup." >&2
    echo "[start-ai-gateway] open-mode requests will 402 until you seed it (re-run this entry, or insert a team_id=0 topup)." >&2
) &

echo "[start-ai-gateway] running gateway (open mode) on http://localhost:${GATEWAY_PORT}"
# Force open mode + the gateway's own valkey/postgres regardless of the
# clone's .env (which may be configured for the resolver flow). The STUB
# flags are forced off too: a clone left with STUB_DISPATCH=true for offline
# work would otherwise leak through here and serve canned completions to the
# agent-runner with no error.
exec env \
    AI_GATEWAY_AUTH_MODE=open \
    AI_GATEWAY_LISTEN_ADDR=":${GATEWAY_PORT}" \
    AI_GATEWAY_REDIS_URL="redis://localhost:6381/0" \
    AI_GATEWAY_POSTGRES_DSN="postgres://postgres:postgres@localhost:5435/ai_gateway?sslmode=disable" \
    AI_GATEWAY_STUB_DISPATCH=false \
    AI_GATEWAY_STUB_PRICING=false \
    go run ./cmd/gateway
