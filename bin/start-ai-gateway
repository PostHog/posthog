#!/usr/bin/env bash
# hogli `ai_gateway` capability entry. Brings up the external Go ai-gateway
# (github.com/PostHog/ai-gateway) for local dev in resolver mode with a real
# phs_ credential, then runs it.
#
# The PostHog-side provisioning — enable the team, mint the phs_, publish the
# credential blob to the gateway's Valkey, fund the ledger, write .env.local —
# lives in bin/setup-gateway-e2e and runs here, retried until migrations are
# ready (this pane often starts before web/migrate finish). The gateway itself
# then runs from the sibling repo on the host under air.
#
# Pair with the agent-runner: setup-gateway-e2e writes AGENT_USE_AI_GATEWAY=true
# + POSTHOG_AI_GATEWAY_KEY into .env.local. With those absent the runner uses
# direct providers and this entry is unused.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
AI_GATEWAY_REPO="${AI_GATEWAY_REPO:-$HOME/Development/ai-gateway}"

if [ ! -d "$AI_GATEWAY_REPO" ]; then
    cat >&2 <<EOF
[start-ai-gateway] No sibling clone at $AI_GATEWAY_REPO.
  git clone git@github.com:PostHog/ai-gateway.git "$AI_GATEWAY_REPO"
Or disable the ai_gateway capability — the runner falls back to direct providers.
Override the path with AI_GATEWAY_REPO=... if your clone lives elsewhere.
EOF
    exit 1
fi

# Provision the credential end to end. Retries until PostHog's DB/migrations
# are ready; setup-gateway-e2e is idempotent so re-runs are cheap.
for i in $(seq 1 10); do
    if "$REPO_ROOT/bin/setup-gateway-e2e"; then
        break
    fi
    echo "[start-ai-gateway] waiting for PostHog (db/migrations) before provisioning (attempt $i/10)..."
    sleep 3
done

# Run the gateway on the host. bin/start brings up the sibling deps and runs
# under air with hot reload; it reads AI_GATEWAY_AUTH_MODE=resolver from the
# sibling .env that setup-gateway-e2e wrote.
cd "$AI_GATEWAY_REPO"
exec bin/start gateway
