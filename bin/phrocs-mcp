#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
venv=""
for candidate in "$repo_root/.flox/cache/venv" "$repo_root/.venv" "$repo_root/env"; do
    if [[ -x "$candidate/bin/python" ]]; then
        venv="$candidate"
        break
    fi
done

cd "$repo_root"
if [[ -n "$venv" ]]; then
    export PATH="$venv/bin:${PATH:-}"
    export VIRTUAL_ENV="$venv"
    export UV_PROJECT_ENVIRONMENT="$venv"
    exec "$venv/bin/python" "$repo_root/tools/phrocs/mcp_server.py"
fi

if command -v uv >/dev/null 2>&1; then
    exec env -u VIRTUAL_ENV -u UV_PROJECT_ENVIRONMENT uv run python "$repo_root/tools/phrocs/mcp_server.py"
fi

echo "error: run bin/setup-worktree-env before starting phrocs MCP" >&2
exit 127
