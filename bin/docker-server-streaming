#!/bin/bash
# Entrypoint for the dedicated SSE streaming tier.
#
# Serves posthog.asgi under granian (the ASGI server already used in dev and
# shipped as a prod dependency) instead of Nginx Unit. Unit recycles an app
# process after a fixed number of requests; a process holding long-lived SSE
# streams then drains (alive, serving nothing new) until its streams end, and
# a pod whose processes are all draining cannot answer health probes. Granian
# has no request-count recycling, so stream-holding workers are never put into
# a draining state. Process hygiene for this tier happens at the pod level.
#
# Long-lived streams also mean shutdown must be patient: pair this entrypoint
# with a terminationGracePeriodSeconds longer than one stream rotation so
# in-flight streams rotate out naturally instead of being severed.
set -e

./bin/migrate-check

# Shared registry directory so metrics from all granian workers can be
# aggregated by the metrics sidecar below.
export PROMETHEUS_MULTIPROC_DIR=$(mktemp -d)
chmod -R 777 "$PROMETHEUS_MULTIPROC_DIR"

export PROMETHEUS_METRICS_EXPORT_PORT=${PROMETHEUS_METRICS_EXPORT_PORT:-8001}
export STATSD_PORT=${STATSD_PORT:-8125}

STREAMING_WORKERS=${STREAMING_WORKERS:-4}
# Wait this long for workers to finish in-flight streams on shutdown before a
# hard kill. Granian caps this option at 1800s.
STREAMING_WORKERS_KILL_TIMEOUT=${STREAMING_WORKERS_KILL_TIMEOUT:-960}

echo "🔧 Starting streaming tier: granian asgi, ${STREAMING_WORKERS} workers..."

# Metrics sidecar: aggregates the multiproc dir on :$PROMETHEUS_METRICS_EXPORT_PORT,
# the same port the Unit entrypoint exposes metrics on. If it ever dies the
# whole pod exits (kill of PID 1's process group via the trap below) so the
# scheduler restarts a fully working pod instead of one that silently stops
# reporting metrics.
python bin/streaming_metrics.py &
METRICS_PID=$!
trap 'kill -TERM "$METRICS_PID" 2>/dev/null || true; rm -rf "$PROMETHEUS_MULTIPROC_DIR"' EXIT
( while kill -0 "$METRICS_PID" 2>/dev/null; do sleep 10; done; echo "metrics sidecar exited, stopping pod"; kill -TERM $$ ) &

exec python -m granian \
    --interface asgi \
    posthog.asgi:application \
    --host 0.0.0.0 \
    --port 8000 \
    --workers "$STREAMING_WORKERS" \
    --workers-kill-timeout "$STREAMING_WORKERS_KILL_TIMEOUT" \
    --respawn-failed-workers \
    --log-level info
