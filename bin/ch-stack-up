#!/usr/bin/env bash
#
# Bring up the multi-node ClickHouse dev stack:
# - clickhouse (main, shard 01)
# - clickhouse-coordinator (shard 02, port 9001)
# - clickhouse-logs (logs role)
# - keeper (single Keeper ensemble)
# - kafka
#
# For single-node use `./bin/start` or the main docker-compose.dev.yml directly.
# See: https://posthog.com/handbook/engineering/developing-locally

set -euo pipefail

cd "$(dirname "$0")/.."

# Use dev-coordinator.yml alone — it `extends` the needed services from
# docker-compose.base.yml. Combining with dev.yml pulls in unrelated
# services (`proxy → capture`, `web → worker`) that fail to validate
# unless you're booting the full single-node dev stack.
#
# Use a dedicated project name so containers and volumes don't collide
# with the default `posthog` project used by docker-compose.dev.yml.
docker compose \
    -p posthog-multinode \
    -f docker-compose.dev-coordinator.yml \
    up -d \
    clickhouse clickhouse-coordinator clickhouse-logs keeper kafka
