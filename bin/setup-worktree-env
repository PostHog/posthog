#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
agent_env_file="$repo_root/.flox/cache/agent-env"
manifest_hash="$(git hash-object "$repo_root/.flox/env/manifest.toml")"

if ! flox_env_snapshot=$("$repo_root/bin/with-flox" printenv) || [[ -z "$flox_env_snapshot" ]]; then
    echo "error: failed to capture the worktree's Flox environment" >&2
    exit 1
fi

env_content="export POSTHOG_AGENT_ENV_VERSION=2"$'\n'
env_content+="export POSTHOG_AGENT_ENV_MANIFEST=$manifest_hash"$'\n'
while IFS='=' read -r key value; do
    case "$key" in
        PATH | FLOX_ACTIVATE_START_SERVICES | FLOX_CONFIG_DIR | FLOX_ENV | FLOX_ENV_CACHE | FLOX_ENV_DESCRIPTION | FLOX_ENV_DIRS | FLOX_ENV_PROJECT | _FLOX_ACTIVE_ENVIRONMENTS | UV_PROJECT_ENVIRONMENT | OPENSSL_* | LDFLAGS | CPPFLAGS | RUST_* | LIBRARY_PATH | MANPATH | DOTENV_FILE | DEBUG | POSTHOG_SKIP_MIGRATION_CHECKS | FLAGS_REDIS_URL | SCCACHE_*)
            printf -v quoted_value '%q' "$value"
            env_content+="export $key=$quoted_value"$'\n'
            ;;
    esac
done <<< "$flox_env_snapshot"

mkdir -p "$(dirname "$agent_env_file")"
temp_env_file=$(mktemp "$agent_env_file.XXXXXX")
chmod 600 "$temp_env_file"
printf '%s' "$env_content" > "$temp_env_file"
mv -f "$temp_env_file" "$agent_env_file"

if (($#)); then
    # shellcheck disable=SC1090
    source "$agent_env_file"
    exec "$@"
fi
