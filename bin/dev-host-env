#!/usr/bin/env bash

# Shared local-dev defaults for host-run processes.
#
# Docker Compose service names such as "db" and "redis7" resolve inside the
# Compose network, but backend, Celery, Node.js, and Rust services launched by
# bin/start run on the host in normal development.

if [[ "${POSTHOG_SANDBOX:-}" == "1" ]]; then
    POSTHOG_DEV_POSTGRES_HOST=${POSTHOG_DEV_POSTGRES_HOST:-db}
    POSTHOG_DEV_REDIS_HOST=${POSTHOG_DEV_REDIS_HOST:-redis7}
    POSTHOG_DEV_CLICKHOUSE_HOST=${POSTHOG_DEV_CLICKHOUSE_HOST:-clickhouse}
    POSTHOG_DEV_KAFKA_HOSTS=${POSTHOG_DEV_KAFKA_HOSTS:-kafka:9092}
    POSTHOG_DEV_OBJECT_STORAGE_ENDPOINT=${POSTHOG_DEV_OBJECT_STORAGE_ENDPOINT:-http://objectstorage:19000}
    POSTHOG_DEV_SESSION_RECORDING_ENDPOINT=${POSTHOG_DEV_SESSION_RECORDING_ENDPOINT:-http://seaweedfs:8333}
    POSTHOG_DEV_TEMPORAL_HOST=${POSTHOG_DEV_TEMPORAL_HOST:-temporal}
else
    POSTHOG_DEV_POSTGRES_HOST=${POSTHOG_DEV_POSTGRES_HOST:-localhost}
    POSTHOG_DEV_REDIS_HOST=${POSTHOG_DEV_REDIS_HOST:-localhost}
    POSTHOG_DEV_CLICKHOUSE_HOST=${POSTHOG_DEV_CLICKHOUSE_HOST:-localhost}
    POSTHOG_DEV_KAFKA_HOSTS=${POSTHOG_DEV_KAFKA_HOSTS:-localhost:19092}
    POSTHOG_DEV_OBJECT_STORAGE_ENDPOINT=${POSTHOG_DEV_OBJECT_STORAGE_ENDPOINT:-http://localhost:19000}
    POSTHOG_DEV_SESSION_RECORDING_ENDPOINT=${POSTHOG_DEV_SESSION_RECORDING_ENDPOINT:-http://localhost:8333}
    POSTHOG_DEV_TEMPORAL_HOST=${POSTHOG_DEV_TEMPORAL_HOST:-localhost}
fi

export PGHOST=${PGHOST:-$POSTHOG_DEV_POSTGRES_HOST}
export PGPORT=${PGPORT:-5432}
export PGUSER=${PGUSER:-posthog}
export PGPASSWORD=${PGPASSWORD:-posthog}
export PGDATABASE=${PGDATABASE:-posthog}

export DATABASE_URL=${DATABASE_URL:-postgres://${PGUSER}:${PGPASSWORD}@${PGHOST}:${PGPORT}/${PGDATABASE}}
export REDIS_URL=${REDIS_URL:-redis://${POSTHOG_DEV_REDIS_HOST}:6379/}
export POSTHOG_REDIS_HOST=${POSTHOG_REDIS_HOST:-$POSTHOG_DEV_REDIS_HOST}
export POSTHOG_REDIS_PORT=${POSTHOG_REDIS_PORT:-6379}
export DATA_WAREHOUSE_REDIS_HOST=${DATA_WAREHOUSE_REDIS_HOST:-$POSTHOG_DEV_REDIS_HOST}
export DATA_WAREHOUSE_REDIS_PORT=${DATA_WAREHOUSE_REDIS_PORT:-6379}
export CELERY_BROKER_URL=${CELERY_BROKER_URL:-$REDIS_URL}
export CELERY_RESULT_BACKEND=${CELERY_RESULT_BACKEND:-$REDIS_URL}

export CLICKHOUSE_HOST=${CLICKHOUSE_HOST:-$POSTHOG_DEV_CLICKHOUSE_HOST}
export CLICKHOUSE_LOGS_HOST=${CLICKHOUSE_LOGS_HOST:-$CLICKHOUSE_HOST}
export KAFKA_HOSTS=${KAFKA_HOSTS:-$POSTHOG_DEV_KAFKA_HOSTS}
export SESSION_RECORDING_KAFKA_HOSTS=${SESSION_RECORDING_KAFKA_HOSTS:-$KAFKA_HOSTS}
export WAREHOUSE_PIPELINES_KAFKA_HOSTS=${WAREHOUSE_PIPELINES_KAFKA_HOSTS:-$KAFKA_HOSTS}

# ClickHouse runs inside Compose, so Kafka engine tables must still use the
# Compose service name even when Python migrations run on the host.
export KAFKA_URL_FOR_CLICKHOUSE=${KAFKA_URL_FOR_CLICKHOUSE:-kafka:9092}

export OBJECT_STORAGE_ENDPOINT=${OBJECT_STORAGE_ENDPOINT:-$POSTHOG_DEV_OBJECT_STORAGE_ENDPOINT}
export OBJECT_STORAGE_PUBLIC_ENDPOINT=${OBJECT_STORAGE_PUBLIC_ENDPOINT:-$OBJECT_STORAGE_ENDPOINT}
export BATCH_EXPORT_OBJECT_STORAGE_ENDPOINT=${BATCH_EXPORT_OBJECT_STORAGE_ENDPOINT:-$OBJECT_STORAGE_ENDPOINT}
export AI_S3_ENDPOINT=${AI_S3_ENDPOINT:-$OBJECT_STORAGE_ENDPOINT}
export SESSION_RECORDING_V2_S3_ENDPOINT=${SESSION_RECORDING_V2_S3_ENDPOINT:-$POSTHOG_DEV_SESSION_RECORDING_ENDPOINT}

export TEMPORAL_HOST=${TEMPORAL_HOST:-$POSTHOG_DEV_TEMPORAL_HOST}
export DUCKLAKE_RDS_HOST=${DUCKLAKE_RDS_HOST:-$POSTHOG_DEV_POSTGRES_HOST}
