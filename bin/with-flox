#!/usr/bin/env bash

set -euo pipefail

if (($# == 0)); then
    echo "usage: bin/with-flox <command> [args...]" >&2
    exit 2
fi

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
flox_bin="$(command -v flox || true)"

if [[ -z "$flox_bin" ]]; then
    echo "error: Flox is required to provision the PostHog development environment" >&2
    exit 127
fi

strip_checkout_paths() {
    local path_list="$1"
    shift
    local cleaned=""
    local entry root skip
    local -a entries

    IFS=':' read -r -a entries <<< "$path_list"
    for entry in "${entries[@]}"; do
        skip=false
        for root in "$@"; do
            if [[ -n "$root" && "$root" != "/" && ( "$entry" == "$root" || "$entry" == "$root/"* ) ]]; then
                skip=true
                break
            fi
        done
        if [[ "$skip" == false ]]; then
            [[ -z "$cleaned" ]] || cleaned+=":"
            cleaned+="$entry"
        fi
    done
    printf '%s' "$cleaned"
}

inherited_roots=(
    "${FLOX_ENV_PROJECT:-}"
    "${FLOX_ENV:-}"
    "${FLOX_ENV_CACHE:-}"
    "${UV_PROJECT_ENVIRONMENT:-}"
    "${VIRTUAL_ENV:-}"
)
clean_path="$(strip_checkout_paths "${PATH:-}" "${inherited_roots[@]}")"
clean_library_path="$(strip_checkout_paths "${LIBRARY_PATH:-}" "${inherited_roots[@]}")"
clean_manpath="$(strip_checkout_paths "${MANPATH:-}" "${inherited_roots[@]}")"

# Codex and other agent hosts can inherit an activated parent checkout. Flox
# uses these values to detect nesting, so clear them before selecting this repo.
exec env \
    -u FLOX_ACTIVATE_START_SERVICES \
    -u FLOX_ENV \
    -u FLOX_ENV_CACHE \
    -u FLOX_ENV_DESCRIPTION \
    -u FLOX_ENV_DIRS \
    -u FLOX_ENV_PROJECT \
    -u UV_PROJECT_ENVIRONMENT \
    -u VIRTUAL_ENV \
    -u VIRTUAL_ENV_DISABLE_PROMPT \
    -u VIRTUAL_ENV_PROMPT \
    -u _FLOX_ACTIVE_ENVIRONMENTS \
    -u _FLOX_HOOK_DIFF \
    -u _FLOX_INVOCATION_TYPE \
    "PATH=$clean_path" \
    "LIBRARY_PATH=$clean_library_path" \
    "MANPATH=$clean_manpath" \
    "$flox_bin" activate --dir "$repo_root" -- "$@"
