#!/usr/bin/env bash
set -euo pipefail

REPOSITORY_ROOT="${REPOSITORY_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
DUCKGRES_BIN="$REPOSITORY_ROOT/.flox/cache/duckgres/duckgres"
DUCKGRES_CONFIG="$REPOSITORY_ROOT/devenv/duckgres.yaml"

"$REPOSITORY_ROOT/bin/download-duckgres"

if [ ! -x "$DUCKGRES_BIN" ]; then
    echo "ERROR: duckgres binary not found at $DUCKGRES_BIN" >&2
    exit 1
fi

while true; do
    "$DUCKGRES_BIN" --config "$DUCKGRES_CONFIG"
    echo "duckgres exited, restarting in 3s..."
    sleep 3
done
