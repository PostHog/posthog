#!/bin/sh

set -e

# The RoundHog brand font ships in @posthog/brand instead of being committed to this repo.
# Materialize it into public/ (gitignored) so the url() refs in src/styles/fonts.scss keep
# resolving and the files are served verbatim from /static/ for Django templates and emails.

mkdir -p public
cp node_modules/@posthog/brand/dist/fonts/RoundHog*.woff2 public/
