    "source": {
      "kind": "HogQLQuery",
      "query": "SELECT\n    toStartOfMonth(timestamp) AS month,\n\n    nullIf(count(), 0) AS s0,\n    nullIf(1* countIf(addMonths(timestamp, 1) <= now()), 0)  AS s1,\n    nullIf(2*countIf(addMonths(timestamp, 2) <= now()), 0)  AS s2,\n    nullIf(3*countIf(addMonths(timestamp, 3) <= now()), 0)  AS s3,\n    nullIf(4*countIf(addMonths(timestamp, 4) <= now()), 0)  AS s4,\n    nullIf(5*countIf(addMonths(timestamp, 5) <= now()), 0)  AS s5,\n    nullIf(6*countIf(addMonths(timestamp, 6) <= now()), 0)  AS s6,\n    nullIf(7*countIf(addMonths(timestamp, 7) <= now()), 0)  AS s7,\n    nullIf(8*countIf(addMonths(timestamp, 8) <= now()), 0)  AS s8,\n    nullIf(9*countIf(addMonths(timestamp, 9) <= now()), 0)  AS s9,\n    nullIf(10*countIf(addMonths(timestamp,10) <= now()), 0)  AS s10,\n    nullIf(11*countIf(addMonths(timestamp,11) <= now()), 0)  AS s11\n\nFROM events\nGROUP BY month\nORDER BY month"
    },
