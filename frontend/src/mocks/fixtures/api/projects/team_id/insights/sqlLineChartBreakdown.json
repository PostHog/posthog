  "hogql": "SELECT\n    toStartOfMonth(timestamp) AS month,\n    nullIf(count(), 0) AS s0,\n    nullIf(multiply(1, countIf(lessOrEquals(addMonths(timestamp, 1), now()))), 0) AS s1,\n    nullIf(multiply(2, countIf(lessOrEquals(addMonths(timestamp, 2), now()))), 0) AS s2,\n    nullIf(multiply(3, countIf(lessOrEquals(addMonths(timestamp, 3), now()))), 0) AS s3,\n    nullIf(multiply(4, countIf(lessOrEquals(addMonths(timestamp, 4), now()))), 0) AS s4,\n    nullIf(multiply(5, countIf(lessOrEquals(addMonths(timestamp, 5), now()))), 0) AS s5,\n    nullIf(multiply(6, countIf(lessOrEquals(addMonths(timestamp, 6), now()))), 0) AS s6,\n    nullIf(multiply(7, countIf(lessOrEquals(addMonths(timestamp, 7), now()))), 0) AS s7,\n    nullIf(multiply(8, countIf(lessOrEquals(addMonths(timestamp, 8), now()))), 0) AS s8,\n    nullIf(multiply(9, countIf(lessOrEquals(addMonths(timestamp, 9), now()))), 0) AS s9,\n    nullIf(multiply(10, countIf(lessOrEquals(addMonths(timestamp, 10), now()))), 0) AS s10,\n    nullIf(multiply(11, countIf(lessOrEquals(addMonths(timestamp, 11), now()))), 0) AS s11\nFROM\n    events\nGROUP BY\n    month\nORDER BY\n    month ASC\nLIMIT 101\nOFFSET 0",
