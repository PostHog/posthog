            "hogql": "SELECT\n    week,\n    sumIf(c, equals(shift, 0)) AS shift_0d,\n    sumIf(c, equals(shift, 1)) AS shift_7d,\n    sumIf(c, equals(shift, 2)) AS shift_14d,\n    sumIf(c, equals(shift, 3)) AS shift_21d,\n    sumIf(c, equals(shift, 4)) AS shift_28d,\n    sumIf(c, equals(shift, 5)) AS shift_35d,\n    sumIf(c, equals(shift, 6)) AS shift_42d\nFROM\n    (SELECT\n        toStartOfWeek(shifted_ts) AS week,\n        shift,\n        count() AS c\n    FROM\n        (SELECT\n            shift,\n            minus(timestamp, toIntervalDay(multiply(shift, 7))) AS shifted_ts\n        FROM\n            events\n        ARRAY JOIN range(7) AS shift\n        WHERE\n            equals(event, '$pageview'))\n    GROUP BY\n        week,\n        shift)\nGROUP BY\n    week\nORDER BY\n    week ASC\nLIMIT 101\nOFFSET 0",
