                "source": {
                    "kind": "HogQLQuery",
                    "query": "SELECT\n    week,\n    sumIf(c, shift = 0) AS shift_0d,\n    sumIf(c, shift = 1) AS shift_7d,\n    sumIf(c, shift = 2) AS shift_14d,\n    sumIf(c, shift = 3) AS shift_21d,\n    sumIf(c, shift = 4) AS shift_28d,\n    sumIf(c, shift = 5) AS shift_35d,\n    sumIf(c, shift = 6) AS shift_42d\nFROM\n(\n    SELECT\n        toStartOfWeek(shifted_ts) AS week,\n        shift,\n        count() AS c\n    FROM\n    (\n        SELECT\n            shift,\n            timestamp - toIntervalDay(shift * 7) AS shifted_ts\n        FROM events\n        ARRAY JOIN range(7) AS shift\n        WHERE event = '$pageview'\n    )\n    GROUP BY week, shift\n)\nGROUP BY week\nORDER BY week"
