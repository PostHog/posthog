{
    "name": "@posthog/cli-2.0",
    "version": "0.1.0",
    "description": "PostHog CLI using direct MCP infrastructure",
    "bin": {
        "ph": "./bin/ph.js"
    },
    "files": [
        "bin",
        "dist"
    ],
    "type": "module",
    "scripts": {
        "build": "pnpm run generate:commands && tsc",
        "dev": "tsx src/index.ts",
        "format": "oxfmt \"{src,scripts}/**/*.ts\"",
        "format:check": "oxfmt --check \"{src,scripts}/**/*.ts\"",
        "generate:mappings": "tsx scripts/generate-command-mappings.ts",
        "generate:commands": "pnpm run generate:mappings && tsx scripts/generate-commands.ts",
        "link:global": "pnpm run build && pnpm link --global",
        "prepack": "pnpm run build",
        "start": "node ./bin/ph.js",
        "test": "node --import tsx --test 'src/**/*.test.ts'"
    },
    "dependencies": {
        "@napi-rs/keyring": "^1.3.0",
        "asciichart": "^1.5.25",
        "chalk": "^5.3.0",
        "chartscii": "4.0.0",
        "cli-highlight": "^2.1.11",
        "cli-table3": "^0.6.5",
        "conf": "^12.0.0",
        "eventsource-parser": "^3.0.0",
        "ink": "^5.1.0",
        "ink-spinner": "^5.0.0",
        "inquirer": "^9.2.0",
        "node-jq": "^6.3.1",
        "ora": "^8.0.1",
        "react": "^18.3.1",
        "tsx": "^4.0.0",
        "uuid": "^11.1.0",
        "yaml": "^2.8.2",
        "yargs": "^17.7.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/inquirer": "^9.0.0",
        "@types/node": "^20.0.0",
        "@types/react": "^18.3.0",
        "@types/yargs": "^17.0.0",
        "oxfmt": "^0.35.0",
        "typescript": "^5.0.0"
    },
    "engines": {
        "node": ">=18"
    },
    "pnpm": {
        "minimumReleaseAge": 10080
    }
}
