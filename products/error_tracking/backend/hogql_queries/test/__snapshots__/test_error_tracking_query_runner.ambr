# name: TestErrorTrackingQueryRunner.test_first_seen_filters
  '''
  SELECT e__fingerprint_issue_state.issue_id AS id,
         any(e__fingerprint_issue_state.issue_status) AS status,
         any(e__fingerprint_issue_state.issue_name) AS name,
