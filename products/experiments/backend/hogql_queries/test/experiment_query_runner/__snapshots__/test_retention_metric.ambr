# name: TestExperimentRetentionMetric.test_only_count_matured_users_anchors_on_start_event_1_precomputed
  '''
  WITH exposures AS
    (SELECT accurateCastOrNull(t.entity_id, 'UUID') AS entity_id,
            if(greater(uniqExact(t.variant), 1), '$multiple', argMin(t.variant, toTimeZone(t.first_exposure_time, 'UTC'))) AS variant,
            min(toTimeZone(t.first_exposure_time, 'UTC')) AS first_exposure_time,
            max(toTimeZone(t.last_exposure_time, 'UTC')) AS last_exposure_time,
            argMin(t.exposure_event_uuid, toTimeZone(t.first_exposure_time, 'UTC')) AS exposure_event_uuid,
            argMin(t.exposure_session_id, toTimeZone(t.first_exposure_time, 'UTC')) AS exposure_session_id
     FROM experiment_exposures_preaggregated AS t
     WHERE and(equals(t.team_id, 99999), in(t.job_id, ['00000000-0000-0000-0000-000000000000', '00000000-0000-0000-0000-000000000000', '00000000-0000-0000-0000-000000000000', '00000000-0000-0000-0000-000000000000', '00000000-0000-0000-0000-000000000000']), equals(t.team_id, 99999), greaterOrEquals(t.first_exposure_time, assumeNotNull(toDateTime('2020-01-01 00:00:00', 'UTC'))), lessOrEquals(t.first_exposure_time, assumeNotNull(toDateTime('2020-01-25 00:00:00', 'UTC'))))
