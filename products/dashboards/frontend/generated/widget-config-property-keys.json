            },
            "limit": {
                "$type": "integer"
            },
            "orderBy": {
                "$enum": ["earliest", "latest"]
            },
            "severityLevels": {
                "$array": {
                    "$enum": ["debug", "error", "fatal", "info", "trace", "warn"]
                }
            },
            "serviceNames": {
                "$array": {
                    "$type": "string"
                }
            },
            "wrapLines": {
                "$type": "boolean"
            },
            "timezone": {
                "$enum": ["UTC", "local"]
            },
            "savedViewId": {
                "$type": "string"
            }
