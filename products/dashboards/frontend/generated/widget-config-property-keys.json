                            "not_between",
                            "not_icontains",
                            "not_icontains_multi",
                            "not_in",
                            "not_regex",
                            "regex",
                            "semver_caret",
                            "semver_eq",
                            "semver_gt",
                            "semver_gte",
                            "semver_lt",
                            "semver_lte",
                            "semver_neq",
                            "semver_tilde",
                            "semver_wildcard"
                        ]
                    },
                    "value": {
                        "$types": ["string"]
                    }
                }
            },
            "limit": {
                "$type": "integer"
            },
            "orderBy": {
                "$enum": [
                    "activity_score",
                    "click_count",
                    "console_error_count",
                    "duration",
                    "recording_duration",
                    "start_time"
                ]
            },
            "orderDirection": {
                "$enum": ["ASC", "DESC"]
            },
            "savedFilterId": {
                "$type": "string"
            },
            "collectionId": {
                "$type": "string"
            }
        },
