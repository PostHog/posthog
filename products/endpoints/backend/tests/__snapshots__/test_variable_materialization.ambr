      toDate(timestamp)
  LIMIT 50000
  '''
# ---
# name: TestTransformQuerySnapshots.test_nested_and_variable_removed
  '''
  SELECT
      count(),
      event AS event_name
  FROM
      events
  WHERE
      equals(distinct_id, 'u1')
  GROUP BY
      event
  LIMIT 50000
  '''
# ---
# name: TestTransformQuerySnapshots.test_order_by_having_limit_preserved
  '''
  SELECT
      event,
      count() AS c,
      event AS event_name
  FROM
      events
  GROUP BY
      event
  HAVING
      greater(c, 10)
  ORDER BY
      c DESC
  LIMIT 50
  '''
