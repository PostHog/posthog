      event AS event_name
  FROM
      events
  GROUP BY
      event
  LIMIT 50000
  '''
# ---
# name: TestTransformQuerySnapshots.test_existing_group_by_preserved
  '''
  SELECT
      toStartOfDay(timestamp) AS day,
      count(),
      event AS event_name
  FROM
      events
  GROUP BY
      day,
      event
  LIMIT 50000
  '''
# ---
# name: TestTransformQuerySnapshots.test_function_call_toDate
  '''
  SELECT
      count(),
      toDate(timestamp) AS from_date
  FROM
      events
  GROUP BY
      toDate(timestamp)
  LIMIT 50000
  '''
# ---
# name: TestTransformQuerySnapshots.test_hard_cap_timestamp_with_variable_range
  '''
  SELECT
      count(),
      toStartOfDay(timestamp) AS start_date,
      toStartOfDay(timestamp) AS end_date
  FROM
      events
  WHERE
      greater(timestamp, minus(today(), toIntervalDay(90)))
  GROUP BY
      toStartOfDay(timestamp)
  LIMIT 50000
  '''
# ---
# name: TestTransformQuerySnapshots.test_like_operator
  '''
  SELECT
      count(),
      event AS pattern
  FROM
      events
  GROUP BY
      event
  LIMIT 50000
  '''
# ---
# name: TestTransformQuerySnapshots.test_mixed_equality_and_range
  '''
  SELECT
      count(),
      event AS name,
