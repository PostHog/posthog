+    const mcpUrl = process.env.POSTHOG_MCP_URL;

     const server = new AgentServer({
       port: parseInt(options.port, 10),
@@ -69,6 +70,7 @@ program
       mode,
       taskId: options.taskId,
       runId: options.runId,
+      mcpUrl,
     });

