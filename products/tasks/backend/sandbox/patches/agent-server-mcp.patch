@@ -11,4 +11,5 @@ export interface AgentServerConfig {
   taskId: string;
   runId: string;
   version?: string;
+  mcpUrl?: string;
 }

--- a/packages/agent/src/server/bin.ts
+++ b/packages/agent/src/server/bin.ts
