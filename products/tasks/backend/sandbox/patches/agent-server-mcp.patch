+  private buildMcpServers(): Array<{
+    name: string;
+    type: string;
+    url: string;
+    headers: Array<{ name: string; value: string }>;
+  }> {
+    const { mcpUrl, apiKey, projectId } = this.config;
+    if (!mcpUrl) {
+      return [];
+    }
+
+    this.logger.info("Configuring PostHog MCP server", { mcpUrl });
+
+    return [
+      {
+        name: "posthog",
+        type: "http",
+        url: mcpUrl,
+        headers: [
+          { name: "Authorization", value: `Bearer ${apiKey}` },
+          { name: "x-posthog-project-id", value: String(projectId) },
+          { name: "x-posthog-mcp-version", value: "2" },
+          { name: "x-posthog-read-only", value: "true" },
+        ],
+      },
+    ];
+  }
