# Dockerfile for the base sandbox image.

FROM ubuntu:24.04

# Set environment variables to prevent interactive prompts
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

# Install system packages (expanded for coding environments)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    # Core tools
    curl \
    wget \
    git \
    vim \
    nano \
    tree \
    htop \
    unzip \
    zip \
    jq \
    tar \
    # Build tools
    build-essential \
    cmake \
    pkg-config \
    # Languages and runtimes
    python3 \
    python3-pip \
    python3-venv \
    python3-dev \
    # Databases
    sqlite3 \
    postgresql-client \
    mysql-client \
    redis-tools \
    # System libraries often needed by Python packages
    libssl-dev \
    libffi-dev \
    libbz2-dev \
    libreadline-dev \
    libsqlite3-dev \
    libncursesw5-dev \
    xz-utils \
    tk-dev \
    libxml2-dev \
    libxmlsec1-dev \
    # Remote access and terminal multiplexers
    openssh-client \
    tmux \
    screen \
    # Fast file search
    ripgrep \
    # Text processing (ensure available)
    diffutils \
    patch \
    # Other useful tools
    ca-certificates \
    gnupg \
    sudo \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 24.x
RUN curl -fsSL https://deb.nodesource.com/setup_24.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# Install additional language package managers (including Bun)
RUN npm install -g yarn pnpm typescript ts-node nodemon bun

# Install uv (fast Python package manager) — pinned to an explicit version
# so rebuilds are reproducible and supply-chain substitutions via :latest
# are caught at the Dockerfile change level.
ARG UV_VERSION=0.7.2
COPY --from=ghcr.io/astral-sh/uv:${UV_VERSION} /uv /uvx /usr/local/bin/

# Install Go (with checksum verification against go.dev's official .sha256)
ARG GO_VERSION=1.24.2
RUN ARCH=$(dpkg --print-architecture) && \
    GO_TARBALL="go${GO_VERSION}.linux-${ARCH}.tar.gz" && \
    curl -fsSL "https://go.dev/dl/${GO_TARBALL}" -o "/tmp/${GO_TARBALL}" && \
    curl -fsSL "https://go.dev/dl/${GO_TARBALL}.sha256" -o "/tmp/${GO_TARBALL}.sha256" && \
    echo "$(cat /tmp/${GO_TARBALL}.sha256)  /tmp/${GO_TARBALL}" | sha256sum -c - && \
    rm -rf /usr/local/go && \
    tar -C /usr/local -xzf "/tmp/${GO_TARBALL}" && \
    rm -f "/tmp/${GO_TARBALL}" "/tmp/${GO_TARBALL}.sha256"
ENV PATH="/usr/local/go/bin:$PATH"

# Install Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path
ENV PATH="/root/.cargo/bin:$PATH"

# Install Java 21, Maven, Ruby, and PHP in a single apt layer
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        openjdk-21-jdk-headless \
        maven \
        ruby-full \
        php-cli \
        php-mbstring \
        php-xml \
        php-curl \
        php-zip && \
    rm -rf /var/lib/apt/lists/* && \
    gem install bundler

# Install Gradle (with checksum verification against services.gradle.org's official .sha256)
ARG GRADLE_VERSION=8.12
RUN curl -fsSL "https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip" -o /tmp/gradle.zip && \
    curl -fsSL "https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip.sha256" -o /tmp/gradle.zip.sha256 && \
    echo "$(cat /tmp/gradle.zip.sha256)  /tmp/gradle.zip" | sha256sum -c - && \
    unzip -d /opt /tmp/gradle.zip && \
    ln -s "/opt/gradle-${GRADLE_VERSION}/bin/gradle" /usr/local/bin/gradle && \
    rm /tmp/gradle.zip /tmp/gradle.zip.sha256

# Install Composer (with installer signature verification per Composer's official docs)
RUN curl -fsSL https://getcomposer.org/installer -o /tmp/composer-setup.php && \
    EXPECTED_SIGNATURE="$(curl -fsSL https://composer.github.io/installer.sig)" && \
    ACTUAL_SIGNATURE="$(php -r "echo hash_file('sha384', '/tmp/composer-setup.php');")" && \
    [ "$EXPECTED_SIGNATURE" = "$ACTUAL_SIGNATURE" ] && \
    php /tmp/composer-setup.php --install-dir=/usr/local/bin --filename=composer && \
    rm -f /tmp/composer-setup.php

# Install GitHub CLI without adding another apt repository refresh.
ARG GH_CLI_VERSION=2.89.0
RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    curl -fsSL -o /tmp/gh.deb \
      "https://github.com/cli/cli/releases/download/v${GH_CLI_VERSION}/gh_${GH_CLI_VERSION}_linux_${arch}.deb" && \
    dpkg -i /tmp/gh.deb && \
    rm /tmp/gh.deb

# Install agentsh for runtime egress policy enforcement
ARG AGENTSH_TAG=v0.16.7
RUN set -eux; \
    version="${AGENTSH_TAG#v}"; \
    arch="$(dpkg --print-architecture)"; \
    curl -fsSL -o /tmp/agentsh.deb \
      "https://github.com/canyonroad/agentsh/releases/download/${AGENTSH_TAG}/agentsh_${version}_linux_${arch}.deb" && \
    dpkg -i /tmp/agentsh.deb && \
    rm /tmp/agentsh.deb && \
    agentsh --version && \
    mkdir -p /var/lib/agentsh/sessions /var/lib/agentsh/quarantine /var/log/agentsh && \
    chmod 777 /var/lib/agentsh /var/lib/agentsh/sessions /var/lib/agentsh/quarantine /var/log/agentsh

ENV AGENTSH_SERVER=http://127.0.0.1:18080

###
# Agent SDK
###

# Set up /scripts as a Node.js project and install @posthog/agent
# COMMIT_HASH changes every build, busting the cache so we always get @latest
ARG COMMIT_HASH
RUN mkdir -p /scripts && \
    cd /scripts && \
    npm init -y && \
    CACHE_BUST=${COMMIT_HASH} npm install @posthog/agent@latest

# Install pre-built skills (PostHog + context-mill) into the plugin directory.
# The dist/skills/ directory is populated by the CD workflow's build_skills job.
COPY products/posthog_ai/dist/skills/ /tmp/skills/
COPY products/tasks/backend/sandbox/images/install-skills.sh /tmp/install-skills.sh
RUN chmod +x /tmp/install-skills.sh && \
    /tmp/install-skills.sh /tmp/skills && \
    rm -rf /tmp/install-skills.sh /tmp/skills

# Default git identity for bot-authored commits.
# Runs configured for user-authored pull requests receive
# GIT_AUTHOR_*/GIT_COMMITTER_* env vars that override these defaults.
RUN git config --global user.email "code@posthog.com" && \
    git config --global user.name "PostHog Code"

# This is required for the Claude Code SDK to allow --dangerously-skip-permissions as the root user
ENV IS_SANDBOX=1

ENV PYTHONPATH="/tmp/workspace"

WORKDIR /tmp/workspace

RUN python3 --version && \
    node --version && \
    npm --version && \
    bun --version && \
    go version && \
    rustc --version && \
    cargo --version && \
    java --version && \
    mvn --version && \
    gradle --version && \
    ruby --version && \
    bundler --version && \
    php --version && \
    composer --version && \
    uv --version

CMD ["/bin/bash"]
