'), 'posthog_person_distinct_id_source', ifNull(multiIf(and(and(isNotNull(sub.distinct_id), notEquals(sub.distinct_id, '')), greaterOrEquals(sub.created_at, coalesce(chg.created_at, toDateTime(0))), greaterOrEquals(sub.created_at, coalesce(inv.created_at, toDateTime(0)))), concat('subscription::', sub.source_id), and(and(isNotNull(chg.distinct_id), notEquals(chg.distinct_id, '')), greaterOrEquals(chg.created_at, coalesce(sub.created_at, toDateTime(0))), greaterOrEquals(chg.created_at, coalesce(inv.created_at, toDateTime(0)))), concat('charge::', chg.source_id), and(and(isNotNull(inv.distinct_id), notEquals(inv.distinct_id, '')), greaterOrEquals(inv.created_at, coalesce(sub.created_at, toDateTime(0))), greaterOrEquals(inv.created_at, coalesce(chg.created_at, toDateTime(0)))), concat('invoice::', inv.source_id), ''), '')))), metadata)) AS metadata,
