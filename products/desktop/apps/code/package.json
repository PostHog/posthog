    "lint-staged": "^15.5.2",
    "memfs": "^4.57.3",
    "mockdate": "^3.0.5",
    "pathe": "^2.0.3",
    "postcss": "^8.5.15",
    "storybook": "10.4.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typed-openapi": "^2.2.6",
    "typescript": "^5.9.3",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^6.0.0",
    "vitest": "^4.1.8",
    "wait-on": "^7.2.0",
    "yaml": "^2.9.0"
