{
  "name": "@posthog/git",
  "version": "1.0.0",
  "description": "Git utilities for PostHog",
  "type": "module",
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "node ../../scripts/rimraf.mjs dist .turbo",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/tar": "^6.1.13",
    "typescript": "^5.5.0",
    "vitest": "^4.1.8"
  },
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "dependencies": {
    "@posthog/shared": "workspace:*",
    "git-url-parse": "^16.1.0",
    "simple-git": "^3.30.0"
  }
}
