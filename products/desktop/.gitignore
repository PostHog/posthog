# Trunk Flaky Tests JUnit reports (one per package, uploaded from CI)
junit.xml

# Downloaded binaries
apps/code/resources/codex-acp/

# Licensed fonts (downloaded from S3 during CI)
apps/code/assets/fonts/BerkeleyMono/

# Local dev skills (override shipped + remote skills in dev mode)
plugins/posthog/local-skills/

# Symlinked copies of posthog, to make developing against those APIs easier
posthog-sym

.claude/settings.local.json
CLAUDE.local.md

apps/mobile/ROADMAP.md
# Local quill tarball for ChatX thread testing (not committed)
.local-quill/

# pi project-local config (per-developer MCP servers, prompts, etc.)
.pi/

# Storybook visual regression: PNGs are never committed. CI uploads captures
# to the PostHog Visual Review product; the committed baseline is the signed
# hash manifest apps/code/snapshots.yml.
apps/code/.storybook/__snapshots__/
