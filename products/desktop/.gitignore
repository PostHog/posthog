# Build outputs
dist/
release/
out/
.vite/
.turbo/
storybook-static
bin/

# node-gyp configure artifact from a stray run at the repo root
/build/

# tsup bundled config artifacts (temporary files left behind when bundling TS configs)
*.config.bundled_*.mjs
# vite bundled config artifacts (left behind when a vitest run is interrupted)
*.config.ts.timestamp-*.mjs

# Environment
.env
.env.local
.envrc

# IDE
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
