{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://posthog.com/signals/pipeline-training/report.schema.json",
    "title": "Observed source report",
    "type": "object",
    "required": ["report_id", "member_ids"],
    "properties": {
        "report_id": { "type": "string", "minLength": 1 },
        "member_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
        },
        "created_at": { "oneOf": [{ "type": "string" }, { "type": "number" }, { "type": "null" }] },
        "status": { "type": ["string", "null"] },
        "metadata": { "type": "object" }
    },
    "additionalProperties": true
}
