---
config:
  flowchart:
    nodeSpacing: 28
    rankSpacing: 40
    subGraphTitleMargin:
      top: 6
      bottom: 6
---
flowchart TD
    %% ============================================================
    %% ReviewHog — current as-built flow (single-turn, pre-Temporal)
    %% Entry: run_review CLI → reviewer.run.main(pr_url, team_id, user_id)
    %% Postgres is the single source of truth; no on-disk store.
    %% ============================================================

    TRIGGER["run_review CLI<br/>pr_url · team_id · user_id"]:::trigger
    TRIGGER --> MAIN(["main() — 9 stages, one async run"]):::trigger

    %% ---- Stage 1: Fetch (local, GitHub API) ----
    MAIN --> S1["STAGE 1 · Fetch PR data<br/>PRFetcher — GitHub API"]:::api
    S1 --> S1OUT["pr_metadata · pr_comments<br/>pr_files · diff &nbsp;(in-process)"]:::data

    %% ---- Setup block (after fetch, before chunking) ----
    S1OUT --> SETUP["SETUP&nbsp;·&nbsp;bind sandbox identity (validates GitHub integration)<br/>open report (idempotent: team+repo+pr#) · snapshot diff + head_sha watermark<br/>sync team review skills · generate prompt schemas"]:::local
    SETUP --> S2

    %% ---- Stage 2: Chunk (1 sandbox agent) ----
    S2{{"STAGE 2 · Split into chunks<br/>1 sandbox agent&nbsp;&nbsp;·&nbsp;&nbsp;↺ resume @ head_sha"}}:::agent
    S2 --> S2OUT["chunks"]:::data

    %% ---- Stage 3: Analyze (fan-out 1/chunk) ----
    S2OUT --> S3{{"STAGE 3 · Analyze chunks<br/>fan-out: 1 agent / chunk (one gather)<br/>informational · best-effort · ↺ resume @ head_sha"}}:::agent
    S3 --> S3OUT["per-chunk analyses"]:::data

    %% ---- Stage 4: Review (3 perspectives × N chunks, ALL concurrent) ----
    S2OUT --> S4
    S3OUT -.->|"analysis as<br/>per-chunk context"| S4
    subgraph S4["STAGE 4 · Review chunks — every (perspective × chunk) concurrent in ONE gather · no cross-perspective context · ↺ resume @ (pass, chunk)"]
        direction LR
        P1{{"logic-correctness<br/>× N chunks"}}:::agent
        P2{{"contracts-security<br/>× N chunks"}}:::agent
        P3{{"performance-reliability<br/>× N chunks"}}:::agent
    end
    S4 --> S4OUT["IssuesReview per (pass, chunk)"]:::data

    %% ---- Stage 5: Combine + scope-clean (local) ----
    S4OUT --> S5["STAGE 5 · Combine + scope-clean &nbsp;(LOCAL)<br/>combine_issues → clean_issues (drop off-diff)<br/>id re-stamped = {pass}-{chunk}-{n}"]:::local
    S5 --> S5OUT["cleaned, in-scope issues"]:::data

    %% ---- Stage 6: Dedup (deterministic gate + conditional sandbox) ----
    S5OUT --> GATE{"STAGE 6 · positional pre-filter (LOCAL)<br/>same file + overlapping lines?"}:::local
    GATE -->|"isolated → kept, no LLM"| S6OUT
    GATE -->|"colliding → candidates"| S6{{"dedup agent (1 sandbox call,<br/>only if any candidate)<br/>uniform over ALL prior inline comments"}}:::agent
    S1OUT -.->|"pr_comments — any author<br/>(bots / humans / our own)"| S6
    S6 --> S6OUT["canonical findings"]:::data

    %% ---- Stage 7: Validate (fan-out 1/issue, recomputes) ----
    S6OUT --> S7{{"STAGE 7 · Validate issues<br/>fan-out: 1 agent / issue (one gather)<br/>pulls validation-criteria skill · recomputes (no resume)"}}:::agent
    S7 --> S7OUT["verdicts — is_valid + reasoning"]:::data

    %% ---- Stage 8: Build report (local) ----
    S7OUT --> S8["STAGE 8 · Build review body &nbsp;(LOCAL)<br/>build_review_body → markdown"]:::local

    %% ---- Stage 9: Publish (gated off) ----
    S8 --> S9["STAGE 9 · Publish review — GitHub API<br/>DB-driven: valid findings → inline comments + body"]:::gated
    S9 --> RESULT["⚠ GATED OFF — PUBLISH_REVIEW_ENABLED=False<br/>(would post the PR review)"]:::gated

    %% ============================================================
    %% Persistence — Postgres single source of truth
    %% ============================================================
    DB[("Postgres&nbsp;· single source of truth<br/>ReviewReport + ReviewReportArtefact<br/>(reuses Signals' artefact leaf)")]:::db
    SETUP -. "report row + commit/diff + watermark" .-> DB
    S2 -. "chunk_set" .-> DB
    S3 -. "chunk_analysis / chunk" .-> DB
    S4 -. "perspective_result / (pass,chunk)" .-> DB
    S6OUT -. "issue_finding" .-> DB
    S7OUT -. "validation_verdict (paired by issue_key)" .-> DB
    S8 -. "report_markdown · run_count++ · status IDLE" .-> DB
    DB -. "load_valid_findings (latest-wins / issue_key)" .-> S9

    %% Resume: a re-run at the same head_sha reuses chunk_set / chunk_analysis /
    %% perspective_result rows (turn-stable sandbox work); dedup + validation recompute.

    %% ============================================================
    %% Shared infrastructure — used by every ⬡ sandbox stage (2, 3, 4, 6, 7)
    %% ============================================================
    subgraph INFRA["shared sandbox infrastructure — used by every ⬡ stage (2, 3, 4, 6, 7)"]
        direction LR
        IDENT["run-scoped identity<br/>ContextVar (team, user)<br/>bound once at SETUP"]:::infra
        SEM["global asyncio.Semaphore(10)<br/>caps concurrent sandboxes"]:::infra
        SKILLS["team skills (MCP)<br/>3 perspectives + validation criteria<br/>agents pull via skill-get"]:::infra
        SBX["products/tasks sandbox<br/>MultiTurnSession.start(model=)<br/>clones repo · checks out PR branch"]:::infra
    end

    %% ============================================================
    %% Styling
    %% ============================================================
    classDef trigger fill:#fdcb6e,stroke:#c7991b,color:#333
    classDef agent fill:#4a90d9,stroke:#2c5f8a,color:#fff
    classDef local fill:#6ab04c,stroke:#3d7a2a,color:#fff
    classDef data fill:#f5f5f5,stroke:#999,color:#333
    classDef api fill:#e17055,stroke:#b34230,color:#fff
    classDef db fill:#9b59b6,stroke:#6c3483,color:#fff
    classDef infra fill:#dfe6e9,stroke:#636e72,color:#2d3436
    classDef gated fill:#b2bec3,stroke:#636e72,color:#2d3436

    %% ============================================================
    %% Legend
    %% ============================================================
    subgraph LEGEND["Legend"]
        direction LR
        L1{{"⬡ sandbox agent"}}:::agent
        L2["local (in-process)"]:::local
        L3["GitHub API"]:::api
        L4[("Postgres")]:::db
        L5["shared infra"]:::infra
        L6["gated off"]:::gated
    end
