# name: TestTrafficTypeSnapshot.test_is_bot
  '''
  -- ClickHouse
  
  SELECT
      ifNull(notEquals(dictGetOrDefault(%(hogql_val_0)s, %(hogql_val_1)s, ifNull(replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(events.properties, %(hogql_val_2)s), ''), 'null'), '^"|"$', ''), %(hogql_val_3)s), %(hogql_val_4)s), %(hogql_val_5)s), 1) AS is_bot,
      count() AS count
  
  FROM
      events
  
  WHERE
      and(equals(events.team_id, 99999), equals(events.event, %(hogql_val_6)s))
  
  GROUP BY
      is_bot
  ORDER BY
      is_bot ASC
  
  LIMIT 100 
  SETTINGS readonly=2, max_execution_time=60, allow_experimental_object_type=1, max_ast_elements=4000000, max_expanded_ast_elements=4000000, max_bytes_before_external_group_by=0, transform_null_in=1, optimize_min_equality_disjunction_chain_length=4294967295, allow_experimental_join_condition=1, use_hive_partitioning=0
  
  -- HogQL
  
  SELECT
      notEquals(dictGetOrDefault('posthog_test.bot_definition_dict', 'traffic_type', ifNull(properties.$user_agent, ''), 'Regular'), 'Regular') AS is_bot,
      count() AS count
  
  FROM
      events
  
  WHERE
      equals(event, '$pageview')
  
  GROUP BY
      is_bot
  ORDER BY
      is_bot ASC
  
  LIMIT 100
  '''
