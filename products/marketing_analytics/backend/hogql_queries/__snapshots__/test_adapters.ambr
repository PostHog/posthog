# serializer version: 1
# name: TestMarketingAnalyticsAdapters.test_azure_adapter_query_generation
  '''
  
  SELECT toString(campaign_name) AS match_key, toString(campaign_name) AS campaign, toString(campaign_name) AS id, toString('Azure') AS source, toFloat(coalesce(toFloat(impressions), 0)) AS impressions, toFloat(coalesce(toFloat(clicks), 0)) AS clicks, toFloat(convertCurrency('USD', 'USD', coalesce(toFloat(spend), 0))) AS cost, toFloat(coalesce(toFloat(conversions), 0)) AS reported_conversion, 0 AS reported_conversion_value 
  FROM azure_table 
  WHERE and(greaterOrEquals(toDateTime(report_date), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(report_date), toDateTime('2024-12-31 23:59:59')))
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_bing_ads_native_query_generation
  '''
  
  SELECT toString(bing_campaigns.name) AS match_key, toString(bing_campaigns.name) AS campaign, toString(bing_campaigns.id) AS id, toString('bing') AS source, toFloat(SUM(ifNull(toFloat(bing_campaign_performance_report.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(bing_campaign_performance_report.clicks), 0))) AS clicks, SUM(ifNull(toFloat(bing_campaign_performance_report.spend), 0)) AS cost, toFloat(SUM(ifNull(toFloat(bing_campaign_performance_report.conversions), 0))) AS reported_conversion, toFloat(SUM(ifNull(toFloat(bing_campaign_performance_report.revenue), 0))) AS reported_conversion_value 
  FROM bing_campaigns LEFT JOIN bing_campaign_performance_report ON equals(toString(bing_campaigns.id), toString(bing_campaign_performance_report.campaign_id)) 
  WHERE and(greaterOrEquals(toDateTime(bing_campaign_performance_report.time_period), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(bing_campaign_performance_report.time_period), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY toString(bing_campaigns.name), toString(bing_campaigns.id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_cloudflare_r2_adapter_query_generation
  '''
  
  SELECT toString(campaign_name) AS match_key, toString(campaign_name) AS campaign, toString(campaign_name) AS id, toString('Cloudflare') AS source, toFloat(coalesce(toFloat(impressions), 0)) AS impressions, toFloat(coalesce(toFloat(clicks), 0)) AS clicks, toFloat(convertCurrency('USD', 'USD', coalesce(toFloat(spend), 0))) AS cost, toFloat(coalesce(toFloat(conversions), 0)) AS reported_conversion, 0 AS reported_conversion_value 
  FROM cloudflare_table 
  WHERE and(greaterOrEquals(toDateTime(report_date), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(report_date), toDateTime('2024-12-31 23:59:59')))
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_currency_conversion_handling
  '''
  
  SELECT toString(campaign_name) AS match_key, toString(campaign_name) AS campaign, toString(campaign_name) AS id, toString('Facebook') AS source, toFloat(coalesce(toFloat(impressions), 0)) AS impressions, toFloat(coalesce(toFloat(clicks), 0)) AS clicks, toFloat(convertCurrency(spend_currency, 'USD', coalesce(toFloat(spend_amount), 0))) AS cost, toFloat(coalesce(toFloat(conversions), 0)) AS reported_conversion, 0 AS reported_conversion_value 
  FROM currency_test_table 
  WHERE and(greaterOrEquals(toDateTime(date), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(date), toDateTime('2024-12-31 23:59:59')))
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_facebook_ads_query_generation
  '''
  
  SELECT toString(campaign_name) AS match_key, toString(campaign_name) AS campaign, toString(campaign_name) AS id, toString('Facebook') AS source, toFloat(coalesce(toFloat(impressions), 0)) AS impressions, toFloat(coalesce(toFloat(clicks), 0)) AS clicks, toFloat(convertCurrency('USD', 'USD', coalesce(toFloat(spend_usd), 0))) AS cost, toFloat(coalesce(toFloat(conversions), 0)) AS reported_conversion, 0 AS reported_conversion_value 
  FROM facebook_table 
  WHERE and(greaterOrEquals(toDateTime(report_date), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(report_date), toDateTime('2024-12-31 23:59:59')))
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_google_ads_query_generation
  '''
  
  SELECT toString(google_campaign.campaign_name) AS match_key, toString(google_campaign.campaign_name) AS campaign, toString(google_campaign.campaign_id) AS id, toString('google') AS source, toFloat(SUM(ifNull(toFloat(google_stats.metrics_impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(google_stats.metrics_clicks), 0))) AS clicks, toFloat(SUM(toFloat(divide(google_stats.metrics_cost_micros, 1000000)))) AS cost, toFloat(SUM(ifNull(toFloat(google_stats.metrics_conversions), 0))) AS reported_conversion, toFloat(SUM(ifNull(toFloat(google_stats.metrics_conversions_value), 0))) AS reported_conversion_value 
  FROM google_campaign LEFT JOIN google_stats ON equals(toString(google_campaign.campaign_id), toString(google_stats.campaign_id)) 
  WHERE and(greaterOrEquals(toDateTime(google_stats.segments_date), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(google_stats.segments_date), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY toString(google_campaign.campaign_name), toString(google_campaign.campaign_id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_google_ads_query_generation_with_clp_currency
  '''
  
  SELECT toString(google_campaign.campaign_name) AS match_key, toString(google_campaign.campaign_name) AS campaign, toString(google_campaign.campaign_id) AS id, toString('google') AS source, toFloat(SUM(ifNull(toFloat(google_stats.metrics_impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(google_stats.metrics_clicks), 0))) AS clicks, SUM(toFloat(convertCurrency(coalesce(google_stats.customer_currency_code, 'CLP'), 'CLP', toFloat(divide(google_stats.metrics_cost_micros, 1000000))))) AS cost, toFloat(SUM(ifNull(toFloat(google_stats.metrics_conversions), 0))) AS reported_conversion, SUM(toFloat(convertCurrency(coalesce(google_stats.customer_currency_code, 'CLP'), 'CLP', ifNull(toFloat(google_stats.metrics_conversions_value), 0)))) AS reported_conversion_value 
  FROM google_campaign LEFT JOIN google_stats ON equals(toString(google_campaign.campaign_id), toString(google_stats.campaign_id)) 
  WHERE and(greaterOrEquals(toDateTime(google_stats.segments_date), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(google_stats.segments_date), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY toString(google_campaign.campaign_name), toString(google_campaign.campaign_id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_linkedin_ads_query_generation
  '''
  
  SELECT toString(linkedin_campaign_groups.name) AS match_key, toString(linkedin_campaign_groups.name) AS campaign, toString(linkedin_campaign_groups.id) AS id, toString('linkedin') AS source, toFloat(SUM(ifNull(toFloat(linkedin_campaign_group_stats.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(linkedin_campaign_group_stats.clicks), 0))) AS clicks, toFloat(SUM(ifNull(toFloat(linkedin_campaign_group_stats.cost_in_usd), 0))) AS cost, toFloat(SUM(ifNull(toFloat(linkedin_campaign_group_stats.external_website_conversions), 0))) AS reported_conversion, 0 AS reported_conversion_value 
  FROM linkedin_campaign_groups LEFT JOIN linkedin_campaign_group_stats ON equals(toString(linkedin_campaign_groups.id), toString(linkedin_campaign_group_stats.campaign_group_id)) 
  WHERE and(greaterOrEquals(toDateTime(linkedin_campaign_group_stats.date_start), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(linkedin_campaign_group_stats.date_start), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY toString(linkedin_campaign_groups.name), toString(linkedin_campaign_groups.id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_match_key_uses_campaign_id_when_configured
  '''
  
  SELECT toString(metaads_campaigns.id) AS match_key, toString(metaads_campaigns.name) AS campaign, toString(metaads_campaigns.id) AS id, toString('meta') AS source, toFloat(SUM(ifNull(toFloat(metaads_campaign_stats.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(metaads_campaign_stats.clicks), 0))) AS clicks, SUM(ifNull(toFloat(metaads_campaign_stats.spend), 0)) AS cost, 0 AS reported_conversion, 0 AS reported_conversion_value 
  FROM metaads_campaigns LEFT JOIN metaads_campaign_stats ON equals(toString(metaads_campaigns.id), toString(metaads_campaign_stats.campaign_id)) 
  WHERE and(greaterOrEquals(toDateTime(metaads_campaign_stats.date_stop), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(metaads_campaign_stats.date_stop), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY toString(metaads_campaigns.name), toString(metaads_campaigns.id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_match_key_uses_campaign_name_by_default
  '''
  
  SELECT toString(metaads_campaigns.name) AS match_key, toString(metaads_campaigns.name) AS campaign, toString(metaads_campaigns.id) AS id, toString('meta') AS source, toFloat(SUM(ifNull(toFloat(metaads_campaign_stats.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(metaads_campaign_stats.clicks), 0))) AS clicks, SUM(ifNull(toFloat(metaads_campaign_stats.spend), 0)) AS cost, 0 AS reported_conversion, 0 AS reported_conversion_value 
  FROM metaads_campaigns LEFT JOIN metaads_campaign_stats ON equals(toString(metaads_campaigns.id), toString(metaads_campaign_stats.campaign_id)) 
  WHERE and(greaterOrEquals(toDateTime(metaads_campaign_stats.date_stop), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(metaads_campaign_stats.date_stop), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY toString(metaads_campaigns.name), toString(metaads_campaigns.id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_meta_ads_query_at_hierarchy_levels_0_ad_group
  '''
  
  SELECT '' AS match_key, coalesce(toString(metaads_campaigns.name), 'Unknown campaign') AS campaign, coalesce(toString(metaads_campaigns.id), 'unknown') AS id, toString('meta') AS source, toString(metaads_adsets.name) AS ad_group_name, toString(metaads_adsets.id) AS ad_group_id, NULL AS ad_name, NULL AS ad_id, toFloat(SUM(ifNull(toFloat(metaads_adset_stats.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(metaads_adset_stats.clicks), 0))) AS clicks, SUM(ifNull(toFloat(metaads_adset_stats.spend), 0)) AS cost, 0 AS reported_conversion, 0 AS reported_conversion_value 
  FROM metaads_adsets LEFT JOIN metaads_adset_stats ON equals(toString(metaads_adsets.id), toString(metaads_adset_stats.adset_id)) LEFT JOIN metaads_campaigns ON equals(toString(metaads_adsets.campaign_id), toString(metaads_campaigns.id)) 
  WHERE and(greaterOrEquals(toDateTime(metaads_adset_stats.date_stop), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(metaads_adset_stats.date_stop), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY coalesce(toString(metaads_campaigns.name), 'Unknown campaign'), coalesce(toString(metaads_campaigns.id), 'unknown'), toString(metaads_adsets.name), toString(metaads_adsets.id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_meta_ads_query_at_hierarchy_levels_1_ad
  '''
  
  SELECT '' AS match_key, coalesce(toString(metaads_campaigns.name), 'Unknown campaign') AS campaign, coalesce(toString(metaads_campaigns.id), 'unknown') AS id, toString('meta') AS source, coalesce(toString(metaads_adsets.name), 'Unknown ad group') AS ad_group_name, coalesce(toString(metaads_adsets.id), 'unknown') AS ad_group_id, toString(metaads_ads.name) AS ad_name, toString(metaads_ads.id) AS ad_id, toFloat(SUM(ifNull(toFloat(metaads_ad_stats.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(metaads_ad_stats.clicks), 0))) AS clicks, SUM(ifNull(toFloat(metaads_ad_stats.spend), 0)) AS cost, 0 AS reported_conversion, 0 AS reported_conversion_value 
  FROM metaads_ads LEFT JOIN metaads_ad_stats ON equals(toString(metaads_ads.id), toString(metaads_ad_stats.ad_id)) LEFT JOIN metaads_adsets ON equals(toString(metaads_ads.adset_id), toString(metaads_adsets.id)) LEFT JOIN metaads_campaigns ON equals(toString(metaads_adsets.campaign_id), toString(metaads_campaigns.id)) 
  WHERE and(greaterOrEquals(toDateTime(metaads_ad_stats.date_stop), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(metaads_ad_stats.date_stop), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY coalesce(toString(metaads_campaigns.name), 'Unknown campaign'), coalesce(toString(metaads_campaigns.id), 'unknown'), coalesce(toString(metaads_adsets.name), 'Unknown ad group'), coalesce(toString(metaads_adsets.id), 'unknown'), toString(metaads_ads.name), toString(metaads_ads.id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_meta_ads_query_generation
  '''
  
  SELECT toString(meta_campaigns.name) AS match_key, toString(meta_campaigns.name) AS campaign, toString(meta_campaigns.id) AS id, toString('meta') AS source, toFloat(SUM(ifNull(toFloat(meta_campaign_stats.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(meta_campaign_stats.clicks), 0))) AS clicks, SUM(ifNull(toFloat(meta_campaign_stats.spend), 0)) AS cost, toFloat(SUM(if(greater(arraySum(x -> JSONExtractFloat(x, 'value'), arrayFilter(x -> or(equals(JSONExtractString(x, 'action_type'), 'omni_purchase'), equals(JSONExtractString(x, 'action_type'), 'omni_lead'), equals(JSONExtractString(x, 'action_type'), 'omni_complete_registration'), equals(JSONExtractString(x, 'action_type'), 'omni_app_install'), equals(JSONExtractString(x, 'action_type'), 'omni_subscribe')), JSONExtractArrayRaw(coalesce(meta_campaign_stats.actions, '[]')))), 0), arraySum(x -> JSONExtractFloat(x, 'value'), arrayFilter(x -> or(equals(JSONExtractString(x, 'action_type'), 'omni_purchase'), equals(JSONExtractString(x, 'action_type'), 'omni_lead'), equals(JSONExtractString(x, 'action_type'), 'omni_complete_registration'), equals(JSONExtractString(x, 'action_type'), 'omni_app_install'), equals(JSONExtractString(x, 'action_type'), 'omni_subscribe')), JSONExtractArrayRaw(coalesce(meta_campaign_stats.actions, '[]')))), if(greater(arraySum(x -> JSONExtractFloat(x, 'value'), arrayFilter(x -> or(equals(JSONExtractString(x, 'action_type'), 'purchase'), equals(JSONExtractString(x, 'action_type'), 'lead'), equals(JSONExtractString(x, 'action_type'), 'complete_registration'), equals(JSONExtractString(x, 'action_type'), 'app_install'), equals(JSONExtractString(x, 'action_type'), 'subscribe')), JSONExtractArrayRaw(coalesce(meta_campaign_stats.actions, '[]')))), 0), arraySum(x -> JSONExtractFloat(x, 'value'), arrayFilter(x -> or(equals(JSONExtractString(x, 'action_type'), 'purchase'), equals(JSONExtractString(x, 'action_type'), 'lead'), equals(JSONExtractString(x, 'action_type'), 'complete_registration'), equals(JSONExtractString(x, 'action_type'), 'app_install'), equals(JSONExtractString(x, 'action_type'), 'subscribe')), JSONExtractArrayRaw(coalesce(meta_campaign_stats.actions, '[]')))), arraySum(x -> JSONExtractFloat(x, 'value'), arrayFilter(x -> or(equals(JSONExtractString(x, 'action_type'), 'offsite_conversion.fb_pixel_purchase'), equals(JSONExtractString(x, 'action_type'), 'app_custom_event.fb_mobile_purchase'), equals(JSONExtractString(x, 'action_type'), 'offsite_conversion.fb_pixel_lead'), equals(JSONExtractString(x, 'action_type'), 'onsite_conversion.lead_grouped'), equals(JSONExtractString(x, 'action_type'), 'offsite_conversion.fb_pixel_complete_registration'), equals(JSONExtractString(x, 'action_type'), 'app_custom_event.fb_mobile_complete_registration'), equals(JSONExtractString(x, 'action_type'), 'offsite_complete_registration_add_meta_leads'), equals(JSONExtractString(x, 'action_type'), 'mobile_app_install'), equals(JSONExtractString(x, 'action_type'), 'offsite_conversion.fb_pixel_subscribe')), JSONExtractArrayRaw(coalesce(meta_campaign_stats.actions, '[]')))))))) AS reported_conversion, toFloat(SUM(if(greater(arraySum(x -> JSONExtractFloat(x, 'value'), arrayFilter(x -> or(equals(JSONExtractString(x, 'action_type'), 'omni_purchase'), equals(JSONExtractString(x, 'action_type'), 'omni_lead'), equals(JSONExtractString(x, 'action_type'), 'omni_complete_registration'), equals(JSONExtractString(x, 'action_type'), 'omni_app_install'), equals(JSONExtractString(x, 'action_type'), 'omni_subscribe')), JSONExtractArrayRaw(coalesce(meta_campaign_stats.action_values, '[]')))), 0), arraySum(x -> JSONExtractFloat(x, 'value'), arrayFilter(x -> or(equals(JSONExtractString(x, 'action_type'), 'omni_purchase'), equals(JSONExtractString(x, 'action_type'), 'omni_lead'), equals(JSONExtractString(x, 'action_type'), 'omni_complete_registration'), equals(JSONExtractString(x, 'action_type'), 'omni_app_install'), equals(JSONExtractString(x, 'action_type'), 'omni_subscribe')), JSONExtractArrayRaw(coalesce(meta_campaign_stats.action_values, '[]')))), if(greater(arraySum(x -> JSONExtractFloat(x, 'value'), arrayFilter(x -> or(equals(JSONExtractString(x, 'action_type'), 'purchase'), equals(JSONExtractString(x, 'action_type'), 'lead'), equals(JSONExtractString(x, 'action_type'), 'complete_registration'), equals(JSONExtractString(x, 'action_type'), 'app_install'), equals(JSONExtractString(x, 'action_type'), 'subscribe')), JSONExtractArrayRaw(coalesce(meta_campaign_stats.action_values, '[]')))), 0), arraySum(x -> JSONExtractFloat(x, 'value'), arrayFilter(x -> or(equals(JSONExtractString(x, 'action_type'), 'purchase'), equals(JSONExtractString(x, 'action_type'), 'lead'), equals(JSONExtractString(x, 'action_type'), 'complete_registration'), equals(JSONExtractString(x, 'action_type'), 'app_install'), equals(JSONExtractString(x, 'action_type'), 'subscribe')), JSONExtractArrayRaw(coalesce(meta_campaign_stats.action_values, '[]')))), arraySum(x -> JSONExtractFloat(x, 'value'), arrayFilter(x -> or(equals(JSONExtractString(x, 'action_type'), 'offsite_conversion.fb_pixel_purchase'), equals(JSONExtractString(x, 'action_type'), 'app_custom_event.fb_mobile_purchase'), equals(JSONExtractString(x, 'action_type'), 'offsite_conversion.fb_pixel_lead'), equals(JSONExtractString(x, 'action_type'), 'onsite_conversion.lead_grouped'), equals(JSONExtractString(x, 'action_type'), 'offsite_conversion.fb_pixel_complete_registration'), equals(JSONExtractString(x, 'action_type'), 'app_custom_event.fb_mobile_complete_registration'), equals(JSONExtractString(x, 'action_type'), 'offsite_complete_registration_add_meta_leads'), equals(JSONExtractString(x, 'action_type'), 'mobile_app_install'), equals(JSONExtractString(x, 'action_type'), 'offsite_conversion.fb_pixel_subscribe')), JSONExtractArrayRaw(coalesce(meta_campaign_stats.action_values, '[]')))))))) AS reported_conversion_value 
  FROM meta_campaigns LEFT JOIN meta_campaign_stats ON equals(toString(meta_campaigns.id), toString(meta_campaign_stats.campaign_id)) 
  WHERE and(greaterOrEquals(toDateTime(meta_campaign_stats.date_stop), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(meta_campaign_stats.date_stop), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY toString(meta_campaigns.name), toString(meta_campaigns.id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_native_adapter_query_at_hierarchy_levels_00_google_ad_group
  '''
  
  SELECT '' AS match_key, coalesce(toString(googleads_campaign.campaign_name), 'Unknown campaign') AS campaign, coalesce(toString(googleads_campaign.campaign_id), 'unknown') AS id, toString('google') AS source, toString(googleads_ad_group.ad_group_name) AS ad_group_name, toString(googleads_ad_group.ad_group_id) AS ad_group_id, NULL AS ad_name, NULL AS ad_id, toFloat(SUM(ifNull(toFloat(googleads_ad_group_stats.metrics_impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(googleads_ad_group_stats.metrics_clicks), 0))) AS clicks, toFloat(SUM(toFloat(divide(googleads_ad_group_stats.metrics_cost_micros, 1000000)))) AS cost, toFloat(SUM(ifNull(toFloat(googleads_ad_group_stats.metrics_conversions), 0))) AS reported_conversion, toFloat(SUM(ifNull(toFloat(googleads_ad_group_stats.metrics_conversions_value), 0))) AS reported_conversion_value 
  FROM googleads_ad_group LEFT JOIN googleads_ad_group_stats ON equals(toString(googleads_ad_group.ad_group_id), toString(googleads_ad_group_stats.ad_group_id)) LEFT JOIN googleads_campaign ON equals(toString(googleads_ad_group.campaign_id), toString(googleads_campaign.campaign_id)) 
  WHERE and(greaterOrEquals(toDateTime(googleads_ad_group_stats.segments_date), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(googleads_ad_group_stats.segments_date), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY coalesce(toString(googleads_campaign.campaign_name), 'Unknown campaign'), coalesce(toString(googleads_campaign.campaign_id), 'unknown'), toString(googleads_ad_group.ad_group_name), toString(googleads_ad_group.ad_group_id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_native_adapter_query_at_hierarchy_levels_01_google_ad
  '''
  
  SELECT '' AS match_key, coalesce(toString(googleads_campaign.campaign_name), 'Unknown campaign') AS campaign, coalesce(toString(googleads_campaign.campaign_id), 'unknown') AS id, toString('google') AS source, coalesce(toString(googleads_ad_group.ad_group_name), 'Unknown ad group') AS ad_group_name, coalesce(toString(googleads_ad_group.ad_group_id), 'unknown') AS ad_group_id, toString(googleads_ad.ad_group_ad_ad_id) AS ad_name, toString(googleads_ad.ad_group_ad_ad_id) AS ad_id, toFloat(SUM(ifNull(toFloat(googleads_ad_stats.metrics_impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(googleads_ad_stats.metrics_clicks), 0))) AS clicks, toFloat(SUM(toFloat(divide(googleads_ad_stats.metrics_cost_micros, 1000000)))) AS cost, toFloat(SUM(ifNull(toFloat(googleads_ad_stats.metrics_conversions), 0))) AS reported_conversion, toFloat(SUM(ifNull(toFloat(googleads_ad_stats.metrics_conversions_value), 0))) AS reported_conversion_value 
  FROM googleads_ad LEFT JOIN googleads_ad_stats ON equals(toString(googleads_ad.ad_group_ad_ad_id), toString(googleads_ad_stats.ad_group_ad_ad_id)) LEFT JOIN googleads_ad_group ON equals(toString(googleads_ad.ad_group_id), toString(googleads_ad_group.ad_group_id)) LEFT JOIN googleads_campaign ON equals(toString(googleads_ad_group.campaign_id), toString(googleads_campaign.campaign_id)) 
  WHERE and(greaterOrEquals(toDateTime(googleads_ad_stats.segments_date), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(googleads_ad_stats.segments_date), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY coalesce(toString(googleads_campaign.campaign_name), 'Unknown campaign'), coalesce(toString(googleads_campaign.campaign_id), 'unknown'), coalesce(toString(googleads_ad_group.ad_group_name), 'Unknown ad group'), coalesce(toString(googleads_ad_group.ad_group_id), 'unknown'), toString(googleads_ad.ad_group_ad_ad_id), toString(googleads_ad.ad_group_ad_ad_id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_native_adapter_query_at_hierarchy_levels_02_google_no_adset_ad
  '''
  
  SELECT '' AS match_key, coalesce(toString(googleads_campaign.campaign_name), 'Unknown campaign') AS campaign, coalesce(toString(googleads_campaign.campaign_id), 'unknown') AS id, toString('google') AS source, 'No sync' AS ad_group_name, 'No sync' AS ad_group_id, toString(googleads_ad.ad_group_ad_ad_id) AS ad_name, toString(googleads_ad.ad_group_ad_ad_id) AS ad_id, toFloat(SUM(ifNull(toFloat(googleads_ad_stats.metrics_impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(googleads_ad_stats.metrics_clicks), 0))) AS clicks, toFloat(SUM(toFloat(divide(googleads_ad_stats.metrics_cost_micros, 1000000)))) AS cost, toFloat(SUM(ifNull(toFloat(googleads_ad_stats.metrics_conversions), 0))) AS reported_conversion, toFloat(SUM(ifNull(toFloat(googleads_ad_stats.metrics_conversions_value), 0))) AS reported_conversion_value 
  FROM googleads_ad LEFT JOIN googleads_ad_stats ON equals(toString(googleads_ad.ad_group_ad_ad_id), toString(googleads_ad_stats.ad_group_ad_ad_id)) LEFT JOIN googleads_campaign ON equals(toString(googleads_ad.campaign_id), toString(googleads_campaign.campaign_id)) 
  WHERE and(greaterOrEquals(toDateTime(googleads_ad_stats.segments_date), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(googleads_ad_stats.segments_date), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY coalesce(toString(googleads_campaign.campaign_name), 'Unknown campaign'), coalesce(toString(googleads_campaign.campaign_id), 'unknown'), 'No sync', 'No sync', toString(googleads_ad.ad_group_ad_ad_id), toString(googleads_ad.ad_group_ad_ad_id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_native_adapter_query_at_hierarchy_levels_03_tiktok_ad_group
  '''
  
  SELECT '' AS match_key, coalesce(toString(tiktokads_campaigns.campaign_name), 'Unknown campaign') AS campaign, coalesce(toString(tiktokads_campaigns.campaign_id), 'unknown') AS id, toString('tiktok') AS source, toString(tiktokads_ad_groups.adgroup_name) AS ad_group_name, toString(tiktokads_ad_groups.adgroup_id) AS ad_group_id, NULL AS ad_name, NULL AS ad_id, toFloat(SUM(ifNull(toFloat(tiktokads_ad_group_report.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(tiktokads_ad_group_report.clicks), 0))) AS clicks, SUM(ifNull(toFloat(tiktokads_ad_group_report.spend), 0)) AS cost, toFloat(SUM(ifNull(toFloat(tiktokads_ad_group_report.conversion), 0))) AS reported_conversion, 0 AS reported_conversion_value 
  FROM tiktokads_ad_groups LEFT JOIN tiktokads_ad_group_report ON equals(toString(tiktokads_ad_groups.adgroup_id), toString(tiktokads_ad_group_report.adgroup_id)) LEFT JOIN tiktokads_campaigns ON equals(toString(tiktokads_ad_groups.campaign_id), toString(tiktokads_campaigns.campaign_id)) 
  WHERE and(greaterOrEquals(toDateTime(tiktokads_ad_group_report.stat_time_day), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(tiktokads_ad_group_report.stat_time_day), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY coalesce(toString(tiktokads_campaigns.campaign_name), 'Unknown campaign'), coalesce(toString(tiktokads_campaigns.campaign_id), 'unknown'), toString(tiktokads_ad_groups.adgroup_name), toString(tiktokads_ad_groups.adgroup_id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_native_adapter_query_at_hierarchy_levels_04_tiktok_ad
  '''
  
  SELECT '' AS match_key, coalesce(toString(tiktokads_campaigns.campaign_name), 'Unknown campaign') AS campaign, coalesce(toString(tiktokads_campaigns.campaign_id), 'unknown') AS id, toString('tiktok') AS source, coalesce(toString(tiktokads_ad_groups.adgroup_name), 'Unknown ad group') AS ad_group_name, coalesce(toString(tiktokads_ad_groups.adgroup_id), 'unknown') AS ad_group_id, toString(tiktokads_ads.ad_name) AS ad_name, toString(tiktokads_ads.ad_id) AS ad_id, toFloat(SUM(ifNull(toFloat(tiktokads_ad_report.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(tiktokads_ad_report.clicks), 0))) AS clicks, SUM(ifNull(toFloat(tiktokads_ad_report.spend), 0)) AS cost, toFloat(SUM(ifNull(toFloat(tiktokads_ad_report.conversion), 0))) AS reported_conversion, 0 AS reported_conversion_value 
  FROM tiktokads_ads LEFT JOIN tiktokads_ad_report ON equals(toString(tiktokads_ads.ad_id), toString(tiktokads_ad_report.ad_id)) LEFT JOIN tiktokads_ad_groups ON equals(toString(tiktokads_ads.adgroup_id), toString(tiktokads_ad_groups.adgroup_id)) LEFT JOIN tiktokads_campaigns ON equals(toString(tiktokads_ad_groups.campaign_id), toString(tiktokads_campaigns.campaign_id)) 
  WHERE and(greaterOrEquals(toDateTime(tiktokads_ad_report.stat_time_day), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(tiktokads_ad_report.stat_time_day), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY coalesce(toString(tiktokads_campaigns.campaign_name), 'Unknown campaign'), coalesce(toString(tiktokads_campaigns.campaign_id), 'unknown'), coalesce(toString(tiktokads_ad_groups.adgroup_name), 'Unknown ad group'), coalesce(toString(tiktokads_ad_groups.adgroup_id), 'unknown'), toString(tiktokads_ads.ad_name), toString(tiktokads_ads.ad_id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_native_adapter_query_at_hierarchy_levels_05_reddit_ad_group
  '''
  
  SELECT '' AS match_key, coalesce(toString(redditads_campaigns.name), 'Unknown campaign') AS campaign, coalesce(toString(redditads_campaigns.id), 'unknown') AS id, toString('reddit') AS source, toString(redditads_ad_groups.name) AS ad_group_name, toString(redditads_ad_groups.id) AS ad_group_id, NULL AS ad_name, NULL AS ad_id, toFloat(SUM(ifNull(toFloat(redditads_ad_group_report.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(redditads_ad_group_report.clicks), 0))) AS clicks, SUM(toFloat(divide(redditads_ad_group_report.spend, 1000000))) AS cost, toFloat(SUM(ifNull(toFloat(redditads_ad_group_report.key_conversion_total_count), 0))) AS reported_conversion, toFloat(plus(SUM(ifNull(divide(toFloat(redditads_ad_group_report.conversion_purchase_total_value), 100), 0)), SUM(ifNull(divide(toFloat(redditads_ad_group_report.conversion_signup_total_value), 100), 0)))) AS reported_conversion_value 
  FROM redditads_ad_groups LEFT JOIN redditads_ad_group_report ON equals(toString(redditads_ad_groups.id), toString(redditads_ad_group_report.ad_group_id)) LEFT JOIN redditads_campaigns ON equals(toString(redditads_ad_groups.campaign_id), toString(redditads_campaigns.id)) 
  WHERE and(greaterOrEquals(toDateTime(redditads_ad_group_report.date), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(redditads_ad_group_report.date), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY coalesce(toString(redditads_campaigns.name), 'Unknown campaign'), coalesce(toString(redditads_campaigns.id), 'unknown'), toString(redditads_ad_groups.name), toString(redditads_ad_groups.id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_native_adapter_query_at_hierarchy_levels_06_reddit_ad
  '''
  
  SELECT '' AS match_key, coalesce(toString(redditads_campaigns.name), 'Unknown campaign') AS campaign, coalesce(toString(redditads_campaigns.id), 'unknown') AS id, toString('reddit') AS source, coalesce(toString(redditads_ad_groups.name), 'Unknown ad group') AS ad_group_name, coalesce(toString(redditads_ad_groups.id), 'unknown') AS ad_group_id, toString(redditads_ads.name) AS ad_name, toString(redditads_ads.id) AS ad_id, toFloat(SUM(ifNull(toFloat(redditads_ad_report.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(redditads_ad_report.clicks), 0))) AS clicks, SUM(toFloat(divide(redditads_ad_report.spend, 1000000))) AS cost, toFloat(SUM(ifNull(toFloat(redditads_ad_report.key_conversion_total_count), 0))) AS reported_conversion, toFloat(plus(SUM(ifNull(divide(toFloat(redditads_ad_report.conversion_purchase_total_value), 100), 0)), SUM(ifNull(divide(toFloat(redditads_ad_report.conversion_signup_total_value), 100), 0)))) AS reported_conversion_value 
  FROM redditads_ads LEFT JOIN redditads_ad_report ON equals(toString(redditads_ads.id), toString(redditads_ad_report.ad_id)) LEFT JOIN redditads_ad_groups ON equals(toString(redditads_ads.ad_group_id), toString(redditads_ad_groups.id)) LEFT JOIN redditads_campaigns ON equals(toString(redditads_ad_groups.campaign_id), toString(redditads_campaigns.id)) 
  WHERE and(greaterOrEquals(toDateTime(redditads_ad_report.date), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(redditads_ad_report.date), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY coalesce(toString(redditads_campaigns.name), 'Unknown campaign'), coalesce(toString(redditads_campaigns.id), 'unknown'), coalesce(toString(redditads_ad_groups.name), 'Unknown ad group'), coalesce(toString(redditads_ad_groups.id), 'unknown'), toString(redditads_ads.name), toString(redditads_ads.id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_native_adapter_query_at_hierarchy_levels_07_pinterest_ad_group
  '''
  
  SELECT '' AS match_key, coalesce(toString(pinterestads_campaigns.name), 'Unknown campaign') AS campaign, coalesce(toString(pinterestads_campaigns.id), 'unknown') AS id, toString('pinterest') AS source, toString(pinterestads_ad_groups.name) AS ad_group_name, toString(pinterestads_ad_groups.id) AS ad_group_id, NULL AS ad_name, NULL AS ad_id, toFloat(0) AS impressions, toFloat(0) AS clicks, toFloat(0) AS cost, toFloat(0) AS reported_conversion, toFloat(0) AS reported_conversion_value 
  FROM pinterestads_ad_groups LEFT JOIN pinterestads_ad_group_analytics ON equals(toString(pinterestads_ad_groups.id), toString(pinterestads_ad_group_analytics.ad_group_id)) LEFT JOIN pinterestads_campaigns ON equals(toString(pinterestads_ad_groups.campaign_id), toString(pinterestads_campaigns.id)) 
  WHERE and(greaterOrEquals(toDateTime(pinterestads_ad_group_analytics.date), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(pinterestads_ad_group_analytics.date), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY coalesce(toString(pinterestads_campaigns.name), 'Unknown campaign'), coalesce(toString(pinterestads_campaigns.id), 'unknown'), toString(pinterestads_ad_groups.name), toString(pinterestads_ad_groups.id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_native_adapter_query_at_hierarchy_levels_08_pinterest_ad
  '''
  
  SELECT '' AS match_key, coalesce(toString(pinterestads_campaigns.name), 'Unknown campaign') AS campaign, coalesce(toString(pinterestads_campaigns.id), 'unknown') AS id, toString('pinterest') AS source, coalesce(toString(pinterestads_ad_groups.name), 'Unknown ad group') AS ad_group_name, coalesce(toString(pinterestads_ad_groups.id), 'unknown') AS ad_group_id, toString(pinterestads_ads.name) AS ad_name, toString(pinterestads_ads.id) AS ad_id, toFloat(0) AS impressions, toFloat(0) AS clicks, toFloat(0) AS cost, toFloat(0) AS reported_conversion, toFloat(0) AS reported_conversion_value 
  FROM pinterestads_ads LEFT JOIN pinterestads_ad_analytics ON equals(toString(pinterestads_ads.id), toString(pinterestads_ad_analytics.ad_id)) LEFT JOIN pinterestads_ad_groups ON equals(toString(pinterestads_ads.ad_group_id), toString(pinterestads_ad_groups.id)) LEFT JOIN pinterestads_campaigns ON equals(toString(pinterestads_ad_groups.campaign_id), toString(pinterestads_campaigns.id)) 
  WHERE and(greaterOrEquals(toDateTime(pinterestads_ad_analytics.date), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(pinterestads_ad_analytics.date), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY coalesce(toString(pinterestads_campaigns.name), 'Unknown campaign'), coalesce(toString(pinterestads_campaigns.id), 'unknown'), coalesce(toString(pinterestads_ad_groups.name), 'Unknown ad group'), coalesce(toString(pinterestads_ad_groups.id), 'unknown'), toString(pinterestads_ads.name), toString(pinterestads_ads.id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_native_adapter_query_at_hierarchy_levels_09_snapchat_ad_group
  '''
  
  SELECT '' AS match_key, coalesce(toString(snapchatads_campaigns.name), 'Unknown campaign') AS campaign, coalesce(toString(snapchatads_campaigns.id), 'unknown') AS id, toString('snapchat') AS source, toString(snapchatads_ad_squads.name) AS ad_group_name, toString(snapchatads_ad_squads.id) AS ad_group_id, NULL AS ad_name, NULL AS ad_id, toFloat(SUM(ifNull(toFloat(snapchatads_ad_squad_stats_daily.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(snapchatads_ad_squad_stats_daily.swipes), 0))) AS clicks, SUM(ifNull(divide(toFloat(snapchatads_ad_squad_stats_daily.spend), 1000000), 0)) AS cost, 0 AS reported_conversion, 0 AS reported_conversion_value 
  FROM snapchatads_ad_squads LEFT JOIN snapchatads_ad_squad_stats_daily ON equals(toString(snapchatads_ad_squads.id), toString(snapchatads_ad_squad_stats_daily.id)) LEFT JOIN snapchatads_campaigns ON equals(toString(snapchatads_ad_squads.campaign_id), toString(snapchatads_campaigns.id)) 
  WHERE and(greaterOrEquals(toDateTime(snapchatads_ad_squad_stats_daily.start_time), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(snapchatads_ad_squad_stats_daily.start_time), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY coalesce(toString(snapchatads_campaigns.name), 'Unknown campaign'), coalesce(toString(snapchatads_campaigns.id), 'unknown'), toString(snapchatads_ad_squads.name), toString(snapchatads_ad_squads.id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_native_adapter_query_at_hierarchy_levels_10_snapchat_ad
  '''
  
  SELECT '' AS match_key, coalesce(toString(snapchatads_campaigns.name), 'Unknown campaign') AS campaign, coalesce(toString(snapchatads_campaigns.id), 'unknown') AS id, toString('snapchat') AS source, coalesce(toString(snapchatads_ad_squads.name), 'Unknown ad group') AS ad_group_name, coalesce(toString(snapchatads_ad_squads.id), 'unknown') AS ad_group_id, toString(snapchatads_ads.name) AS ad_name, toString(snapchatads_ads.id) AS ad_id, toFloat(SUM(ifNull(toFloat(snapchatads_ad_stats_daily.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(snapchatads_ad_stats_daily.swipes), 0))) AS clicks, SUM(ifNull(divide(toFloat(snapchatads_ad_stats_daily.spend), 1000000), 0)) AS cost, 0 AS reported_conversion, 0 AS reported_conversion_value 
  FROM snapchatads_ads LEFT JOIN snapchatads_ad_stats_daily ON equals(toString(snapchatads_ads.id), toString(snapchatads_ad_stats_daily.id)) LEFT JOIN snapchatads_ad_squads ON equals(toString(snapchatads_ads.ad_squad_id), toString(snapchatads_ad_squads.id)) LEFT JOIN snapchatads_campaigns ON equals(toString(snapchatads_ad_squads.campaign_id), toString(snapchatads_campaigns.id)) 
  WHERE and(greaterOrEquals(toDateTime(snapchatads_ad_stats_daily.start_time), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(snapchatads_ad_stats_daily.start_time), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY coalesce(toString(snapchatads_campaigns.name), 'Unknown campaign'), coalesce(toString(snapchatads_campaigns.id), 'unknown'), coalesce(toString(snapchatads_ad_squads.name), 'Unknown ad group'), coalesce(toString(snapchatads_ad_squads.id), 'unknown'), toString(snapchatads_ads.name), toString(snapchatads_ads.id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_native_adapter_query_at_hierarchy_levels_11_linkedin_ad_group
  '''
  
  SELECT '' AS match_key, coalesce(toString(linkedinads_campaign_groups.name), 'Unknown campaign') AS campaign, coalesce(toString(linkedinads_campaign_groups.id), 'unknown') AS id, toString('linkedin') AS source, toString(linkedinads_campaigns.name) AS ad_group_name, toString(linkedinads_campaigns.id) AS ad_group_id, NULL AS ad_name, NULL AS ad_id, toFloat(SUM(ifNull(toFloat(linkedinads_campaign_stats.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(linkedinads_campaign_stats.clicks), 0))) AS clicks, toFloat(SUM(ifNull(toFloat(linkedinads_campaign_stats.cost_in_usd), 0))) AS cost, toFloat(SUM(ifNull(toFloat(linkedinads_campaign_stats.external_website_conversions), 0))) AS reported_conversion, 0 AS reported_conversion_value 
  FROM linkedinads_campaigns LEFT JOIN linkedinads_campaign_stats ON equals(toString(linkedinads_campaigns.id), toString(linkedinads_campaign_stats.campaign_id)) LEFT JOIN linkedinads_campaign_groups ON equals(toString(linkedinads_campaigns.campaign_group_id), toString(linkedinads_campaign_groups.id)) 
  WHERE and(greaterOrEquals(toDateTime(linkedinads_campaign_stats.date_start), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(linkedinads_campaign_stats.date_start), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY coalesce(toString(linkedinads_campaign_groups.name), 'Unknown campaign'), coalesce(toString(linkedinads_campaign_groups.id), 'unknown'), toString(linkedinads_campaigns.name), toString(linkedinads_campaigns.id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_native_adapter_query_at_hierarchy_levels_12_linkedin_ad
  '''
  
  SELECT '' AS match_key, coalesce(toString(linkedinads_campaign_groups.name), 'Unknown campaign') AS campaign, coalesce(toString(linkedinads_campaign_groups.id), 'unknown') AS id, toString('linkedin') AS source, coalesce(toString(linkedinads_campaigns.name), 'Unknown ad group') AS ad_group_name, coalesce(toString(linkedinads_campaigns.id), 'unknown') AS ad_group_id, toString(linkedinads_creatives.name) AS ad_name, toString(linkedinads_creatives.id) AS ad_id, toFloat(SUM(ifNull(toFloat(linkedinads_creative_stats.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(linkedinads_creative_stats.clicks), 0))) AS clicks, toFloat(SUM(ifNull(toFloat(linkedinads_creative_stats.cost_in_usd), 0))) AS cost, toFloat(SUM(ifNull(toFloat(linkedinads_creative_stats.external_website_conversions), 0))) AS reported_conversion, 0 AS reported_conversion_value 
  FROM linkedinads_creatives LEFT JOIN linkedinads_creative_stats ON equals(toString(linkedinads_creatives.id), toString(linkedinads_creative_stats.creative_id)) LEFT JOIN linkedinads_campaigns ON equals(toString(linkedinads_creatives.campaign_id), toString(linkedinads_campaigns.id)) LEFT JOIN linkedinads_campaign_groups ON equals(toString(linkedinads_campaigns.campaign_group_id), toString(linkedinads_campaign_groups.id)) 
  WHERE and(greaterOrEquals(toDateTime(linkedinads_creative_stats.date_start), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(linkedinads_creative_stats.date_start), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY coalesce(toString(linkedinads_campaign_groups.name), 'Unknown campaign'), coalesce(toString(linkedinads_campaign_groups.id), 'unknown'), coalesce(toString(linkedinads_campaigns.name), 'Unknown ad group'), coalesce(toString(linkedinads_campaigns.id), 'unknown'), toString(linkedinads_creatives.name), toString(linkedinads_creatives.id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_native_adapter_query_at_hierarchy_levels_13_bing_ad_group
  '''
  
  SELECT '' AS match_key, toString(bingads_ad_group_performance_report.campaign_name) AS campaign, toString(bingads_ad_group_performance_report.campaign_id) AS id, toString('bing') AS source, toString(bingads_ad_group_performance_report.ad_group_name) AS ad_group_name, toString(bingads_ad_group_performance_report.ad_group_id) AS ad_group_id, NULL AS ad_name, NULL AS ad_id, toFloat(SUM(ifNull(toFloat(bingads_ad_group_performance_report.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(bingads_ad_group_performance_report.clicks), 0))) AS clicks, SUM(ifNull(toFloat(bingads_ad_group_performance_report.spend), 0)) AS cost, toFloat(SUM(ifNull(toFloat(bingads_ad_group_performance_report.conversions), 0))) AS reported_conversion, toFloat(SUM(ifNull(toFloat(bingads_ad_group_performance_report.revenue), 0))) AS reported_conversion_value 
  FROM bingads_ad_group_performance_report 
  WHERE and(greaterOrEquals(toDateTime(bingads_ad_group_performance_report.time_period), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(bingads_ad_group_performance_report.time_period), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY toString(bingads_ad_group_performance_report.campaign_name), toString(bingads_ad_group_performance_report.campaign_id), toString(bingads_ad_group_performance_report.ad_group_name), toString(bingads_ad_group_performance_report.ad_group_id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_native_adapter_query_at_hierarchy_levels_14_bing_ad
  '''
  
  SELECT '' AS match_key, toString(bingads_ad_performance_report.campaign_name) AS campaign, toString(bingads_ad_performance_report.campaign_id) AS id, toString('bing') AS source, toString(bingads_ad_performance_report.ad_group_name) AS ad_group_name, toString(bingads_ad_performance_report.ad_group_id) AS ad_group_id, toString(bingads_ad_performance_report.ad_title) AS ad_name, toString(bingads_ad_performance_report.ad_id) AS ad_id, toFloat(SUM(ifNull(toFloat(bingads_ad_performance_report.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(bingads_ad_performance_report.clicks), 0))) AS clicks, SUM(ifNull(toFloat(bingads_ad_performance_report.spend), 0)) AS cost, toFloat(SUM(ifNull(toFloat(bingads_ad_performance_report.conversions), 0))) AS reported_conversion, toFloat(SUM(ifNull(toFloat(bingads_ad_performance_report.revenue), 0))) AS reported_conversion_value 
  FROM bingads_ad_performance_report 
  WHERE and(greaterOrEquals(toDateTime(bingads_ad_performance_report.time_period), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(bingads_ad_performance_report.time_period), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY toString(bingads_ad_performance_report.campaign_name), toString(bingads_ad_performance_report.campaign_id), toString(bingads_ad_performance_report.ad_group_name), toString(bingads_ad_performance_report.ad_group_id), toString(bingads_ad_performance_report.ad_title), toString(bingads_ad_performance_report.ad_id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_pinterest_ads_native_query_generation
  '''
  
  SELECT toString(pinterest_campaigns.name) AS match_key, toString(pinterest_campaigns.name) AS campaign, toString(pinterest_campaigns.id) AS id, toString('pinterest') AS source, toFloat(SUM(ifNull(toFloat(pinterest_campaign_analytics.total_impression), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(pinterest_campaign_analytics.total_clickthrough), 0))) AS clicks, SUM(toFloat(pinterest_campaign_analytics.spend_in_dollar)) AS cost, toFloat(0) AS reported_conversion, toFloat(0) AS reported_conversion_value 
  FROM pinterest_campaigns LEFT JOIN pinterest_campaign_analytics ON equals(toString(pinterest_campaigns.id), toString(pinterest_campaign_analytics.campaign_id)) 
  WHERE and(greaterOrEquals(toDateTime(pinterest_campaign_analytics.date), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(pinterest_campaign_analytics.date), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY toString(pinterest_campaigns.name), toString(pinterest_campaigns.id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_reddit_ads_query_generation
  '''
  
  SELECT toString(reddit_campaign.name) AS match_key, toString(reddit_campaign.name) AS campaign, toString(reddit_campaign.id) AS id, toString('reddit') AS source, toFloat(SUM(ifNull(toFloat(reddit_stats.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(reddit_stats.clicks), 0))) AS clicks, SUM(toFloat(divide(reddit_stats.spend, 1000000))) AS cost, toFloat(SUM(ifNull(toFloat(reddit_stats.key_conversion_total_count), 0))) AS reported_conversion, toFloat(plus(SUM(ifNull(divide(toFloat(reddit_stats.conversion_purchase_total_value), 100), 0)), SUM(ifNull(divide(toFloat(reddit_stats.conversion_signup_total_value), 100), 0)))) AS reported_conversion_value 
  FROM reddit_campaign LEFT JOIN reddit_stats ON equals(toString(reddit_campaign.id), toString(reddit_stats.campaign_id)) 
  WHERE and(greaterOrEquals(toDateTime(reddit_stats.date), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(reddit_stats.date), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY toString(reddit_campaign.name), toString(reddit_campaign.id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_tiktok_ads_native_query_generation
  '''
  
  SELECT toString(tiktok_campaigns.campaign_name) AS match_key, toString(tiktok_campaigns.campaign_name) AS campaign, toString(tiktok_campaigns.campaign_id) AS id, toString('tiktok') AS source, toFloat(SUM(ifNull(toFloat(tiktok_campaign_report.impressions), 0))) AS impressions, toFloat(SUM(ifNull(toFloat(tiktok_campaign_report.clicks), 0))) AS clicks, SUM(ifNull(toFloat(tiktok_campaign_report.spend), 0)) AS cost, toFloat(SUM(ifNull(toFloat(tiktok_campaign_report.conversion), 0))) AS reported_conversion, 0 AS reported_conversion_value 
  FROM tiktok_campaigns LEFT JOIN tiktok_campaign_report ON equals(toString(tiktok_campaigns.campaign_id), toString(tiktok_campaign_report.campaign_id)) 
  WHERE and(greaterOrEquals(toDateTime(tiktok_campaign_report.stat_time_day), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(tiktok_campaign_report.stat_time_day), toDateTime('2024-12-31 23:59:59'))) 
  GROUP BY toString(tiktok_campaigns.campaign_name), toString(tiktok_campaigns.campaign_id)
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_tiktok_ads_query_generation
  '''
  
  SELECT toString(campaign_name) AS match_key, toString(campaign_name) AS campaign, toString(campaign_name) AS id, toString('TikTok') AS source, toFloat(coalesce(toFloat(impressions), 0)) AS impressions, toFloat(coalesce(toFloat(clicks), 0)) AS clicks, toFloat(convertCurrency('USD', 'USD', coalesce(toFloat(spend), 0))) AS cost, toFloat(coalesce(toFloat(conversions), 0)) AS reported_conversion, 0 AS reported_conversion_value 
  FROM tiktok_table 
  WHERE and(greaterOrEquals(toDateTime(report_date), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(report_date), toDateTime('2024-12-31 23:59:59')))
  '''
# ---
# name: TestMarketingAnalyticsAdapters.test_union_query_compatibility
  '''
  
  SELECT campaign AS campaign, source AS source, impressions AS impressions, clicks AS clicks, cost AS cost 
  FROM (
    SELECT toString(campaign_id) AS match_key, toString(campaign_id) AS campaign, toString(campaign_id) AS id, toString('Facebook') AS source, toFloat(coalesce(toFloat(impressions), 0)) AS impressions, toFloat(coalesce(toFloat(clicks), 0)) AS clicks, toFloat(convertCurrency(currency, 'USD', coalesce(toFloat(spend), 0))) AS cost, toFloat(coalesce(toFloat(conversions), 0)) AS reported_conversion, 0 AS reported_conversion_value 
    FROM facebook_table 
    WHERE and(greaterOrEquals(toDateTime(date), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(date), toDateTime('2024-12-31 23:59:59'))) UNION ALL 
    SELECT toString(campaign_name) AS match_key, toString(campaign_name) AS campaign, toString(campaign_name) AS id, toString('TikTok') AS source, toFloat(coalesce(toFloat(impressions), 0)) AS impressions, toFloat(coalesce(toFloat(clicks), 0)) AS clicks, toFloat(convertCurrency(currency, 'USD', coalesce(toFloat(spend), 0))) AS cost, toFloat(coalesce(toFloat(conversions), 0)) AS reported_conversion, 0 AS reported_conversion_value 
    FROM tiktok_table 
    WHERE and(greaterOrEquals(toDateTime(date), toDateTime('2024-01-01 00:00:00')), lessOrEquals(toDateTime(date), toDateTime('2024-12-31 23:59:59')))) AS all_marketing_data
  '''
# ---
