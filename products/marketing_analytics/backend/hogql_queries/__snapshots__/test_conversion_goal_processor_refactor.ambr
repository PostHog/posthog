  FROM events 
  WHERE or(equals(events.event, 'purchase'), and(equals(events.event, '$pageview'), notEmpty(toString(ifNull(events.properties.utm_campaign, ''))), notEmpty(toString(ifNull(events.properties.utm_source, ''))))) 
  GROUP BY events.person_id 
  HAVING greater(length(conversion_timestamps), 0)) ARRAY JOIN arrayEnumerate(conversion_timestamps) AS i) ARRAY JOIN arrayEnumerate(attribution_weights) AS tp_idx)) AS attributed_conversions 
