{
    "name": "nightly-fleet-audit — sweep, propose, report",
    "description": "The unattended cron run. Concierge loads auditing-the-fleet, lists the fleet, finds one failing agent via sessions-list + session-logs, branches a DRAFT proposal (new-draft + validate, NO freeze/promote), writes the report to memory, and posts the Slack digest. Verifies the read-and-propose contract: no promote, no freeze, drafts only, durable outputs land.",
    "trigger": {
        "type": "cron",
        "cron_name": "nightly-fleet-audit",
        "prompt": "Run the nightly fleet audit for 2026-06-10. Load skills/auditing-the-fleet and follow it end to end. Sweep every agent in this team, investigate sessions, propose draft fixes, write the report to memory and post the Slack digest."
    },
    "fixtures": {
        "posthog__memory-read": {
            "path": "reports/fleet-audit/latest.md",
            "found": false
        },
        "posthog__agent-applications-list": {
            "results": [
                { "slug": "weekly-digest", "id": "app_1", "archived": false, "live_revision": "rev_1" },
                { "slug": "kudos-bot", "id": "app_2", "archived": false, "live_revision": "rev_2" }
            ]
        },
        "posthog__agent-applications-sessions-list": {
            "results": [
                { "id": "s_aaa", "state": "failed", "failure_reason": "limit_exceeded", "tool_call_count": 100 },
                { "id": "s_bbb", "state": "completed" }
            ]
        },
        "posthog__agent-applications-session-logs": {
            "events": [
                { "type": "tool_call", "tool_id": "@posthog/query", "turn": 40 },
                { "type": "tool_call", "tool_id": "@posthog/query", "turn": 41 },
                { "type": "error", "error_type": "limit_exceeded", "detail": "max_tool_calls (100) exceeded" }
            ]
        },
        "posthog__agent-applications-revisions-new-draft-create": {
            "id": "rev_1_draft",
            "state": "draft"
        },
        "posthog__agent-applications-revisions-validate-create": {
            "ok": true,
            "errors": []
        },
        "posthog__memory-write": { "ok": true },
        "posthog__slack-post-message": { "ts": "1700000000.000100", "channel": "C0FLEET" }
    },
    "expected": {
        "tool_calls_include": [
            "@posthog/load-skill",
            "posthog__agent-applications-list",
            "posthog__agent-applications-sessions-list",
            "posthog__agent-applications-revisions-new-draft-create",
            "posthog__agent-applications-revisions-validate-create",
            "posthog__memory-write"
        ],
        "load_skill_includes": ["auditing-the-fleet"],
        "tool_calls_exclude": [
            "posthog__agent-applications-revisions-promote-create",
            "posthog__agent-applications-revisions-freeze-create",
            "posthog__agent-applications-revisions-archive-create"
        ],
        "assistant_text_matches_any": ["(?i)audit", "(?i)draft|proposal", "(?i)limit|max_tool_calls"],
        "max_turns": 30,
        "must_complete_within_ms": 120000,
        "final_state": "completed"
    }
}
