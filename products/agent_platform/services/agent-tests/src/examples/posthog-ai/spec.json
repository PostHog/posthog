{
    "models": { "mode": "manual", "models": [{ "model": "openai/gpt-5.5" }] },
    "triggers": [
        {
            "type": "slack",
            "config": {
                "mention_only": true,
                "auto_resume_threads": true,
                "allow_workspace_participants": false,
                "allow_direct_messages": true,
                "trusted_workspaces": "*",
                "ack_reaction": "eyes"
            }
        }
    ],
    "tools": [],
    "mcps": [
        {
            "kind": "principal",
            "id": "posthog",
            "url": "http://localhost:8787/mcp",
            "default_tool_approval": "allow",
            "auth": { "provider": "posthog" }
        }
    ],
    "skills": [],
    "identity_providers": [
        {
            "kind": "posthog",
            "scopes": [
                "openid",
                "profile",
                "email",
                "user:read",
                "query:read",
                "insight:read",
                "dashboard:read",
                "feature_flag:read",
                "experiment:read",
                "error_tracking:read",
                "event_definition:read",
                "property_definition:read",
                "cohort:read",
                "person:read",
                "session_recording:read",
                "survey:read",
                "action:read",
                "annotation:read"
            ]
        }
    ],
    "secrets": [],
    "limits": {
        "max_turns": 30,
        "max_tool_calls": 100,
        "max_wall_seconds": 600
    },
    "reasoning": "medium"
}
