{
    "name": "@posthog/agent-tools",
    "version": "0.1.0",
    "private": true,
    "description": "PostHog-shipped native tools for the agent platform. Each tool is one TS file + tests; the runner imports by id.",
    "license": "MIT",
    "author": "PostHog <hey@posthog.com>",
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts"
    },
    "scripts": {
        "lint": "oxlint --quiet .",
        "format": "oxfmt .",
        "format:check": "oxfmt --check .",
        "typescript:check": "tsc --noEmit -p .",
        "test": "vitest run"
    },
    "dependencies": {
        "@posthog/agent-shared": "workspace:*",
        "typebox": "^1.1.38",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@aws-sdk/client-s3": "^3.723.0",
        "@types/node": "catalog:",
        "typescript": "catalog:",
        "vitest": "^4.1.0"
    },
    "engines": {
        "node": ">=24 <25"
    }
}
