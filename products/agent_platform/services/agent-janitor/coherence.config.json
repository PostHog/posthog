{
    "outputDir": ".coherence-out",
    "entryDir": "src",
    "ignore": ["node_modules", "dist", ".coherence-out"],
    "codeExt": ["ts"],
    "typecheck": ["npx", "tsc", "--noEmit", "-p", "."],
    "test": ["npx", "vitest", "run", "-t"],
