{
    "name": "@posthog/agent-ingress",
    "version": "0.1.0",
    "private": true,
    "description": "Greenfield ingress for the agent platform. HTTP triggers (slack, webhook, chat) + per-agent MCP transport.",
    "license": "MIT",
    "author": "PostHog <hey@posthog.com>",
    "type": "module",
    "main": "./src/lib.ts",
    "types": "./src/lib.ts",
    "exports": {
        ".": "./src/lib.ts",
        "./bin": "./src/index.ts"
    },
    "scripts": {
        "lint": "oxlint --quiet .",
        "format": "oxfmt .",
        "format:check": "oxfmt --check .",
        "typescript:check": "tsc --noEmit -p .",
        "test": "vitest run",
        "start": "tsx src/index.ts",
        "start:dev": "tsx watch src/index.ts"
    },
    "dependencies": {
        "@posthog/agent-shared": "workspace:*",
        "express": "^4.21.1",
        "jose": "^6.2.3",
        "pg": "^8.6.0",
        "tsx": "^4.7.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "catalog:",
        "@types/pg": "^8.6.0",
        "@types/supertest": "^6.0.2",
        "supertest": "^7.0.0",
        "typescript": "catalog:",
        "vitest": "^4.1.0"
    },
    "engines": {
        "node": ">=24 <25"
    }
}
