# Copy to .env.local and fill in. None of these are required for `pnpm dev`
# — `src/lib/config.ts` supplies deterministic dev defaults via zod.
# Override here only when you need a non-default value (e.g. pointing at
# a non-local Django, or a real cookie sealer when testing prod behavior).

# Where PostHog Django is running. Dev default = http://localhost:8010.
# POSTHOG_BASE_URL=http://localhost:8010

# Where agent-ingress is running. Dev default = http://localhost:3030
# (matches agent-ingress's default PORT). The playground dock hits this
# to start + stream chat sessions.
# POSTHOG_AGENTS_BASE=http://localhost:3030

# Public URL the browser hits the console at. Dev default = http://localhost:3040.
# Used to build the OAuth redirect URI.
# CONSOLE_BASE_URL=http://localhost:3040

# OAuth client provisioned by `pnpm setup:local`, which wraps:
#   python manage.py setup_oauth_for_agent_console
# The client_id is deterministic (`agent-console-dev`); the secret is
# random per provisioning and lives in Django's DB.
POSTHOG_OAUTH_CLIENT_ID=
POSTHOG_OAUTH_CLIENT_SECRET=

# 32+ char string used to seal the HTTP-only session cookie. Dev
# defaults to a deterministic local key so sessions survive `next dev`
# restarts. Required in prod — set it explicitly.
#   openssl rand -hex 32
# OAUTH_COOKIE_SECRET=
