{
    "outputDir": ".coherence-out",
    "entryDir": "logic",
    "ignore": ["migrations", "__pycache__", ".coherence-out"],
    "codeExt": ["py"],
    "typecheck": ["uv", "run", "--no-sync", "ty", "check", "logic"],
    "test": ["env", "DJANGO_SETTINGS_MODULE=posthog.settings", "python", "-m", "pytest", "-q", "-k"],
    "testMatch": "[1-9][0-9]* passed",
    "language": "python"
}
