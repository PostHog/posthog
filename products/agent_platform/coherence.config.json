{
    "outputDir": "docs/coherence",
    "entryDir": ".",
    "tooling": [],
    "ignore": ["node_modules", ".git", "dist", "__pycache__", "backend", "frontend/generated", "docs/coherence"],
    "codeExt": ["ts"],
    "typecheck": ["pnpm", "--filter=@posthog/agent-tests", "typescript:check"],
    "test": ["pnpm", "--filter=@posthog/agent-tests", "test", "--"],
    "testMatch": "Tests\\s+\\d+\\s+passed",
    "language": "typescript"
}
