{
    "name": "@posthog/ml-mirror-image-scrub-sidecar",
    "version": "0.0.0",
    "private": true,
    "description": "replay_vision image-scrub sidecar: an HTTP service that turns raw session-replay image bytes into scrubbed bytes using the native ML scrub (NSFW gate + solid-fill of detected faces, text, and QR/barcodes). The plugin-server consumer owns Kafka + S3 and calls this over loopback. Standalone package (not in pnpm-workspace.yaml) so its ML deps (onnxruntime + models) never reach the root lockfile or the plugin-server image.",
    "type": "module",
    "scripts": {
        "start": "tsx src/main.ts",
        "test:unit": "jest --forceExit",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint -c .oxlintrc.json",
        "format": "oxfmt -c .oxfmtrc.json",
        "format:check": "oxfmt -c .oxfmtrc.json --check",
        "setup": "tsx dev/setup.ts",
        "corpus": "tsx dev/make-corpus.ts",
        "bench": "tsx dev/bench.ts",
        "scale": "tsx dev/scale.ts",
        "verify": "tsx dev/verify.ts",
        "eval": "tsx dev/scrub-eval.ts",
        "smoke": "tsx src/smoke.ts"
    },
    "dependencies": {
        "express": "^4.21.1",
        "onnxruntime-node": "^1.27.0",
        "prom-client": "^15.1.3",
        "sharp": "^0.34.5",
        "tsx": "^4.19.2",
        "zxing-wasm": "^2.2.0"
    },
    "devDependencies": {
        "@babel/core": "^7.26.0",
        "@babel/preset-env": "^7.26.0",
        "@babel/preset-typescript": "^7.26.0",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.14",
        "@types/node": "^24.0.0",
        "babel-jest": "^29.7.0",
        "jest": "^29.7.0",
        "oxfmt": "^0.35.0",
        "oxlint": "^1.72.0",
        "tesseract.js": "^6.0.1",
        "typescript": "^5.7.2"
    },
    "packageManager": "pnpm@10.29.3",
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "onnxruntime-node",
            "sharp"
        ]
    }
}
