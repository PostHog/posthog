#!/usr/bin/env bash

set -euo pipefail

usage() {
    cat >&2 <<'EOF'
usage: bash .codex/with-flox <mode> [command] [args...]

modes:
  prepare              provision the worktree and cache its Flox environment
  run <command>        run with the cached environment and .env settings
  deps <command>       update dependencies inside the required dev sandbox
  stack <command>      run a local-stack command with Docker and loopback access
  mcp <command>        run an MCP server inside the required dev sandbox
EOF
}

mode="${1:-}"
if [[ -z "$mode" ]]; then
    usage
    exit 2
fi
shift

case "$mode" in
    prepare)
        if (($# > 0)); then
            usage
            exit 2
        fi
        ;;
    deps | mcp | run | stack)
        if (($# == 0)); then
            usage
            exit 2
        fi
        ;;
    *)
        usage
        exit 2
        ;;
esac

caller_cwd="$PWD"
repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
environment_file="$repo_root/.codex/.cache/environment"

if [[ -n "${CODEX_SANDBOX:-}" ]]; then
    case "$mode" in
        deps)
            echo "error: dependency changes require elevated execution so bin/dev-sandbox can protect credentials" >&2
            exit 77
            ;;
        prepare)
            echo "error: Codex environment setup requires elevated execution for Flox network access" >&2
            exit 77
            ;;
        stack)
            echo "error: local-stack commands require elevated execution for loopback and Docker access" >&2
            exit 77
            ;;
    esac
fi

fingerprint_inputs=(
    "$repo_root/.codex/run-with-dotenv.py"
    "$repo_root/.codex/with-flox"
    "$repo_root/.flox/env/manifest.toml"
    "$repo_root/.flox/env/on-activate.sh"
    "$repo_root/bin/dev-sandbox"
    "$repo_root/bin/dev-sandbox.sb"
    "$repo_root/pnpm-lock.yaml"
    "$repo_root/uv.lock"
)
while IFS= read -r path; do
    fingerprint_inputs+=("$path")
done < <(find "$repo_root/tools/phrocs" -type f \( -name '*.go' -o -name 'go.mod' -o -name 'go.sum' -o -name 'Makefile' \) -print | sort)

toolchain_variables=(
    ACLOCAL_PATH
    AGENT_PREVIEW_SECRET
    BUILDENV_NIX
    CLICKHOUSE_DATABASE
    CMAKE_PREFIX_PATH
    CPATH
    CPPFLAGS
    DEBUG
    DIRENV_LOG_FORMAT
    DYLD_FALLBACK_LIBRARY_PATH
    FLOX_ACTIVATE_START_SERVICES
    FLOX_CONFIG_DIR
    FLOX_ENV
    FLOX_ENV_CACHE
    FLOX_ENV_DESCRIPTION
    FLOX_ENV_DIRS
    FLOX_ENV_PROJECT
    FLOX_PROMPT_COLOR_1
    FLOX_PROMPT_COLOR_2
    FLOX_PROMPT_ENVIRONMENTS
    FLOX_SENTRY_DSN
    FLOX_SENTRY_ENV
    FLAGS_REDIS_URL
    GOCACHE
    GOMODCACHE
    GOPATH
    GOTOOLCHAIN
    INFOPATH
    LDFLAGS
    LIBRARY_PATH
    LOCAL_POSTHOG_CODE_MONOREPO_ROOT
    MANPATH
    NIX_BIN
    NIX_PLUGINS
    NIX_SSL_CERT_FILE
    OPENSSL_INCLUDE_DIR
    OPENSSL_LIB_DIR
    OPENSSL_ROOT_DIR
    PATH
    PATH_LOCALE
    PKG_CONFIG_PATH
    POSTHOG_SKIP_MIGRATION_CHECKS
    PROCESS_COMPOSE_BIN
    RUSTC_WRAPPER
    RUST_LOG
    RUST_SRC_PATH
    SSL_CERT_FILE
    UV_PROJECT_ENVIRONMENT
    VIRTUAL_ENV
    XDG_DATA_DIRS
)

environment_fingerprint() {
    cksum "${fingerprint_inputs[@]}" | cksum
}

find_flox() {
    local candidate found
    found="$(command -v flox || true)"
    if [[ -z "$found" ]]; then
        for candidate in /usr/local/bin/flox /opt/homebrew/bin/flox "$HOME/.local/bin/flox"; do
            if [[ -x "$candidate" ]]; then
                found="$candidate"
                break
            fi
        done
    fi
    printf '%s' "$found"
}

load_cached_environment() {
    if [[ ! -f "$environment_file" ]]; then
        echo "error: Codex environment is not prepared; run 'bash $repo_root/.codex/with-flox prepare'" >&2
        exit 1
    fi

    runtime_environment=(env -i)
    protected_environment_names=()
    local allowed allowed_name assignment name
    local cached_cache="" cached_fingerprint="" cached_project="" cached_venv="" cached_variables=0

    while IFS= read -r -d '' assignment; do
        name="${assignment%%=*}"
        if [[ "$name" == "CODEX_ENV_FINGERPRINT" ]]; then
            cached_fingerprint="${assignment#*=}"
            continue
        fi

        allowed=0
        for allowed_name in "${toolchain_variables[@]}"; do
            if [[ "$name" == "$allowed_name" ]]; then
                allowed=1
                break
            fi
        done
        if [[ "$allowed" -ne 1 ]]; then
            echo "error: Codex environment contains an unexpected variable; rerun setup" >&2
            exit 1
        fi

        case "$name" in
            FLOX_ENV_CACHE) cached_cache="${assignment#*=}" ;;
            FLOX_ENV_PROJECT) cached_project="${assignment#*=}" ;;
            VIRTUAL_ENV) cached_venv="${assignment#*=}" ;;
        esac
        runtime_environment+=("$assignment")
        protected_environment_names+=("$name")
        cached_variables=$((cached_variables + 1))
    done < "$environment_file"

    if [[ "$cached_variables" -eq 0 || "$cached_fingerprint" != "$(environment_fingerprint)" ]]; then
        echo "error: Codex environment is stale; run 'bash $repo_root/.codex/with-flox prepare'" >&2
        exit 1
    fi
    if [[ "$cached_project" != "$repo_root" || "$cached_cache" != "$repo_root/.flox/cache" || "$cached_venv" != "$repo_root/.flox/cache/venv" ]]; then
        echo "error: Codex environment belongs to another worktree; rerun setup" >&2
        exit 1
    fi

    runtime_environment+=("CARGO_TARGET_DIR=$repo_root/.flox/cache/cargo-target")
    runtime_environment+=("HOME=$HOME")
    runtime_environment+=("LANG=${LANG:-C.UTF-8}")
    runtime_environment+=("LOGNAME=${LOGNAME:-}")
    runtime_environment+=("POSTHOG_CODE=1")
    runtime_environment+=("PYTEST_ADDOPTS=${PYTEST_ADDOPTS:--p no:xdist}")
    runtime_environment+=("SCCACHE_DIR=$repo_root/.flox/cache/sccache")
    runtime_environment+=("SHELL=${SHELL:-/bin/bash}")
    runtime_environment+=("TMPDIR=${TMPDIR:-/tmp}")
    runtime_environment+=("USER=${USER:-}")
    protected_environment_names+=(CARGO_TARGET_DIR HOME LANG LOGNAME POSTHOG_CODE PYTEST_ADDOPTS SCCACHE_DIR SHELL TMPDIR USER)
    if [[ -n "${CODEX_SANDBOX:-}" ]]; then
        runtime_environment+=("CODEX_SANDBOX=$CODEX_SANDBOX")
        protected_environment_names+=(CODEX_SANDBOX)
    fi
    if [[ -n "${CODEX_SANDBOX_NETWORK_DISABLED:-}" ]]; then
        runtime_environment+=("CODEX_SANDBOX_NETWORK_DISABLED=$CODEX_SANDBOX_NETWORK_DISABLED")
        protected_environment_names+=(CODEX_SANDBOX_NETWORK_DISABLED)
    fi
    if [[ -n "${TERM:-}" ]]; then
        runtime_environment+=("TERM=$TERM")
        protected_environment_names+=(TERM)
    fi
}

run_cached() {
    local protected_names

    load_cached_environment
    if [[ "$mode" == "stack" ]]; then
        runtime_environment+=("COMPOSE_PROJECT_NAME=posthog")
        protected_environment_names+=(COMPOSE_PROJECT_NAME)
    fi
    protected_names="$(IFS=:; printf '%s' "${protected_environment_names[*]}")"
    runtime_environment+=("CODEX_PROTECTED_ENV_NAMES=$protected_names")
    cd "$caller_cwd"

    if [[ -f "$repo_root/.env" ]]; then
        exec "${runtime_environment[@]}" \
            "$repo_root/.flox/cache/venv/bin/python" \
            "$repo_root/.codex/run-with-dotenv.py" "$repo_root/.env" -- "$@"
    fi
    exec "${runtime_environment[@]}" "$@"
}

run_sandboxed_cached() {
    local command_string

    load_cached_environment
    printf -v command_string '%q ' "$@"
    cd "$caller_cwd"
    if [[ "$mode" == "mcp" ]]; then
        exec "${runtime_environment[@]}" "$repo_root/bin/dev-sandbox" --require "$command_string"
    fi
    "${runtime_environment[@]}" "$repo_root/bin/dev-sandbox" --require "$command_string"
}

refresh_environment_fingerprint() {
    local assignment cache_tmp name
    umask 077
    cache_tmp="$(mktemp "$environment_file.XXXXXX")"
    cleanup_environment_tmp() { rm -f "$cache_tmp"; }
    trap cleanup_environment_tmp EXIT

    printf 'CODEX_ENV_FINGERPRINT=%s\0' "$(environment_fingerprint)" > "$cache_tmp"
    while IFS= read -r -d '' assignment; do
        name="${assignment%%=*}"
        if [[ "$name" != "CODEX_ENV_FINGERPRINT" ]]; then
            printf '%s\0' "$assignment" >> "$cache_tmp"
        fi
    done < "$environment_file"
    mv "$cache_tmp" "$environment_file"
    trap - EXIT
}

prepare_environment() {
    local flox_bin
    flox_bin="$(find_flox)"
    if [[ -z "$flox_bin" ]]; then
        echo "error: Flox is required to provision the PostHog development environment" >&2
        exit 127
    fi

    mkdir -p "${environment_file%/*}"
    cd "$repo_root"

    # A minimal parent environment prevents another checkout's activation state
    # and ambient credentials from entering the cached toolchain environment.
    # shellcheck disable=SC2016
    exec env -i \
        FLOX_CONFIG_DIR="$repo_root/.flox/cache/flox-config" \
        FLOX_DISABLE_METRICS=true \
        HOME="$HOME" \
        LANG="${LANG:-C.UTF-8}" \
        LOGNAME="${LOGNAME:-}" \
        PATH="/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:$HOME/.local/bin" \
        POSTHOG_CODE=1 \
        POSTHOG_DEV_SANDBOX_REQUIRED=1 \
        POSTHOG_SKIP_DOTENV=1 \
        SHELL="${SHELL:-/bin/bash}" \
        TMPDIR="${TMPDIR:-/tmp}" \
        USER="${USER:-}" \
        "$flox_bin" activate --dir "$repo_root" -- bash -c '
            set -euo pipefail
            cache_file="$1"
            fingerprint="$2"
            variable_names="$3"
            shift 3

            export VIRTUAL_ENV="$FLOX_ENV_CACHE/venv"
            export UV_PROJECT_ENVIRONMENT="$VIRTUAL_ENV"
            export PATH="$VIRTUAL_ENV/bin:$PATH"

            umask 077
            cache_tmp="$(mktemp "$cache_file.XXXXXX")"
            cleanup_cache_tmp() { rm -f "$cache_tmp"; }
            trap cleanup_cache_tmp EXIT

            printf "CODEX_ENV_FINGERPRINT=%s\0" "$fingerprint" > "$cache_tmp"
            while IFS= read -r name; do
                if [[ -n "$name" ]] && declare -p "$name" >/dev/null 2>&1; then
                    printf "%s=%s\0" "$name" "${!name}" >> "$cache_tmp"
                fi
            done <<< "$variable_names"
            mv "$cache_tmp" "$cache_file"
            trap - EXIT
            exec "$@"
        ' bash "$environment_file" "$(environment_fingerprint)" "$(printf '%s\n' "${toolchain_variables[@]}")" true
}

case "$mode" in
    prepare)
        prepare_environment
        ;;
    run | stack)
        run_cached "$@"
        ;;
    deps)
        run_sandboxed_cached "$@"
        refresh_environment_fingerprint
        ;;
    mcp)
        run_sandboxed_cached "$@"
        ;;
esac
