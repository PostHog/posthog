#!/usr/bin/env bash

set -euo pipefail

prepare=0
if [[ "${1:-}" == "--prepare" ]]; then
    prepare=1
    shift
fi

if (($# == 0)); then
    echo "usage: bash .codex/with-flox [--prepare] <command> [args...]" >&2
    exit 2
fi

caller_cwd="$PWD"
repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
env_file="$repo_root/.flox/cache/codex-env"
fingerprint_file="$env_file.fingerprint"
fingerprint_inputs=(
    "$repo_root/.flox/env/manifest.toml"
    "$repo_root/.flox/env/on-activate.sh"
    "$repo_root/pnpm-lock.yaml"
    "$repo_root/uv.lock"
)

environment_fingerprint() {
    cksum "${fingerprint_inputs[@]}" | cksum
}

cd "$repo_root"

if [[ "$prepare" -eq 0 ]]; then
    if [[ ! -f "$env_file" || ! -f "$fingerprint_file" ]]; then
        echo "error: Codex environment is not prepared; run 'bash .codex/with-flox --prepare true'" >&2
        exit 1
    fi

    if [[ "$(<"$fingerprint_file")" != "$(environment_fingerprint)" ]]; then
        echo "error: Codex environment is stale; run 'bash .codex/with-flox --prepare true'" >&2
        exit 1
    fi

    runtime_env=(env -i)
    [[ -n "${CODEX_SANDBOX:-}" ]] && runtime_env+=("CODEX_SANDBOX=$CODEX_SANDBOX")
    [[ -n "${CODEX_SANDBOX_NETWORK_DISABLED:-}" ]] && runtime_env+=("CODEX_SANDBOX_NETWORK_DISABLED=$CODEX_SANDBOX_NETWORK_DISABLED")
    runtime_env+=("PYTEST_ADDOPTS=${PYTEST_ADDOPTS:--p no:xdist}")
    [[ -n "${TERM:-}" ]] && runtime_env+=("TERM=$TERM")

    # Start from the prepared toolchain environment, then load current local
    # application settings without persisting them in the cache.
    # shellcheck disable=SC2016
    exec "${runtime_env[@]}" "$BASH" -c '
        set -euo pipefail
        env_file="$1"
        repo_root="$2"
        caller_cwd="$3"
        shift 3
        # shellcheck disable=SC1090
        source "$env_file"
        cd "$repo_root"
        dotenv_file="${DOTENV_FILE:-}"
        if [[ -n "$dotenv_file" && "$dotenv_file" != /* ]]; then
            dotenv_file="$repo_root/$dotenv_file"
        fi
        if [[ -n "$dotenv_file" && -f "$dotenv_file" ]]; then
            set -o allexport
            # shellcheck disable=SC1090
            source "$dotenv_file"
            set +o allexport
        fi
        cd "$caller_cwd"

        if [[ "$(uname -s)" == "Darwin" && -f "$repo_root/bin/dev-sandbox-shims" ]]; then
            # shellcheck disable=SC1090
            source "$repo_root/bin/dev-sandbox-shims"
            should_sandbox=0
            _ph_sandbox_should_wrap "$@" && should_sandbox=1
            unset -f uv pnpm _ph_sandbox_run _ph_sandbox_should_wrap 2>/dev/null || true
            if [[ "$should_sandbox" -eq 1 ]]; then
                if [[ -n "${CODEX_SANDBOX:-}" ]]; then
                    echo "error: dependency changes require elevated execution so bin/dev-sandbox can protect credentials" >&2
                    exit 77
                fi
                exec "$repo_root/bin/dev-sandbox" "$(printf "%q " "$@")"
            fi
        fi

        exec "$@"
    ' bash "$env_file" "$repo_root" "$caller_cwd" "$@"
fi

flox_bin="$(command -v flox || true)"

if [[ -z "$flox_bin" ]]; then
    for candidate in /usr/local/bin/flox /opt/homebrew/bin/flox "$HOME/.local/bin/flox"; do
        if [[ -x "$candidate" ]]; then
            flox_bin="$candidate"
            break
        fi
    done
fi

if [[ -z "$flox_bin" ]]; then
    echo "error: Flox is required to provision the PostHog development environment" >&2
    exit 127
fi

# Provision from a minimal environment so the cached file cannot capture ambient
# credentials or another checkout's activation state.
# shellcheck disable=SC2016
exec env -i \
    HOME="$HOME" \
    LANG="${LANG:-C.UTF-8}" \
    LOGNAME="${LOGNAME:-}" \
    PATH="/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:$HOME/.local/bin" \
    SHELL="${SHELL:-/bin/bash}" \
    TMPDIR="${TMPDIR:-/tmp}" \
    USER="${USER:-}" \
    "$flox_bin" activate --dir "$repo_root" -- bash -c '
        set -euo pipefail
        prepare="$1"
        fingerprint="$2"
        shift 2
        export VIRTUAL_ENV="$FLOX_ENV_CACHE/venv"
        export UV_PROJECT_ENVIRONMENT="$VIRTUAL_ENV"
        export PATH="$VIRTUAL_ENV/bin:$PATH"
        if [[ "$prepare" -eq 1 ]]; then
            umask 077
            if [[ -n "${DOTENV_FILE:-}" && -f "$DOTENV_FILE" ]]; then
                while IFS= read -r name; do
                    unset "$name"
                done < <(sed -nE "s/^[[:space:]]*(export[[:space:]]+)?([A-Za-z_][A-Za-z0-9_]*)=.*/\\2/p" "$DOTENV_FILE")
            fi
            export -p > "$FLOX_ENV_CACHE/codex-env.tmp"
            printf "%s\n" "$fingerprint" > "$FLOX_ENV_CACHE/codex-env.fingerprint.tmp"
            mv "$FLOX_ENV_CACHE/codex-env.tmp" "$FLOX_ENV_CACHE/codex-env"
            mv "$FLOX_ENV_CACHE/codex-env.fingerprint.tmp" "$FLOX_ENV_CACHE/codex-env.fingerprint"
        fi
        exec "$@"
    ' bash "$prepare" "$(environment_fingerprint)" "$@"
