#!/usr/bin/env bash

set -euo pipefail

if (($# == 0)); then
    echo "usage: bash .codex/with-flox <command> [args...]" >&2
    exit 2
fi

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
flox_bin="$(command -v flox || true)"

if [[ -z "$flox_bin" ]]; then
    for candidate in /usr/local/bin/flox /opt/homebrew/bin/flox "$HOME/.local/bin/flox"; do
        if [[ -x "$candidate" ]]; then
            flox_bin="$candidate"
            break
        fi
    done
fi

if [[ -z "$flox_bin" ]]; then
    echo "error: Flox is required to provision the PostHog development environment" >&2
    exit 127
fi

cd "$repo_root"

# Codex worktrees inherit the source checkout's process environment. Clear
# its activation markers before selecting this worktree's Flox environment.
# The inner Bash expands Flox's environment.
# shellcheck disable=SC2016
exec env \
    -u CONDA_DEFAULT_ENV \
    -u DIRENV_DIFF \
    -u DIRENV_DIR \
    -u DIRENV_WATCHES \
    -u FLOX_ACTIVATE_START_SERVICES \
    -u FLOX_ENV \
    -u FLOX_ENV_CACHE \
    -u FLOX_ENV_DESCRIPTION \
    -u FLOX_ENV_DIRS \
    -u FLOX_ENV_PROJECT \
    -u PYTHONPATH \
    -u UV_PROJECT_ENVIRONMENT \
    -u VIRTUAL_ENV \
    -u VIRTUAL_ENV_DISABLE_PROMPT \
    -u VIRTUAL_ENV_PROMPT \
    -u _FLOX_ACTIVE_ENVIRONMENTS \
    -u _FLOX_HOOK_DIFF \
    -u _FLOX_INVOCATION_TYPE \
    "$flox_bin" activate --dir "$repo_root" -- bash -c '
        export VIRTUAL_ENV="$FLOX_ENV_CACHE/venv"
        export UV_PROJECT_ENVIRONMENT="$VIRTUAL_ENV"
        export PATH="$VIRTUAL_ENV/bin:$PATH"
        exec "$@"
    ' bash "$@"
