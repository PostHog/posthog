     HAVING and(equals(argMax(person.is_deleted, person.version), 0), less(argMax(toTimeZone(person.created_at, 'UTC'), person.version), plus(now64(6, 'UTC'), toIntervalDay(1))))) AS persons
  WHERE ifNull(ilike(toString(persons.properties___test_prop), '%5%'), 0)
  LIMIT 50000
  '''
# ---
# name: TestPersonPropertySkipIndexes.test_mat_col_nullable_ngrambf_lower_0_icontains_long
  '''
  SELECT count() AS `count()`
  FROM
    (SELECT tupleElement(argMax(tuple(person.pmat_test_prop), person.version), 1) AS properties___test_prop,
            person.id AS id
     FROM person
     WHERE and(equals(person.team_id, 99999), in(id,
                                                   (SELECT where_optimization.id AS id
                                                    FROM person AS where_optimization
                                                    WHERE and(equals(where_optimization.team_id, 99999), and(like(lower(coalesce(where_optimization.pmat_test_prop, '')), lower('%value_that_is_long_enough%')), isNotNull(where_optimization.pmat_test_prop))))))
     GROUP BY person.id
     HAVING and(equals(argMax(person.is_deleted, person.version), 0), less(argMax(toTimeZone(person.created_at, 'UTC'), person.version), plus(now64(6, 'UTC'), toIntervalDay(1))))) AS persons
  WHERE ifNull(ilike(toString(persons.properties___test_prop), '%value_that_is_long_enough%'), 0)
  LIMIT 50000
  '''
# ---
# name: TestPersonPropertySkipIndexes.test_mat_col_nullable_ngrambf_lower_1_eq
  '''
  SELECT count() AS `count()`
  FROM
    (SELECT tupleElement(argMax(tuple(person.pmat_test_prop), person.version), 1) AS properties___test_prop,
            person.id AS id
     FROM person
     WHERE and(equals(person.team_id, 99999), in(id,
                                                   (SELECT where_optimization.id AS id
                                                    FROM person AS where_optimization
                                                    WHERE and(equals(where_optimization.team_id, 99999), and(equals(where_optimization.pmat_test_prop, '5'), isNotNull(where_optimization.pmat_test_prop))))))
     GROUP BY person.id
     HAVING and(equals(argMax(person.is_deleted, person.version), 0), less(argMax(toTimeZone(person.created_at, 'UTC'), person.version), plus(now64(6, 'UTC'), toIntervalDay(1))))) AS persons
  WHERE ifNull(equals(persons.properties___test_prop, '5'), 0)
  LIMIT 50000
  '''
