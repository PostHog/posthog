# name: TestTrafficTypeSnapshot.test_get_bot_type
  '''
  -- ClickHouse
  
  SELECT
      multiIf(match(replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(events.properties, %(hogql_val_0)s), ''), 'null'), '^"|"$', ''), %(hogql_val_1)s), %(hogql_val_2)s, match(replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(events.properties, %(hogql_val_3)s), ''), 'null'), '^"|"$', ''), %(hogql_val_4)s), %(hogql_val_5)s, match(replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(events.properties, %(hogql_val_6)s), ''), 'null'), '^"|"$', ''), %(hogql_val_7)s), %(hogql_val_8)s, match(replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(events.properties, %(hogql_val_9)s), ''), 'null'), '^"|"$', ''), %(hogql_val_10)s), %(hogql_val_11)s, match(replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(events.properties, %(hogql_val_12)s), ''), 'null'), '^"|"$', ''), %(hogql_val_13)s), %(hogql_val_14)s, match(replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(events.properties, %(hogql_val_15)s), ''), 'null'), '^"|"$', ''), %(hogql_val_16)s), %(hogql_val_17)s, match(replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(events.properties, %(hogql_val_18)s), ''), 'null'), '^"|"$', ''), %(hogql_val_19)s), %(hogql_val_20)s, match(replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(events.properties, %(hogql_val_21)s), ''), 'null'), '^"|"$', ''), %(hogql_val_22)s), %(hogql_val_23)s, %(hogql_val_24)s) AS bot_type,
      count() AS count
  
  FROM
      events
  
  WHERE
      and(equals(events.team_id, 99999), equals(events.event, %(hogql_val_25)s))
  
  GROUP BY
      bot_type
  ORDER BY
      bot_type ASC
  
  LIMIT 100 
  SETTINGS readonly=2, max_execution_time=60, allow_experimental_object_type=1, format_csv_allow_double_quotes=0, max_ast_elements=4000000, max_expanded_ast_elements=4000000, max_bytes_before_external_group_by=0, transform_null_in=1, optimize_min_equality_disjunction_chain_length=4294967295, allow_experimental_join_condition=1, use_hive_partitioning=0
  
  -- HogQL
  
  SELECT
      multiIf(match(properties.$raw_user_agent, 'GPTBot|ChatGPT-User|Claude|anthropic-ai|PerplexityBot|Google-Extended|CCBot|Applebot-Extended|cohere-ai|meta-externalagent|Bytespider'), 'llm_crawler', match(properties.$raw_user_agent, 'Googlebot|Bingbot|Yandex|Baiduspider|DuckDuckBot|Slurp'), 'search_crawler', match(properties.$raw_user_agent, 'AhrefsBot|SemrushBot|MJ12bot|DotBot|PetalBot'), 'seo_crawler', match(properties.$raw_user_agent, 'facebookexternalhit|Twitterbot|LinkedInBot|Pinterest|Slackbot|TelegramBot|WhatsApp'), 'social_crawler', match(properties.$raw_user_agent, 'Pingdom|UptimeRobot|Site24x7|StatusCake|Datadog'), 'monitoring', match(properties.$raw_user_agent, 'curl/|wget/|python-requests/|axios/|node-fetch/|Go-http-client/|Java/|okhttp/|Apache-HttpClient|libwww-perl|Scrapy'), 'http_client', match(properties.$raw_user_agent, 'PhantomJS|HeadlessChrome|Puppeteer|Playwright|Selenium'), 'headless_browser', match(properties.$raw_user_agent, '^$'), 'no_user_agent', '') AS bot_type,
      count() AS count
  
  FROM
      events
  
  WHERE
      equals(event, '$pageview')
  
  GROUP BY
      bot_type
  ORDER BY
      bot_type ASC
  
  LIMIT 100
  '''
