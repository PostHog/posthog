{
    "_comment": "Single source of truth for dmat coercion parity. Both the Python-side ClickHouse extraction tests (legacy per-slot AND batched paths) and the TypeScript-side plugin-server tests load this file and assert their respective code path produces `expected_output` for `input`. Used by `test_coercion_parity.py` and `create-event.dmat.test.ts`.",
    "string_cases": [
        { "name": "plain ascii string", "input": "Chrome", "expected_output": "Chrome" },
        { "name": "empty string", "input": "", "expected_output": "" },
        { "name": "whitespace string", "input": "   ", "expected_output": "   " },
        { "name": "string with internal escaped quotes", "input": "a \"b\" c", "expected_output": "a \\\"b\\\" c" },
        { "name": "string of digits", "input": "123", "expected_output": "123" },
        { "name": "the literal string 'null'", "input": "null", "expected_output": "null" },
        { "name": "JSON object", "input": { "a": 1 }, "expected_output": "{\"a\":1}" },
        { "name": "JSON array of numbers", "input": [1, 2, 3], "expected_output": "[1,2,3]" },
        { "name": "JSON array of strings", "input": ["a", "b"], "expected_output": "[\"a\",\"b\"]" },
        { "name": "number type (integer)", "input": 42, "expected_output": "42" },
        { "name": "number type (float)", "input": 3.14, "expected_output": "3.14" },
        { "name": "boolean true", "input": true, "expected_output": "true" },
        { "name": "boolean false", "input": false, "expected_output": "false" }
    ],
    "numeric_cases": [
        { "name": "integer", "input": 42, "expected_output": 42 },
        { "name": "float", "input": 42.5, "expected_output": 42.5 },
        { "name": "negative", "input": -100, "expected_output": -100 },
        { "name": "zero", "input": 0, "expected_output": 0 },
        { "name": "string of digits", "input": "42", "expected_output": 42 },
        { "name": "string of digits with whitespace", "input": "  42  ", "expected_output": 42 },
        { "name": "string that is not a number", "input": "not a number", "expected_output": null },
        {
            "name": "boolean true",
            "input": true,
            "_skip_reason": "ClickHouse toFloat64OrNull('true') == NULL but JS parseFloat('true') == NaN — both NULL, agreement is incidental",
            "expected_output": null
        },
        { "name": "object", "input": { "a": 1 }, "expected_output": null },
        { "name": "array", "input": [1, 2, 3], "expected_output": null }
    ],
    "boolean_cases": [
        { "name": "boolean true", "input": true, "expected_output": 1 },
        { "name": "boolean false", "input": false, "expected_output": 0 },
        { "name": "string 'true'", "input": "true", "expected_output": 1 },
        { "name": "string 'false'", "input": "false", "expected_output": 0 },
        {
            "name": "uppercase string 'TRUE' rejected (SQL transform is case-sensitive)",
            "input": "TRUE",
            "expected_output": null
        },
        { "name": "mixed case string 'True' rejected", "input": "True", "expected_output": null },
        { "name": "string '1' rejected", "input": "1", "expected_output": null },
        { "name": "string '0' rejected", "input": "0", "expected_output": null },
        { "name": "number 1 rejected", "input": 1, "expected_output": null },
        { "name": "number 0 rejected", "input": 0, "expected_output": null },
        { "name": "string 'yes' rejected", "input": "yes", "expected_output": null }
    ],
    "datetime_cases": [
        { "name": "ISO 8601 with Z", "input": "2024-01-15T10:30:00Z", "expected_output": "2024-01-15 10:30:00.000000" },
        {
            "name": "ISO 8601 with offset",
            "input": "2024-01-15T10:30:00+00:00",
            "expected_output": "2024-01-15 10:30:00.000000"
        },
        { "name": "date only", "input": "2024-01-15", "expected_output": "2024-01-15 00:00:00.000000" },
        {
            "name": "SQL-format datetime",
            "input": "2024-01-15 10:30:00",
            "expected_output": "2024-01-15 10:30:00.000000"
        },
        { "name": "garbage string", "input": "not a date", "expected_output": null },
        {
            "name": "_skip US-style M/D/Y",
            "_skip_reason": "Ambiguous format — ClickHouse's best-effort parser may accept; JS does not. Documented as out-of-spec.",
            "input": "01/15/2024",
            "expected_output": null
        }
    ]
}
