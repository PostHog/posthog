{
    "_comment": "Single source of truth for dmat coercion parity. Both the Python-side ClickHouse extraction tests and the TypeScript-side plugin-server tests load this file and assert their respective code path produces `expected_output` for `input`. Per the dmat RFC, every dmat column is `Nullable(String)` — HogQL applies type wrappers (toFloat/toBool/toDateTime) at read time the same way it does for normal mat_* columns. So this fixture only covers the string extraction; type-cast parity is covered at the HogQL layer in test_property_types_dmat.py.",
    "string_cases": [
        { "name": "plain ascii string", "input": "Chrome", "expected_output": "Chrome" },
        { "name": "empty string", "input": "", "expected_output": "" },
        { "name": "whitespace string", "input": "   ", "expected_output": "   " },
        { "name": "string with internal escaped quotes", "input": "a \"b\" c", "expected_output": "a \\\"b\\\" c" },
        { "name": "string of digits", "input": "123", "expected_output": "123" },
        { "name": "the literal string 'null'", "input": "null", "expected_output": "null" },
        { "name": "JSON object", "input": { "a": 1 }, "expected_output": "{\"a\":1}" },
        { "name": "JSON array of numbers", "input": [1, 2, 3], "expected_output": "[1,2,3]" },
        { "name": "JSON array of strings", "input": ["a", "b"], "expected_output": "[\"a\",\"b\"]" },
        { "name": "number type (integer)", "input": 42, "expected_output": "42" },
        { "name": "number type (float)", "input": 3.14, "expected_output": "3.14" },
        { "name": "boolean true", "input": true, "expected_output": "true" },
        { "name": "boolean false", "input": false, "expected_output": "false" },
        { "name": "string wrapped in double quotes", "input": "\"hello\"", "expected_output": "\\\"hello\\\"" }
    ]
}
