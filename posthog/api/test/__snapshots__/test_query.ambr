         if(notEquals(toJSONString(events.properties.^key), '{}'), toJSONString(events.properties.^key), if(isNull(events.properties.key), NULL, if(startsWith(dynamicType(events.properties.key), 'DateTime'), replaceOne(toString(events.properties.key), ' ', 'T'), toString(events.properties.key)))) AS key,
         'a%sd',
         concat(ifNull(toString(events.event), ''), ' ', ifNull(toString(if(notEquals(toJSONString(events.properties.^key), '{}'), toJSONString(events.properties.^key), if(isNull(events.properties.key), NULL, if(startsWith(dynamicType(events.properties.key), 'DateTime'), replaceOne(toString(events.properties.key), ' ', 'T'), toString(events.properties.key))))), '')) AS `concat(event, ' ', if(notEquals(toJSONString(properties.^key), '{}'), toJSONString(properties.^key), if(isNull(properties.key), NULL, if(startsWith(dynamicType(properties.key), 'DateTime'), replaceOne(toString(properties.key), ' ', 'T'), toString(properties.key)))))`
  FROM events_json AS events
  LEFT OUTER JOIN
    (SELECT argMax(person_distinct_id_overrides.person_id, person_distinct_id_overrides.version) AS person_id,
            person_distinct_id_overrides.distinct_id AS distinct_id
     FROM person_distinct_id_overrides
     WHERE equals(person_distinct_id_overrides.team_id, 99999)
     GROUP BY person_distinct_id_overrides.distinct_id
     HAVING equals(argMax(person_distinct_id_overrides.is_deleted, person_distinct_id_overrides.version), 0) SETTINGS optimize_aggregation_in_order=1) AS events__override ON equals(events.distinct_id, events__override.distinct_id)
  LEFT JOIN
    (SELECT person.id AS id,
            replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(person.properties, 'email'), ''), 'null'), '^"|"$', '') AS properties___email
