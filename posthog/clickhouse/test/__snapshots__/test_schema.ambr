# name: test_create_table_query[error_tracking_fingerprint_issue_state]
  '''
  
  CREATE TABLE IF NOT EXISTS error_tracking_fingerprint_issue_state 
  (
      team_id Int64,
      fingerprint VARCHAR,
      issue_id UUID,
