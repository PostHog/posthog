      ai_highlighted UInt8,
      surfacing_score Nullable(Float32),
  ) ENGINE = Kafka(msk_cluster, kafka_topic_list = 'clickhouse_session_replay_events_test', kafka_group_name = 'group1', kafka_format = 'JSONEachRow')
  
