      expires_at DateTime64(6, 'UTC') DEFAULT now() + INTERVAL 7 DAY
  ) ENGINE = Distributed('aux', 'posthog_test', 'sharded_web_overview_preaggregated', sipHash64(job_id))
  
  '''
