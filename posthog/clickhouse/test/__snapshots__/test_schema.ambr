      product LowCardinality(String),
      document_type LowCardinality(String),
      model_name LowCardinality(String),  -- Used for filtering in model-specific MVs
      rendering LowCardinality(String),
      document_id String,
      timestamp DateTime64(3, 'UTC'),
      inserted_at DateTime64(3, 'UTC'),
      content String DEFAULT '',
      metadata String DEFAULT '{}',
      embedding Array(Float64)
      
  , _timestamp DateTime
  , _offset UInt64
  , _partition UInt64
  
  ) ENGINE = Distributed('posthog', 'posthog_test', 'sharded_posthog_document_embeddings_buffer', cityHash64(document_id))
  
  '''
