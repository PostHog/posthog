  , _timestamp DateTime
  , _offset UInt64
  , _partition UInt64
  
  ) ENGINE = ReplicatedReplacingMergeTree('/clickhouse/tables/77f1df52-4b43-11e9-910f-b8ca3a9b9f3e_{shard}/posthog.sharded_posthog_document_embeddings_buffer', '{replica}', inserted_at)
