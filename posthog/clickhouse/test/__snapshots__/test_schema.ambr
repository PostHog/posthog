# name: test_create_table_query[events_json_mv]
  '''
  
  CREATE MATERIALIZED VIEW IF NOT EXISTS events_json_mv ON CLUSTER 'posthog'
  TO posthog_test.writable_events
  AS SELECT
  uuid,
  event,
  properties,
  timestamp,
  team_id,
  distinct_id,
  elements_chain,
  created_at,
  person_id,
  person_created_at,
  person_properties,
  group0_properties,
  group1_properties,
  group2_properties,
  group3_properties,
  group4_properties,
  group0_created_at,
  group1_created_at,
  group2_created_at,
  group3_created_at,
  group4_created_at,
  person_mode,
  historical_migration,
  dmat_string_0,
  dmat_string_1,
  dmat_string_2,
  dmat_string_3,
  dmat_string_4,
  dmat_string_5,
  dmat_string_6,
  dmat_string_7,
  dmat_string_8,
  dmat_string_9,
  _timestamp,
  _offset,
  arrayMap(
      i -> _headers.value[i],
      arrayFilter(
          i -> _headers.name[i] = 'kafka-consumer-breadcrumbs',
          arrayEnumerate(_headers.name)
      )
  ) as consumer_breadcrumbs
  FROM posthog_test.kafka_events_json
  
  '''
