  CREATE MATERIALIZED VIEW IF NOT EXISTS app_metrics2_mv
  TO writable_app_metrics2
  AS SELECT
  team_id,
  timestamp,
  app_source,
  app_source_id,
  instance_id,
  metric_kind,
  metric_name,
  count,
  _timestamp,
  _offset,
  _partition
  FROM kafka_app_metrics2
  
  '''
