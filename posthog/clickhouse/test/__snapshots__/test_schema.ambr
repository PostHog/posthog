      invocation_id,
      action_id,
      kind,
      distinct_id,
      person_id,
      recipient,
      subject,
      status,
      sent_at,
      version,
      is_deleted,
      html,
      _timestamp,
      _offset,
      _partition
  FROM kafka_message_assets
  
  '''
