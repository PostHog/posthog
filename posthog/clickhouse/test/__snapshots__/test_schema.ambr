      computed_at DateTime64(6, 'UTC') DEFAULT now(),
      expires_at Date DEFAULT today() + INTERVAL 7 DAY
  ) ENGINE = ReplicatedReplacingMergeTree('/clickhouse/tables/77f1df52-4b43-11e9-910f-b8ca3a9b9f3e_noshard/posthog.conversion_goal_attributed_preaggregated', '{replica}-{shard}', computed_at)
  
  PARTITION BY toYYYYMMDD(expires_at)
  ORDER BY (team_id, job_id, person_id, conversion_timestamp, touchpoint_timestamp)
  TTL expires_at
