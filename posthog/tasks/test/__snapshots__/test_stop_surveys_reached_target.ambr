# name: TestStopSurveysReachedTarget.test_stop_surveys_with_enough_responses[new_events_schema.1]
  '''
  SELECT events.properties.`$survey_id` AS survey_id,
         count(DISTINCT if(ifNull(notEquals(coalesce(if(notEquals(toJSONString(events.properties.^`$survey_submission_id`), '{}'), toJSONString(events.properties.^`$survey_submission_id`), if(isNull(events.properties.`$survey_submission_id`), NULL, if(startsWith(dynamicType(events.properties.`$survey_submission_id`), 'DateTime'), replaceOne(toString(events.properties.`$survey_submission_id`), ' ', 'T'), if(or(startsWith(dynamicType(events.properties.`$survey_submission_id`), 'Array'), startsWith(dynamicType(events.properties.`$survey_submission_id`), 'Map'), startsWith(dynamicType(events.properties.`$survey_submission_id`), 'Tuple')), toJSONString(events.properties.`$survey_submission_id`), toString(events.properties.`$survey_submission_id`))))), ''), ''), 1), if(notEquals(toJSONString(events.properties.^`$survey_submission_id`), '{}'), toJSONString(events.properties.^`$survey_submission_id`), if(isNull(events.properties.`$survey_submission_id`), NULL, if(startsWith(dynamicType(events.properties.`$survey_submission_id`), 'DateTime'), replaceOne(toString(events.properties.`$survey_submission_id`), ' ', 'T'), if(or(startsWith(dynamicType(events.properties.`$survey_submission_id`), 'Array'), startsWith(dynamicType(events.properties.`$survey_submission_id`), 'Map'), startsWith(dynamicType(events.properties.`$survey_submission_id`), 'Tuple')), toJSONString(events.properties.`$survey_submission_id`), toString(events.properties.`$survey_submission_id`))))), toString(events.uuid))) AS unique_responses
  FROM events_json AS events
  WHERE and(equals(events.team_id, 99999), equals(events.event, 'survey sent'), greaterOrEquals(events.timestamp, toDateTime64('today', 6, 'UTC')), in(events.properties.`$survey_id`, ['00000000-0000-0000-0000-000000000003']))
  GROUP BY survey_id
  LIMIT 1 SETTINGS readonly=2,
                   max_execution_time=60,
                   allow_experimental_object_type=1,
                   max_ast_elements=4000000,
                   max_expanded_ast_elements=4000000,
                   max_bytes_before_external_group_by=0,
                   transform_null_in=1,
                   optimize_min_equality_disjunction_chain_length=4294967295,
                   optimize_rewrite_aggregate_function_with_if=0,
                   optimize_min_inequality_conjunction_chain_length=4294967295,
                   allow_experimental_join_condition=1,
                   use_hive_partitioning=0
  '''
