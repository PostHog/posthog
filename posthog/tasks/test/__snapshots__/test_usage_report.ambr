# name: TestFeatureFlagsUsageReport.test_usage_report_decide_requests[new_events_schema.49]
  '''
  
  SELECT team_id,
         count(1) as count
  FROM events_json
  WHERE timestamp >= '2022-01-10 00:00:00'
    AND timestamp < '2022-01-10 23:59:59'
    AND ($group_0 != ''
         OR $group_1 != ''
         OR $group_2 != ''
         OR $group_3 != ''
         OR $group_4 != '')
  GROUP BY team_id
  '''
# ---
# name: TestFeatureFlagsUsageReport.test_usage_report_decide_requests[new_events_schema.4]
  '''
  
  SELECT team_id,
         multiIf(event LIKE 'helicone%', 'helicone_events', event LIKE 'langfuse%', 'langfuse_events', event LIKE 'keywords_ai%', 'keywords_ai_events', event LIKE 'traceloop%', 'traceloop_events', ifNull(properties.`$lib`, '') = 'web', 'web_events', ifNull(properties.`$lib`, '') = 'js', 'web_lite_events', ifNull(properties.`$lib`, '') = 'posthog-node', 'node_events', ifNull(properties.`$lib`, '') = 'posthog-edge', 'edge_events', ifNull(properties.`$lib`, '') = 'posthog-convex', 'convex_events', ifNull(properties.`$lib`, '') = 'posthog-android', 'android_events', ifNull(properties.`$lib`, '') = 'posthog-flutter', 'flutter_events', ifNull(properties.`$lib`, '') = 'posthog-ios', 'ios_events', ifNull(properties.`$lib`, '') = 'posthog-go', 'go_events', ifNull(properties.`$lib`, '') = 'posthog-java', 'java_events', ifNull(properties.`$lib`, '') = 'posthog-server', 'java_events', ifNull(properties.`$lib`, '') = 'posthog-react-native', 'react_native_events', ifNull(properties.`$lib`, '') = 'posthog-ruby', 'ruby_events', ifNull(properties.`$lib`, '') = 'posthog-python', 'python_events', ifNull(properties.`$lib`, '') = 'posthog-php', 'php_events', ifNull(properties.`$lib`, '') = 'posthog-dotnet', 'dotnet_events', ifNull(properties.`$lib`, '') = 'posthog-elixir', 'elixir_events', ifNull(properties.`$lib`, '') = 'posthog-unity', 'unity_events', ifNull(properties.`$lib`, '') = 'posthog-rs', 'rust_events', 'other') AS metric,
         count(1) as count
  FROM events_json PREWHERE timestamp >= '2022-01-10 08:00:00'
  AND timestamp < '2022-01-10 10:00:00'
  WHERE (event LIKE 'helicone%'
         OR event LIKE 'langfuse%'
         OR event LIKE 'keywords_ai%'
         OR event LIKE 'traceloop%'
         OR ifNull(properties.`$lib`, '') IN ('web',
                                              'js',
                                              'posthog-node',
                                              'posthog-edge',
                                              'posthog-convex',
                                              'posthog-android',
                                              'posthog-flutter',
                                              'posthog-ios',
                                              'posthog-go',
                                              'posthog-java',
                                              'posthog-server',
                                              'posthog-react-native',
                                              'posthog-ruby',
                                              'posthog-python',
                                              'posthog-php',
                                              'posthog-dotnet',
                                              'posthog-elixir',
                                              'posthog-unity',
                                              'posthog-rs'))
  GROUP BY team_id,
