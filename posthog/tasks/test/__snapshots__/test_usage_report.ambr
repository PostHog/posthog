# ---
# name: TestFeatureFlagsUsageReport.test_usage_report_decide_requests[new_events_schema.24]
  '''
  
  SELECT team_id,
         multiIf(ifNull(properties.`$lib`, '') = 'web', 'web', ifNull(properties.`$lib`, '') = 'js', 'web_lite', ifNull(properties.`$lib`, '') = 'posthog-node', 'node', ifNull(properties.`$lib`, '') = 'posthog-edge', 'node', ifNull(properties.`$lib`, '') = 'posthog-android', 'android', ifNull(properties.`$lib`, '') = 'posthog-flutter', 'flutter', ifNull(properties.`$lib`, '') = 'posthog-ios', 'ios', ifNull(properties.`$lib`, '') = 'posthog-go', 'go', ifNull(properties.`$lib`, '') = 'posthog-java', 'java', ifNull(properties.`$lib`, '') = 'posthog-server', 'java', ifNull(properties.`$lib`, '') = 'posthog-react-native', 'react_native', ifNull(properties.`$lib`, '') = 'posthog-ruby', 'ruby', ifNull(properties.`$lib`, '') = 'posthog-python', 'python', 'unknown') AS library,
         count(1) as total
  FROM events_json
  WHERE event = '$exception'
    AND timestamp >= '2022-01-10 00:00:00'
    AND timestamp < '2022-01-10 23:59:59'
  GROUP BY team_id,
           library
  '''
