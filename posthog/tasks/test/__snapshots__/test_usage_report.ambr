                                                                                                                         OR startsWith(dynamicType(properties.`$ai_lib`), 'Tuple'), toJSONString(properties.`$ai_lib`), if(startsWith(dynamicType(properties.`$ai_lib`), 'DateTime'), replaceOne(toString(properties.`$ai_lib`), ' ', 'T'), toString(properties.`$ai_lib`)))), ''), '^"|"$', '') AS ai_lib,
         count(1) as count
  FROM events_json PREWHERE timestamp >= '2022-01-10 18:00:00'
  AND timestamp < '2022-01-10 20:00:00'
  AND ifNull(properties.`$lib`, '') IN ('posthog-node')
  AND startsWith(event, '$ai_')
  WHERE replaceRegexpAll(ifNull(if(toJSONString(properties.^`$ai_lib`) != '{}', toJSONString(properties.^`$ai_lib`), if(startsWith(dynamicType(properties.`$ai_lib`), 'Array')
                                                                                                                        OR startsWith(dynamicType(properties.`$ai_lib`), 'Map')
