  '''
# ---
# name: TestFeatureFlagsUsageReport.test_usage_report_decide_requests[new_events_schema.50]
  '''
  
  SELECT distinct_id as team,
         sum(JSONExtractInt(toJSONString(properties), 'count')) as sum
  FROM events_json
  WHERE team_id = 99999
    AND event='decide usage'
    AND timestamp >= '2022-01-10 00:00:00'
    AND timestamp < '2022-01-10 23:59:59'
    AND has(['correct'], replaceRegexpAll(JSONExtractRaw(toJSONString(properties), 'token'), '^"|"$', ''))
  GROUP BY team
  '''
# ---
# name: TestFeatureFlagsUsageReport.test_usage_report_decide_requests[new_events_schema.51]
  '''
  
  SELECT distinct_id as team,
         sum(JSONExtractInt(toJSONString(properties), 'count')) as sum
  FROM events_json
  WHERE team_id = 99999
    AND event='local evaluation usage'
    AND timestamp >= '2022-01-10 00:00:00'
    AND timestamp < '2022-01-10 23:59:59'
    AND has(['correct'], replaceRegexpAll(JSONExtractRaw(toJSONString(properties), 'token'), '^"|"$', ''))
  GROUP BY team
  '''
# ---
# name: TestFeatureFlagsUsageReport.test_usage_report_decide_requests[new_events_schema.52]
  '''
  
  SELECT team_id,
         COUNT() as count
  FROM events_json
  WHERE event = 'survey sent'
    AND timestamp >= '2022-01-10 00:00:00'
    AND timestamp < '2022-01-10 23:59:59'
    AND uuid IN
      (SELECT argMax(uuid, timestamp)
       FROM events_json
       WHERE timestamp >= '2022-01-10 00:00:00'
         AND timestamp < '2022-01-10 23:59:59'
         AND event = 'survey sent'
       GROUP BY team_id,
                ifNull(properties.`$survey_id`, ''),
                CASE
                    WHEN COALESCE(replaceRegexpAll(ifNull(if(toJSONString(properties.^`$survey_submission_id`) != '{}', toJSONString(properties.^`$survey_submission_id`), if(startsWith(dynamicType(properties.`$survey_submission_id`), 'Array')
                                                                                                                                                                              OR startsWith(dynamicType(properties.`$survey_submission_id`), 'Map')
                                                                                                                                                                              OR startsWith(dynamicType(properties.`$survey_submission_id`), 'Tuple'), toJSONString(properties.`$survey_submission_id`), if(startsWith(dynamicType(properties.`$survey_submission_id`), 'DateTime'), replaceOne(toString(properties.`$survey_submission_id`), ' ', 'T'), toString(properties.`$survey_submission_id`)))), ''), '^"|"$', ''), '') = '' THEN toString(uuid)
                    ELSE replaceRegexpAll(ifNull(if(toJSONString(properties.^`$survey_submission_id`) != '{}', toJSONString(properties.^`$survey_submission_id`), if(startsWith(dynamicType(properties.`$survey_submission_id`), 'Array')
                                                                                                                                                                     OR startsWith(dynamicType(properties.`$survey_submission_id`), 'Map')
                                                                                                                                                                     OR startsWith(dynamicType(properties.`$survey_submission_id`), 'Tuple'), toJSONString(properties.`$survey_submission_id`), if(startsWith(dynamicType(properties.`$survey_submission_id`), 'DateTime'), replaceOne(toString(properties.`$survey_submission_id`), ' ', 'T'), toString(properties.`$survey_submission_id`)))), ''), '^"|"$', '')
                END)
  GROUP BY team_id
  '''
# ---
# name: TestFeatureFlagsUsageReport.test_usage_report_decide_requests[new_events_schema.53]
  '''
  
  SELECT team_id,
         COUNT() - uniqExactIf(request_id, verified
                               AND request_id != '') as count
  FROM
    (SELECT team_id,
            JSONExtractBool(toJSONString(properties), '$ai_gateway_verified') as verified,
            if(verified, JSONExtractString(toJSONString(properties), '$ai_gateway_request_id'), '') as request_id
     FROM events_json
     WHERE event IN ['$ai_generation', '$ai_embedding', '$ai_span', '$ai_trace', '$ai_metric', '$ai_feedback', '$ai_evaluation', '$ai_tag', '$ai_trace_summary', '$ai_generation_summary', '$ai_trace_clusters', '$ai_generation_clusters']
       AND timestamp >= '2022-01-10 00:00:00'
       AND timestamp < '2022-01-10 23:59:59')
  GROUP BY team_id
  '''
