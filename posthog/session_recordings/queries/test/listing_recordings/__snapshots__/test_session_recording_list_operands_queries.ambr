                                                                                                                                                                                                                                                       WHERE and(equals(events.team_id, 99999), notEmpty(nullIf(nullIf(events.properties.`$session_id`, ''), 'null')), lessOrEquals(events.timestamp, now64(6, 'UTC')), and(equals(events.event, '$pageview'), and(ilike(events.properties.`$pathname`, '%target%'), isNotNull(events.properties.`$pathname`))), greaterOrEquals(events.timestamp, toDateTime64('2020-12-28 00:00:00.000000', 6, 'UTC')))
