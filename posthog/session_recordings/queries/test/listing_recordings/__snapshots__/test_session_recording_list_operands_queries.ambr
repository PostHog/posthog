                                                                                                                                                                                                                                                       HAVING 1
                                                                                                                                                                                                                                                       ORDER BY min(toTimeZone(events.timestamp, 'UTC')) DESC
                                                                                                                                                                                                                                                       LIMIT 1000000))))
  GROUP BY s.session_id
