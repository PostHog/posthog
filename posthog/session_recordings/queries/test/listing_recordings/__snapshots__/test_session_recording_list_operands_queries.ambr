         dateDiff('DAY', toDateTime64('today', 6, 'UTC'), expiry_time) AS recording_ttl,
         greaterOrEquals(max(toTimeZone(s._timestamp, 'UTC')), toDateTime64('today', 6, 'UTC')) AS ongoing,
         round(multiply(divide(plus(plus(plus(divide(sum(s.active_milliseconds), 1000), sum(s.click_count)), sum(s.keypress_count)), sum(s.console_error_count)), plus(plus(plus(plus(sum(s.mouse_activity_count), dateDiff('SECOND', start_time, end_time)), sum(s.console_error_count)), sum(s.console_log_count)), sum(s.console_warn_count))), 100), 2) AS activity_score,
         coalesce(max(s.surfacing_score), 0.36) AS surfacing_score
  FROM session_replay_events AS s
  WHERE and(equals(s.team_id, 99999), greaterOrEquals(s.min_first_timestamp, toDateTime64('2020-12-29 00:00:00.000000', 6, 'UTC')), lessOrEquals(s.min_first_timestamp, toDateTime64('today', 6, 'UTC')), globalNotIn(s.session_id,
                                                                                                                                                                                                                        (SELECT nullIf(nullIf(events.properties.`$session_id`, ''), 'null') AS session_id
                                                                                                                                                                                                                         FROM events_json AS events
                                                                                                                                                                                                                         WHERE and(equals(events.team_id, 99999), notEmpty(nullIf(nullIf(events.properties.`$session_id`, ''), 'null')), lessOrEquals(events.timestamp, now64(6, 'UTC')), or(ifNull(equals(if(notEquals(toJSONString(events.properties.^vip), '{}'), toJSONString(events.properties.^vip), if(isNull(events.properties.vip), NULL, if(startsWith(dynamicType(events.properties.vip), 'DateTime'), replaceOne(toString(events.properties.vip), ' ', 'T'), toString(events.properties.vip)))), 'true'), 0), and(ilike(events.properties.`$pathname`, '%target%'), isNotNull(events.properties.`$pathname`))), greaterOrEquals(events.timestamp, toDateTime64('2020-12-28 00:00:00.000000', 6, 'UTC')))
                                                                                                                                                                                                                         GROUP BY nullIf(nullIf(events.properties.`$session_id`, ''), 'null')
                                                                                                                                                                                                                         LIMIT 1000000)), and(globalIn(s.session_id,
                                                                                                                                                                                                                                                         (SELECT nullIf(nullIf(events.properties.`$session_id`, ''), 'null') AS session_id
                                                                                                                                                                                                                                                          FROM events_json AS events
                                                                                                                                                                                                                                                          WHERE and(equals(events.team_id, 99999), notEmpty(nullIf(nullIf(events.properties.`$session_id`, ''), 'null')), lessOrEquals(events.timestamp, now64(6, 'UTC')), and(equals(events.event, '$pageview'), ifNull(notEquals(if(notEquals(toJSONString(events.properties.^vip), '{}'), toJSONString(events.properties.^vip), if(isNull(events.properties.vip), NULL, if(startsWith(dynamicType(events.properties.vip), 'DateTime'), replaceOne(toString(events.properties.vip), ' ', 'T'), toString(events.properties.vip)))), 'true'), 1)), greaterOrEquals(events.timestamp, toDateTime64('2020-12-28 00:00:00.000000', 6, 'UTC')))
                                                                                                                                                                                                                                                          GROUP BY nullIf(nullIf(events.properties.`$session_id`, ''), 'null')
                                                                                                                                                                                                                                                          HAVING and(equals(countIf(ifNull(equals(if(notEquals(toJSONString(events.properties.^vip), '{}'), toJSONString(events.properties.^vip), if(isNull(events.properties.vip), NULL, if(startsWith(dynamicType(events.properties.vip), 'DateTime'), replaceOne(toString(events.properties.vip), ' ', 'T'), toString(events.properties.vip)))), 'true'), 0)), 0), equals(countIf(and(ilike(events.properties.`$pathname`, '%target%'), isNotNull(events.properties.`$pathname`))), 0))
                                                                                                                                                                                                                                                          ORDER BY min(toTimeZone(events.timestamp, 'UTC')) DESC
                                                                                                                                                                                                                                                          LIMIT 1000000)), globalIn(s.session_id,
                                                                                                                                                                                                                                                                                      (SELECT nullIf(nullIf(events.properties.`$session_id`, ''), 'null') AS session_id
                                                                                                                                                                                                                                                                                       FROM events_json AS events
                                                                                                                                                                                                                                                                                       WHERE and(equals(events.team_id, 99999), notEmpty(nullIf(nullIf(events.properties.`$session_id`, ''), 'null')), lessOrEquals(events.timestamp, now64(6, 'UTC')), and(equals(events.event, '$pageview'), ifNull(notILike(events.properties.`$pathname`, '%target%'), 1)), greaterOrEquals(events.timestamp, toDateTime64('2020-12-28 00:00:00.000000', 6, 'UTC')))
                                                                                                                                                                                                                                                                                       GROUP BY nullIf(nullIf(events.properties.`$session_id`, ''), 'null')
                                                                                                                                                                                                                                                                                       HAVING and(equals(countIf(ifNull(equals(if(notEquals(toJSONString(events.properties.^vip), '{}'), toJSONString(events.properties.^vip), if(isNull(events.properties.vip), NULL, if(startsWith(dynamicType(events.properties.vip), 'DateTime'), replaceOne(toString(events.properties.vip), ' ', 'T'), toString(events.properties.vip)))), 'true'), 0)), 0), equals(countIf(and(ilike(events.properties.`$pathname`, '%target%'), isNotNull(events.properties.`$pathname`))), 0))
                                                                                                                                                                                                                                                                                       ORDER BY min(toTimeZone(events.timestamp, 'UTC')) DESC
                                                                                                                                                                                                                                                                                       LIMIT 1000000))))
  GROUP BY s.session_id
  HAVING and(greaterOrEquals(expiry_time, toDateTime64('today', 6, 'UTC')), equals(max(s.is_deleted), 0))
  ORDER BY start_time DESC,
           s.session_id DESC
  LIMIT 51 SETTINGS readonly=2,
                    max_execution_time=60,
                    allow_experimental_object_type=1,
                    max_ast_elements=4000000,
                    max_expanded_ast_elements=4000000,
                    max_bytes_before_external_group_by=0,
                    transform_null_in=1,
                    optimize_min_equality_disjunction_chain_length=4294967295,
                    optimize_rewrite_aggregate_function_with_if=0,
                    optimize_min_inequality_conjunction_chain_length=4294967295,
                    allow_experimental_join_condition=1,
                    use_hive_partitioning=0
  '''
# ---
