xception_types', ''), if(isNotNull(events.properties.`$exception_values`), '$exception_values', ''), if(isNotNull(events.properties.`$feature_flag`), '$feature_flag', ''), if(isNotNull(events.properties.`$feature_flag_payloads`), '$feature_flag_payloads', ''), if(isNotNull(events.properties.`$feature_flag_response`), '$feature_flag_response', ''), if(isNotNull(events.properties.`$geoip_city_name`), '$geoip_city_name', ''), if(isNotNull(events.properties.`$geoip_country_code`), '$geoip_country_code', ''), if(isNotNull(events.properties.`$geoip_country_name`), '$geoip_country_name', ''), if(isNotNull(events.properties.`$geoip_subdivision_1_code`), '$geoip_subdivision_1_code', ''), if(isNotNull(events.properties.`$group_0`), '$group_0', ''), if(isNotNull(events.properties.`$group_1`), '$group_1', ''), if(isNotNull(events.properties.`$group_2`), '$group_2', ''), if(isNotNull(events.properties.`$group_3`), '$group_3', ''), if(isNotNull(events.properties.`$group_4`), '$group_4', ''), if(isNotNull(events.properties.`$groups`), '$groups', ''), if(isNotNull(events.properties.`$host`), '$host', ''), if(isNotNull(events.properties.`$initial_pathname`), '$initial_pathname', ''), if(isNotNull(events.properties.`$initial_referrer`), '$initial_referrer', ''), if(isNotNull(events.properties.`$initial_referring_domain`), '$initial_referring_domain', ''), if(isNotNull(events.properties.`$ip`), '$ip', ''), if(isNotNull(events.properties.`$is_identified`), '$is_identified', ''), if(isNotNull(events.properties.`$lib`), '$lib', ''), if(isNotNull(events.properties.`$lib_custom_api_host`), '$lib_custom_api_host', ''), if(isNotNull(events.properties.`$lib_version`), '$lib_version', ''), if(isNotNull(events.properties.`$lib_version__minor`), '$lib_version__minor', ''), if(isNotNull(events.properties.`$os`), '$os', ''), if(isNotNull(events.properties.`$os_name`), '$os_name', ''), if(isNotNull(events.properties.`$os_version`), '$os_version', ''), if(isNotNull(events.properties.`$pathname`), '$pathname', ''), if(isNotNull(events.properties.`$prev_pageview_max_content_percentage`), '$prev_pageview_max_content_percentage', ''), if(isNotNull(events.properties.`$prev_pageview_max_scroll_percentage`), '$prev_pageview_max_scroll_percentage', ''), if(isNotNull(events.properties.`$prev_pageview_pathname`), '$prev_pageview_pathname', ''), if(isNotNull(events.properties.`$process_person_profile`), '$process_person_profile', ''), if(isNotNull(events.properties.`$referrer`), '$referrer', ''), if(isNotNull(events.properties.`$referring_domain`), '$referring_domain', ''), if(isNotNull(events.properties.`$screen_height`), '$screen_height', ''), if(isNotNull(events.properties.`$screen_name`), '$screen_name', ''), if(isNotNull(events.properties.`$screen_width`), '$screen_width', ''), if(isNotNull(events.properties.`$sent_at`), '$sent_at', ''), if(isNotNull(events.properties.`$session_id`), '$session_id', ''), if(isNotNull(events.properties.`$survey_id`), '$survey_id', ''), if(isNotNull(events.properties.`$survey_response`), '$survey_response', ''), if(isNotNull(events.properties.`$survey_response_1`), '$survey_response_1', ''), if(isNotNull(events.properties.`$time`), '$time', ''), if(isNotNull(events.properties.`$user_id`), '$user_id', ''), if(isNotNull(events.properties.`$viewport_height`), '$viewport_height', ''), if(isNotNull(events.properties.`$viewport_width`), '$viewport_width', ''), if(isNotNull(events.properties.`$web_vitals_CLS_value`), '$web_vitals_CLS_value', ''), if(isNotNull(events.properties.`$web_vitals_FCP_value`), '$web_vitals_FCP_value', ''), if(isNotNull(events.properties.`$web_vitals_INP_value`), '$web_vitals_INP_value', ''), if(isNotNull(events.properties.`$web_vitals_LCP_value`), '$web_vitals_LCP_value', ''), if(isNotNull(events.properties.`$window_id`), '$window_id', '')]))))), ','), '}'), 'String') AS kv,
               toTimeZone(events.timestamp, 'UTC') AS timestamp
        FROM events_json AS events
        WHERE and(equals(events.team_id, 99999), greaterOrEquals(events.timestamp, minus(now64(6, 'UTC'), toIntervalDay(30))), equals(events.event, '$pageview'))
        ORDER BY toTimeZone(events.timestamp, 'UTC') DESC
        LIMIT 100) ARRAY
     JOIN (kv).1 AS key,
          (kv).2 AS value
     WHERE and(not(match(key, '(\\$set|\\$time|\\$set_once|\\$sent_at|distinct_id|\\$ip|\\$feature\\/|\\$feature_enrollment\\/|\\$feature_interaction\\/|\\$product_tour|__|survey_dismiss|survey_responded|phjs|partial_filter_chosen|changed_action|window-id|changed_event|partial_filter)')), isNotNull(value), ifNull(notEquals(value, ''), 1))
     GROUP BY key,
              value)
  GROUP BY key
  ORDER BY total_count DESC,
           key ASC
  LIMIT 501
  OFFSET 0 SETTINGS readonly=2,
                    max_execution_time=60,
                    allow_experimental_object_type=1,
                    max_ast_elements=4000000,
                    max_expanded_ast_elements=4000000,
                    max_bytes_before_external_group_by=0,
                    transform_null_in=1,
                    optimize_min_equality_disjunction_chain_length=4294967295,
                    optimize_rewrite_aggregate_function_with_if=0,
                    optimize_min_inequality_conjunction_chain_length=4294967295,
                    allow_experimental_join_condition=1,
                    use_hive_partitioning=0
