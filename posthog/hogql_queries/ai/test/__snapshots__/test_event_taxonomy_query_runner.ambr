  '''
  SELECT key AS key,
                arrayMap(item -> item.3, arraySlice(reverse(arraySort(item -> tuple(item.1, item.2, item.3), groupArray(tuple(value_count, latest_seen, value)))), 1, 5)) AS
  values,
                count(DISTINCT value) AS total_count
  FROM
    (SELECT key,
            value,
            count() AS value_count,
            max(timestamp) AS latest_seen
     FROM
       (SELECT [tuple('zero_duration_recording_count_in_period', JSONExtractString(events.properties, 'zero_duration_recording_count_in_period'))] AS kv,
               toTimeZone(events.timestamp, 'UTC') AS timestamp
        FROM events
        WHERE and(equals(events.team_id, 99999), greaterOrEquals(events.timestamp, minus(now64(6, 'UTC'), toIntervalDay(30))), equals(events.event, 'organization usage report'), notEquals(JSONExtractString(events.properties, 'zero_duration_recording_count_in_period'), ''))) ARRAY
     JOIN (kv).1 AS key,
          (kv).2 AS value
     WHERE and(isNotNull(value), ifNull(notEquals(value, ''), 1))
     GROUP BY key,
              value)
  GROUP BY key
  ORDER BY total_count DESC,
           key ASC
  LIMIT 501
  OFFSET 0 SETTINGS readonly=2,
