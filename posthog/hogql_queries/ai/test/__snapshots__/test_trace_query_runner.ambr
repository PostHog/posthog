                                                                                                                                                                                                                                                                                                                                                                                                                                           and isNull(ai_events.trace_id))))), 2) AS total_latency,
         nullIf(sumIf(ai_events.input_tokens, in(ai_events.event, tuple('$ai_generation', '$ai_embedding'))), 0) AS input_tokens,
         nullIf(sumIf(ai_events.output_tokens, in(ai_events.event, tuple('$ai_generation', '$ai_embedding'))), 0) AS output_tokens,
         nullIf(round(sumIf(ai_events.input_cost_usd, in(ai_events.event, tuple('$ai_generation', '$ai_embedding'))), 10), 0) AS input_cost,
         nullIf(round(sumIf(ai_events.output_cost_usd, in(ai_events.event, tuple('$ai_generation', '$ai_embedding'))), 10), 0) AS output_cost,
         nullIf(round(sumIf(ai_events.total_cost_usd, in(ai_events.event, tuple('$ai_generation', '$ai_embedding'))), 10), 0) AS total_cost,
         arrayDistinct(arraySort(x -> x.3, groupArrayIf(tuple(ai_events.uuid, ai_events.event, toTimeZone(ai_events.timestamp, 'UTC'), ai_events.properties, ai_events.input, ai_events.output, ai_events.output_choices, ai_events.input_state, ai_events.output_state, ai_events.tools), notEquals(ai_events.event, '$ai_trace')))) AS events,
         argMinIf(ai_events.input_state, toTimeZone(ai_events.timestamp, 'UTC'), equals(ai_events.event, '$ai_trace')) AS input_state,
         argMinIf(ai_events.output_state, toTimeZone(ai_events.timestamp, 'UTC'), equals(ai_events.event, '$ai_trace')) AS output_state,
         argMinIf(ai_events.properties, toTimeZone(ai_events.timestamp, 'UTC'), equals(ai_events.event, '$ai_trace')) AS trace_properties,
         ifNull(argMinIf(ifNull(nullIf(ai_events.span_name, ''), nullIf(ai_events.trace_name, '')), toTimeZone(ai_events.timestamp, 'UTC'), equals(ai_events.event, '$ai_trace')), argMin(ifNull(nullIf(ai_events.span_name, ''), nullIf(ai_events.trace_name, '')), toTimeZone(ai_events.timestamp, 'UTC'))) AS trace_name
  FROM ai_events
  INNER JOIN
    (SELECT argMax(person_distinct_id2.person_id, person_distinct_id2.version) AS ai_events__pdi___person_id,
            argMax(person_distinct_id2.person_id, person_distinct_id2.version) AS person_id,
            person_distinct_id2.distinct_id AS distinct_id
     FROM person_distinct_id2
     WHERE equals(person_distinct_id2.team_id, 99999)
     GROUP BY person_distinct_id2.distinct_id
     HAVING equals(argMax(person_distinct_id2.is_deleted, person_distinct_id2.version), 0) SETTINGS optimize_aggregation_in_order=1) AS ai_events__pdi ON equals(ai_events.distinct_id, ai_events__pdi.distinct_id)
  LEFT JOIN
    (SELECT person.id AS id,
            replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(person.properties, 'bar'), ''), 'null'), '^"|"$', '') AS properties___bar
     FROM person
     WHERE and(equals(person.team_id, 99999), in(tuple(person.id, person.version),
                                                   (SELECT person.id AS id, max(person.version) AS version
                                                    FROM person
                                                    WHERE equals(person.team_id, 99999)
                                                    GROUP BY person.id
                                                    HAVING and(equals(argMax(person.is_deleted, person.version), 0), less(argMax(toTimeZone(person.created_at, 'UTC'), person.version), plus(now64(6, 'UTC'), toIntervalDay(1))))))) SETTINGS optimize_aggregation_in_order=1) AS ai_events__pdi__person ON equals(ai_events__pdi.ai_events__pdi___person_id, ai_events__pdi__person.id)
  WHERE and(equals(ai_events.team_id, 99999), in(ai_events.event, tuple('$ai_span', '$ai_generation', '$ai_embedding', '$ai_metric', '$ai_feedback', '$ai_trace')), and(greaterOrEquals(ai_events.timestamp, assumeNotNull(toDateTime('2024-11-30 23:50:00', 'UTC'))), lessOrEquals(ai_events.timestamp, assumeNotNull(toDateTime('2024-12-01 00:20:00', 'UTC'))), equals(ai_events.trace_id, 'trace1'), ifNull(equals(ai_events__pdi__person.properties___bar, 'foo'), 0)))
  GROUP BY ai_events.trace_id
