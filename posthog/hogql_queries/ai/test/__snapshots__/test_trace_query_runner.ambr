            if(notEquals(toJSONString(__ai_events_fallback.properties.^`$ai_trace_name`), '{}'), toJSONString(__ai_events_fallback.properties.^`$ai_trace_name`), if(isNull(__ai_events_fallback.properties.`$ai_trace_name`), NULL, if(startsWith(dynamicType(__ai_events_fallback.properties.`$ai_trace_name`), 'DateTime'), replaceOne(toString(__ai_events_fallback.properties.`$ai_trace_name`), ' ', 'T'), if(or(startsWith(dynamicType(__ai_events_fallback.properties.`$ai_trace_name`), 'Array'), startsWith(dynamicType(__ai_events_fallback.properties.`$ai_trace_name`), 'Map'), startsWith(dynamicType(__ai_events_fallback.properties.`$ai_trace_name`), 'Tuple')), toJSONString(__ai_events_fallback.properties.`$ai_trace_name`), toString(__ai_events_fallback.properties.`$ai_trace_name`))))) AS trace_name,
