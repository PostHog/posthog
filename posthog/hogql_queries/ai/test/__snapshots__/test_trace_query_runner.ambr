# name: TestTraceQueryRunner.test_person_property_filters.1
  '''
  SELECT ai_events.trace_id AS id,
         any(ai_events.session_id) AS ai_session_id,
         min(toTimeZone(ai_events.timestamp, 'UTC')) AS first_timestamp,
