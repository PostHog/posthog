         nullIf(round(sumIf(accurateCastOrNull(accurateCastOrNull(if(notEquals(toJSONString(events.properties.^`$ai_output_cost_usd`), '{}'), toJSONString(events.properties.^`$ai_output_cost_usd`), if(isNull(events.properties.`$ai_output_cost_usd`), NULL, if(startsWith(dynamicType(events.properties.`$ai_output_cost_usd`), 'DateTime'), replaceOne(toString(events.properties.`$ai_output_cost_usd`), ' ', 'T'), toString(events.properties.`$ai_output_cost_usd`)))), 'Float64'), 'Float64'), in(events.event, tuple('$ai_generation', '$ai_embedding'))), 10), 0) AS output_cost,
         nullIf(round(sumIf(accurateCastOrNull(accurateCastOrNull(events.properties.`$ai_total_cost_usd`, 'Float64'), 'Float64'), in(events.event, tuple('$ai_generation', '$ai_embedding'))), 10), 0) AS total_cost,
         arrayDistinct(arraySort(x -> x.3, groupArrayIf(tuple(events.uuid, events.event, toTimeZone(events.timestamp, 'UTC'), concat('{', arrayStringConcat(arrayMap(kv -> concat(toJSONString(kv.1), ':', kv.2), arrayFilter(kv -> kv.2 != 'null'
                                                                                                                                                                                                                              AND NOT (kv.2 = '[]'
                                                                                                                                                                                                                                       AND has(['$active_feature_flags', '$exception_functions', '$exception_sources', '$exception_types', '$exception_values'], kv.1)), JSONExtractKeysAndValuesRaw(toJSONString(events.properties)))), ','), '}'), if(notEquals(toJSONString(events.properties.^`$ai_input`), '{}'), toJSONString(events.properties.^`$ai_input`), if(isNull(events.properties.`$ai_input`), NULL, if(startsWith(dynamicType(events.properties.`$ai_input`), 'DateTime'), concat('"', ifNull(toString(replaceOne(toString(events.properties.`$ai_input`), ' ', 'T')), ''), '"'), toJSONString(events.properties.`$ai_input`)))), if(notEquals(toJSONString(events.properties.^`$ai_output`), '{}'), toJSONString(events.properties.^`$ai_output`), if(isNull(events.properties.`$ai_output`), NULL, if(startsWith(dynamicType(events.properties.`$ai_output`), 'DateTime'), concat('"', ifNull(toString(replaceOne(toString(events.properties.`$ai_output`), ' ', 'T')), ''), '"'), toJSONString(events.properties.`$ai_output`)))), if(notEquals(toJSONString(events.properties.^`$ai_output_choices`), '{}'), toJSONString(events.properties.^`$ai_output_choices`), if(isNull(events.properties.`$ai_output_choices`), NULL, if(startsWith(dynamicType(events.properties.`$ai_output_choices`), 'DateTime'), concat('"', ifNull(toString(replaceOne(toString(events.properties.`$ai_output_choices`), ' ', 'T')), ''), '"'), toJSONString(events.properties.`$ai_output_choices`)))), if(notEquals(toJSONString(events.properties.^`$ai_input_state`), '{}'), toJSONString(events.properties.^`$ai_input_state`), if(isNull(events.properties.`$ai_input_state`), NULL, if(startsWith(dynamicType(events.properties.`$ai_input_state`), 'DateTime'), concat('"', ifNull(toString(replaceOne(toString(events.properties.`$ai_input_state`), ' ', 'T')), ''), '"'), toJSONString(events.properties.`$ai_input_state`)))), if(notEquals(toJSONString(events.properties.^`$ai_output_state`), '{}'), toJSONString(events.properties.^`$ai_output_state`), if(isNull(events.properties.`$ai_output_state`), NULL, if(startsWith(dynamicType(events.properties.`$ai_output_state`), 'DateTime'), concat('"', ifNull(toString(replaceOne(toString(events.properties.`$ai_output_state`), ' ', 'T')), ''), '"'), toJSONString(events.properties.`$ai_output_state`)))), if(notEquals(toJSONString(events.properties.^`$ai_tools`), '{}'), toJSONString(events.properties.^`$ai_tools`), if(isNull(events.properties.`$ai_tools`), NULL, if(startsWith(dynamicType(events.properties.`$ai_tools`), 'DateTime'), concat('"', ifNull(toString(replaceOne(toString(events.properties.`$ai_tools`), ' ', 'T')), ''), '"'), toJSONString(events.properties.`$ai_tools`))))), notEquals(events.event, '$ai_trace')))) AS __ai_events_result_events,
         argMinIf(if(notEquals(toJSONString(events.properties.^`$ai_input_state`), '{}'), toJSONString(events.properties.^`$ai_input_state`), if(isNull(events.properties.`$ai_input_state`), NULL, if(startsWith(dynamicType(events.properties.`$ai_input_state`), 'DateTime'), concat('"', ifNull(toString(replaceOne(toString(events.properties.`$ai_input_state`), ' ', 'T')), ''), '"'), toJSONString(events.properties.`$ai_input_state`)))), toTimeZone(events.timestamp, 'UTC'), equals(events.event, '$ai_trace')) AS input_state,
         argMinIf(if(notEquals(toJSONString(events.properties.^`$ai_output_state`), '{}'), toJSONString(events.properties.^`$ai_output_state`), if(isNull(events.properties.`$ai_output_state`), NULL, if(startsWith(dynamicType(events.properties.`$ai_output_state`), 'DateTime'), concat('"', ifNull(toString(replaceOne(toString(events.properties.`$ai_output_state`), ' ', 'T')), ''), '"'), toJSONString(events.properties.`$ai_output_state`)))), toTimeZone(events.timestamp, 'UTC'), equals(events.event, '$ai_trace')) AS output_state,
         argMinIf(concat('{', arrayStringConcat(arrayMap(kv -> concat(toJSONString(kv.1), ':', kv.2), arrayFilter(kv -> kv.2 != 'null'
                                                                                                                  AND NOT (kv.2 = '[]'
                                                                                                                           AND has(['$active_feature_flags', '$exception_functions', '$exception_sources', '$exception_types', '$exception_values'], kv.1)), JSONExtractKeysAndValuesRaw(toJSONString(events.properties)))), ','), '}'), toTimeZone(events.timestamp, 'UTC'), equals(events.event, '$ai_trace')) AS trace_properties,
         ifNull(argMinIf(ifNull(nullIf(if(notEquals(toJSONString(events.properties.^`$ai_span_name`), '{}'), toJSONString(events.properties.^`$ai_span_name`), if(isNull(events.properties.`$ai_span_name`), NULL, if(startsWith(dynamicType(events.properties.`$ai_span_name`), 'DateTime'), replaceOne(toString(events.properties.`$ai_span_name`), ' ', 'T'), toString(events.properties.`$ai_span_name`)))), ''), nullIf(if(notEquals(toJSONString(events.properties.^`$ai_trace_name`), '{}'), toJSONString(events.properties.^`$ai_trace_name`), if(isNull(events.properties.`$ai_trace_name`), NULL, if(startsWith(dynamicType(events.properties.`$ai_trace_name`), 'DateTime'), replaceOne(toString(events.properties.`$ai_trace_name`), ' ', 'T'), toString(events.properties.`$ai_trace_name`)))), '')), toTimeZone(events.timestamp, 'UTC'), equals(events.event, '$ai_trace')), argMin(ifNull(nullIf(if(notEquals(toJSONString(events.properties.^`$ai_span_name`), '{}'), toJSONString(events.properties.^`$ai_span_name`), if(isNull(events.properties.`$ai_span_name`), NULL, if(startsWith(dynamicType(events.properties.`$ai_span_name`), 'DateTime'), replaceOne(toString(events.properties.`$ai_span_name`), ' ', 'T'), toString(events.properties.`$ai_span_name`)))), ''), nullIf(if(notEquals(toJSONString(events.properties.^`$ai_trace_name`), '{}'), toJSONString(events.properties.^`$ai_trace_name`), if(isNull(events.properties.`$ai_trace_name`), NULL, if(startsWith(dynamicType(events.properties.`$ai_trace_name`), 'DateTime'), replaceOne(toString(events.properties.`$ai_trace_name`), ' ', 'T'), toString(events.properties.`$ai_trace_name`)))), '')), toTimeZone(events.timestamp, 'UTC'))) AS trace_name
  FROM events_json AS events
  WHERE and(equals(events.team_id, 99999), in(events.event, tuple('$ai_span', '$ai_generation', '$ai_embedding', '$ai_metric', '$ai_feedback', '$ai_trace')), and(greaterOrEquals(events.timestamp, assumeNotNull(toDateTime('2024-11-30 23:50:00', 'UTC'))), lessOrEquals(events.timestamp, assumeNotNull(toDateTime('2024-12-01 00:20:00', 'UTC'))), equals(events.properties.`$ai_trace_id`, 'trace1'), ifNull(equals(if(notEquals(toJSONString(events.properties.^foo), '{}'), toJSONString(events.properties.^foo), if(isNull(events.properties.foo), NULL, if(startsWith(dynamicType(events.properties.foo), 'DateTime'), replaceOne(toString(events.properties.foo), ' ', 'T'), toString(events.properties.foo)))), 'barz'), 0)))
  GROUP BY events.properties.`$ai_trace_id`
  LIMIT 1 SETTINGS readonly=2,
                   max_execution_time=60,
                   allow_experimental_object_type=1,
                   max_ast_elements=4000000,
                   max_expanded_ast_elements=4000000,
                   max_bytes_before_external_group_by=0,
                   transform_null_in=1,
                   optimize_min_equality_disjunction_chain_length=4294967295,
                   optimize_rewrite_aggregate_function_with_if=0,
                   optimize_min_inequality_conjunction_chain_length=4294967295,
                   allow_experimental_join_condition=1,
                   use_hive_partitioning=0
  '''
# ---
# name: TestTraceQueryRunner.test_person_property_filters
  '''
  SELECT ai_events.trace_id AS id,
         any(ai_events.session_id) AS ai_session_id,
         min(toTimeZone(ai_events.timestamp, 'UTC')) AS first_timestamp,
         max(toTimeZone(ai_events.timestamp, 'UTC')) AS last_timestamp,
         ifNull(nullIf(argMinIf(ai_events.distinct_id, toTimeZone(ai_events.timestamp, 'UTC'), equals(ai_events.event, '$ai_trace')), ''), argMin(ai_events.distinct_id, toTimeZone(ai_events.timestamp, 'UTC'))) AS first_distinct_id,
         round(if(and(equals(countIf(and(ifNull(greater(ai_events.latency, 0), 0), notEquals(ai_events.event, '$ai_generation'))), 0), greater(countIf(and(ifNull(greater(ai_events.latency, 0), 0), equals(ai_events.event, '$ai_generation'))), 0)), sumIf(ai_events.latency, and(equals(ai_events.event, '$ai_generation'), ifNull(greater(ai_events.latency, 0), 0))), sumIf(ai_events.latency, or(isNull(ai_events.parent_id), ifNull(equals(ai_events.parent_id, ai_events.trace_id), isNull(ai_events.parent_id)
                                                                                                                                                                                                                                                                                                                                                                                                                                           and isNull(ai_events.trace_id))))), 2) AS total_latency,
         nullIf(sumIf(ai_events.input_tokens, in(ai_events.event, tuple('$ai_generation', '$ai_embedding'))), 0) AS input_tokens,
         nullIf(sumIf(ai_events.output_tokens, in(ai_events.event, tuple('$ai_generation', '$ai_embedding'))), 0) AS output_tokens,
         nullIf(round(sumIf(ai_events.input_cost_usd, in(ai_events.event, tuple('$ai_generation', '$ai_embedding'))), 10), 0) AS input_cost,
         nullIf(round(sumIf(ai_events.output_cost_usd, in(ai_events.event, tuple('$ai_generation', '$ai_embedding'))), 10), 0) AS output_cost,
         nullIf(round(sumIf(ai_events.total_cost_usd, in(ai_events.event, tuple('$ai_generation', '$ai_embedding'))), 10), 0) AS total_cost,
         arrayDistinct(arraySort(x -> x.3, groupArrayIf(tuple(ai_events.uuid, ai_events.event, toTimeZone(ai_events.timestamp, 'UTC'), ai_events.properties, ai_events.input, ai_events.output, ai_events.output_choices, ai_events.input_state, ai_events.output_state, ai_events.tools), notEquals(ai_events.event, '$ai_trace')))) AS events,
         argMinIf(ai_events.input_state, toTimeZone(ai_events.timestamp, 'UTC'), equals(ai_events.event, '$ai_trace')) AS input_state,
         argMinIf(ai_events.output_state, toTimeZone(ai_events.timestamp, 'UTC'), equals(ai_events.event, '$ai_trace')) AS output_state,
         argMinIf(ai_events.properties, toTimeZone(ai_events.timestamp, 'UTC'), equals(ai_events.event, '$ai_trace')) AS trace_properties,
         ifNull(argMinIf(ifNull(nullIf(ai_events.span_name, ''), nullIf(ai_events.trace_name, '')), toTimeZone(ai_events.timestamp, 'UTC'), equals(ai_events.event, '$ai_trace')), argMin(ifNull(nullIf(ai_events.span_name, ''), nullIf(ai_events.trace_name, '')), toTimeZone(ai_events.timestamp, 'UTC'))) AS trace_name
  FROM ai_events
  INNER JOIN
    (SELECT argMax(person_distinct_id2.person_id, person_distinct_id2.version) AS ai_events__pdi___person_id,
            argMax(person_distinct_id2.person_id, person_distinct_id2.version) AS person_id,
            person_distinct_id2.distinct_id AS distinct_id
     FROM person_distinct_id2
     WHERE equals(person_distinct_id2.team_id, 99999)
     GROUP BY person_distinct_id2.distinct_id
     HAVING equals(argMax(person_distinct_id2.is_deleted, person_distinct_id2.version), 0) SETTINGS optimize_aggregation_in_order=1) AS ai_events__pdi ON equals(ai_events.distinct_id, ai_events__pdi.distinct_id)
  LEFT JOIN
    (SELECT person.id AS id,
            replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(person.properties, 'bar'), ''), 'null'), '^"|"$', '') AS properties___bar
     FROM person
     WHERE and(equals(person.team_id, 99999), in(tuple(person.id, person.version),
                                                   (SELECT person.id AS id, max(person.version) AS version
                                                    FROM person
                                                    WHERE equals(person.team_id, 99999)
                                                    GROUP BY person.id
                                                    HAVING and(equals(argMax(person.is_deleted, person.version), 0), less(argMax(toTimeZone(person.created_at, 'UTC'), person.version), plus(now64(6, 'UTC'), toIntervalDay(1))))))) SETTINGS optimize_aggregation_in_order=1) AS ai_events__pdi__person ON equals(ai_events__pdi.ai_events__pdi___person_id, ai_events__pdi__person.id)
  WHERE and(equals(ai_events.team_id, 99999), in(ai_events.event, tuple('$ai_span', '$ai_generation', '$ai_embedding', '$ai_metric', '$ai_feedback', '$ai_trace')), and(greaterOrEquals(ai_events.timestamp, assumeNotNull(toDateTime('2024-11-30 23:50:00', 'UTC'))), lessOrEquals(ai_events.timestamp, assumeNotNull(toDateTime('2024-12-01 00:20:00', 'UTC'))), equals(ai_events.trace_id, 'trace1'), ifNull(equals(ai_events__pdi__person.properties___bar, 'baz'), 0)))
  GROUP BY ai_events.trace_id
  LIMIT 1 SETTINGS readonly=2,
                   max_execution_time=60,
                   allow_experimental_object_type=1,
                   max_ast_elements=4000000,
                   max_expanded_ast_elements=4000000,
                   max_bytes_before_external_group_by=0,
                   transform_null_in=1,
                   optimize_min_equality_disjunction_chain_length=4294967295,
                   optimize_rewrite_aggregate_function_with_if=0,
                   optimize_min_inequality_conjunction_chain_length=4294967295,
                   allow_experimental_join_condition=1,
                   use_hive_partitioning=0
  '''
