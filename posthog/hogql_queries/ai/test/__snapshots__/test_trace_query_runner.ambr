if(isNotNull(events.properties.`$exception_values`), '$exception_values', ''), if(isNotNull(events.properties.`$feature_flag`), '$feature_flag', ''), if(isNotNull(events.properties.`$feature_flag_payloads`), '$feature_flag_payloads', ''), if(isNotNull(events.properties.`$feature_flag_response`), '$feature_flag_response', ''), if(isNotNull(events.properties.`$geoip_city_name`), '$geoip_city_name', ''), if(isNotNull(events.properties.`$geoip_country_code`), '$geoip_country_code', ''), if(isNotNull(events.properties.`$geoip_country_name`), '$geoip_country_name', ''), if(isNotNull(events.properties.`$geoip_subdivision_1_code`), '$geoip_subdivision_1_code', ''), if(isNotNull(events.properties.`$group_0`), '$group_0', ''), if(isNotNull(events.properties.`$group_1`), '$group_1', ''), if(isNotNull(events.properties.`$group_2`), '$group_2', ''), if(isNotNull(events.properties.`$group_3`), '$group_3', ''), if(isNotNull(events.properties.`$group_4`), '$group_4', ''), if(isNotNull(events.properties.`$groups`), '$groups', ''), if(isNotNull(events.properties.`$host`), '$host', ''), if(isNotNull(events.properties.`$initial_pathname`), '$initial_pathname', ''), if(isNotNull(events.properties.`$initial_referrer`), '$initial_referrer', ''), if(isNotNull(events.properties.`$initial_referring_domain`), '$initial_referring_domain', ''), if(isNotNull(events.properties.`$ip`), '$ip', ''), if(isNotNull(events.properties.`$is_identified`), '$is_identified', ''), if(isNotNull(events.properties.`$lib`), '$lib', ''), if(isNotNull(events.properties.`$lib_custom_api_host`), '$lib_custom_api_host', ''), if(isNotNull(events.properties.`$lib_version`), '$lib_version', ''), if(isNotNull(events.properties.`$lib_version__minor`), '$lib_version__minor', ''), if(isNotNull(events.properties.`$os`), '$os', ''), if(isNotNull(events.properties.`$os_name`), '$os_name', ''), if(isNotNull(events.properties.`$os_version`), '$os_version', ''), if(isNotNull(events.properties.`$pathname`), '$pathname', ''), if(isN