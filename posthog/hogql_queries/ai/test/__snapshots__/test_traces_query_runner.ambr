         argMinIf(ai_events.output_state, toTimeZone(ai_events.timestamp, 'UTC'), equals(ai_events.event, '$ai_trace')) AS output_state,
         ifNull(argMinIf(ifNull(nullIf(ai_events.span_name, ''), nullIf(ai_events.trace_name, '')), toTimeZone(ai_events.timestamp, 'UTC'), equals(ai_events.event, '$ai_trace')), argMin(ifNull(nullIf(ai_events.span_name, ''), nullIf(ai_events.trace_name, '')), toTimeZone(ai_events.timestamp, 'UTC'))) AS trace_name,
         countIf(equals(ai_events.is_error, 1)) AS error_count,
         any(replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(ai_events.properties, 'ai_support_impersonated'), ''), 'null'), '^"|"$', '')) AS is_support_trace,
         arrayFilter(x -> ifNull(notEquals(x, ''), 1), arrayDistinct(splitByChar(',', arrayStringConcat(groupArrayIf(toString(replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(ai_events.properties, '$ai_tools_called'), ''), 'null'), '^"|"$', '')), and(equals(ai_events.event, '$ai_generation'), isNotNull(replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(ai_events.properties, '$ai_tools_called'), ''), 'null'), '^"|"$', '')), ifNull(notEquals(toString(replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(ai_events.properties, '$ai_tools_called'), ''), 'null'), '^"|"$', '')), ''), 1))), ',')))) AS tools
  FROM ai_events
  WHERE and(equals(ai_events.team_id, 99999), and(in(ai_events.event, tuple('$ai_span', '$ai_generation', '$ai_embedding', '$ai_metric', '$ai_feedback', '$ai_trace')), and(greaterOrEquals(toTimeZone(ai_events.timestamp, 'UTC'), assumeNotNull(toDateTime('2025-01-14 23:50:00', 'UTC'))), lessOrEquals(toTimeZone(ai_events.timestamp, 'UTC'), assumeNotNull(toDateTime('2025-01-15 10:10:00', 'UTC'))))), in(ai_events.trace_id, tuple('trace_10', 'trace_9', 'trace_8', 'trace_7', 'trace_6', 'trace_5', 'trace_4', 'trace_3', 'trace_2', 'trace_1', 'trace_0')))
  GROUP BY ai_events.trace_id
