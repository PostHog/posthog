# serializer version: 1
# name: TestTracesQueryRunner.test_field_mapping
  '''
  SELECT groupArray(trace_id) AS trace_ids,
         min(first_ts) AS min_timestamp,
         max(last_ts) AS max_timestamp
  FROM
    (SELECT ai_events.trace_id AS trace_id,
            min(toTimeZone(ai_events.timestamp, 'UTC')) AS first_ts,
            max(toTimeZone(ai_events.timestamp, 'UTC')) AS last_ts
     FROM ai_events
     WHERE and(equals(ai_events.team_id, 99999), in(ai_events.event, tuple('$ai_span', '$ai_generation', '$ai_embedding', '$ai_metric', '$ai_feedback', '$ai_trace')), and(notEquals(trace_id, ''), and(greaterOrEquals(toTimeZone(ai_events.timestamp, 'UTC'), assumeNotNull(toDateTime('2025-01-08 23:50:00', 'UTC'))), lessOrEquals(toTimeZone(ai_events.timestamp, 'UTC'), assumeNotNull(toDateTime('2025-01-16 00:10:59', 'UTC'))))))
     GROUP BY trace_id
     ORDER BY min(toTimeZone(ai_events.timestamp, 'UTC')) DESC
     LIMIT 101)
  LIMIT 100 SETTINGS readonly=2,
                     max_execution_time=60,
                     allow_experimental_object_type=1,
                     max_ast_elements=4000000,
                     max_expanded_ast_elements=4000000,
                     max_bytes_before_external_group_by=0,
                     transform_null_in=1,
                     optimize_min_equality_disjunction_chain_length=4294967295,
                     allow_experimental_join_condition=1,
                     use_hive_partitioning=0
  '''
# ---
# name: TestTracesQueryRunner.test_field_mapping.1
  '''
  SELECT ai_events.trace_id AS id,
         any(ai_events.session_id) AS ai_session_id,
         min(toTimeZone(ai_events.timestamp, 'UTC')) AS first_timestamp,
         ifNull(nullIf(argMinIf(ai_events.distinct_id, toTimeZone(ai_events.timestamp, 'UTC'), equals(ai_events.event, '$ai_trace')), ''), argMin(ai_events.distinct_id, toTimeZone(ai_events.timestamp, 'UTC'))) AS first_distinct_id,
         round(if(and(ifNull(equals(countIf(and(greater(ai_events.latency, 0), notEquals(ai_events.event, '$ai_generation'))), 0), 0), ifNull(greater(countIf(and(greater(ai_events.latency, 0), equals(ai_events.event, '$ai_generation'))), 0), 0)), sumIf(ai_events.latency, and(equals(ai_events.event, '$ai_generation'), greater(ai_events.latency, 0))), sumIf(ai_events.latency, or(equals(ai_events.parent_id, ''), equals(ai_events.parent_id, ai_events.trace_id)))), 2) AS total_latency,
         nullIf(sumIf(ai_events.input_tokens, in(ai_events.event, tuple('$ai_generation', '$ai_embedding'))), 0) AS input_tokens,
         nullIf(sumIf(ai_events.output_tokens, in(ai_events.event, tuple('$ai_generation', '$ai_embedding'))), 0) AS output_tokens,
         nullIf(round(sumIf(ai_events.input_cost_usd, in(ai_events.event, tuple('$ai_generation', '$ai_embedding'))), 10), 0) AS input_cost,
         nullIf(round(sumIf(ai_events.output_cost_usd, in(ai_events.event, tuple('$ai_generation', '$ai_embedding'))), 10), 0) AS output_cost,
         nullIf(round(sumIf(ai_events.total_cost_usd, in(ai_events.event, tuple('$ai_generation', '$ai_embedding'))), 10), 0) AS total_cost,
         arrayDistinct(arraySort(x -> x.3, groupArrayIf(tuple(ai_events.uuid, ai_events.event, toTimeZone(ai_events.timestamp, 'UTC'), ai_events.properties, ai_events.input, ai_events.output, ai_events.output_choices, ai_events.input_state, ai_events.output_state, ai_events.tools), or(in(ai_events.event, tuple('$ai_metric', '$ai_feedback')), equals(ai_events.parent_id, ai_events.trace_id))))) AS events,
         argMinIf(ai_events.input_state, toTimeZone(ai_events.timestamp, 'UTC'), equals(ai_events.event, '$ai_trace')) AS input_state,
         argMinIf(ai_events.output_state, toTimeZone(ai_events.timestamp, 'UTC'), equals(ai_events.event, '$ai_trace')) AS output_state,
         ifNull(argMinIf(ifNull(nullIf(ai_events.span_name, ''), nullIf(ai_events.trace_name, '')), toTimeZone(ai_events.timestamp, 'UTC'), equals(ai_events.event, '$ai_trace')), argMin(ifNull(nullIf(ai_events.span_name, ''), nullIf(ai_events.trace_name, '')), toTimeZone(ai_events.timestamp, 'UTC'))) AS trace_name,
         countIf(equals(ai_events.is_error, 1)) AS error_count,
         any(replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(ai_events.properties, 'ai_support_impersonated'), ''), 'null'), '^"|"$', '')) AS is_support_trace,
         arrayFilter(x -> ifNull(notEquals(x, ''), 1), arrayDistinct(splitByChar(',', arrayStringConcat(groupArrayIf(toString(replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(ai_events.properties, '$ai_tools_called'), ''), 'null'), '^"|"$', '')), and(equals(ai_events.event, '$ai_generation'), isNotNull(replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(ai_events.properties, '$ai_tools_called'), ''), 'null'), '^"|"$', '')), ifNull(notEquals(toString(replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(ai_events.properties, '$ai_tools_called'), ''), 'null'), '^"|"$', '')), ''), 1))), ',')))) AS tools
  FROM ai_events
  WHERE and(equals(ai_events.team_id, 99999), and(in(ai_events.event, tuple('$ai_span', '$ai_generation', '$ai_embedding', '$ai_metric', '$ai_feedback', '$ai_trace')), and(greaterOrEquals(toTimeZone(ai_events.timestamp, 'UTC'), assumeNotNull(toDateTime('2025-01-13 23:50:00', 'UTC'))), lessOrEquals(toTimeZone(ai_events.timestamp, 'UTC'), assumeNotNull(toDateTime('2025-01-15 01:10:00', 'UTC'))))), in(ai_events.trace_id, tuple('trace1', 'trace2')))
  GROUP BY ai_events.trace_id
  ORDER BY first_timestamp DESC
  LIMIT 101
  OFFSET 0 SETTINGS readonly=2,
                    max_execution_time=60,
                    allow_experimental_object_type=1,
                    max_ast_elements=4000000,
                    max_expanded_ast_elements=4000000,
                    max_bytes_before_external_group_by=0,
                    transform_null_in=1,
                    optimize_min_equality_disjunction_chain_length=4294967295,
                    allow_experimental_join_condition=1,
                    use_hive_partitioning=0
  '''
