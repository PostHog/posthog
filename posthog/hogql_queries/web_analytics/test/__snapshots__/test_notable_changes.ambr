  GROUP BY dimension_value
  HAVING and(isNotNull(dimension_value), ifNull(notEquals(dimension_value,
                                                          ''), 1))
  LIMIT 100 SETTINGS readonly=2,
                     max_execution_time=60,
                     allow_experimental_object_type=1,
                     max_ast_elements=4000000,
                     max_expanded_ast_elements=4000000,
                     max_bytes_before_external_group_by=0,
                     transform_null_in=1,
                     optimize_min_equality_disjunction_chain_length=4294967295,
                     allow_experimental_join_condition=1,
                     use_hive_partitioning=0
  '''
# ---
# name: TestWebNotableChangesQueryRunner.test_integration_with_events.1
  '''
  SELECT 'Page' AS dimension_type,
         dimension_value AS dimension_value,
         uniqIf(person_id,
                and(ifNull(greaterOrEquals(start_timestamp,
                                           assumeNotNull(toDateTime('2025-01-22 00:00:00',
                                                                    'UTC'))), 0), ifNull(lessOrEquals(start_timestamp,
                                                                                                      assumeNotNull(toDateTime('2025-01-29 23:59:59',
                                                                                                                               'UTC'))), 0))) AS current_visitors,
                                                                                                                                            uniqIf(person_id,
                                                                                                                                                   and(ifNull(greaterOrEquals(start_timestamp,
                                                                                                                                                                              assumeNotNull(toDateTime('2025-01-15 00:00:00',
                                                                                                                                                                                                       'UTC'))), 0), ifNull(lessOrEquals(start_timestamp,
                                                                                                                                                                                                                                         assumeNotNull(toDateTime('2025-01-22 23:59:59',
                                                                                                                                                                                                                                                                  'UTC'))), 0))) AS previous_visitors
  FROM (
  SELECT any(if(not(empty(events__override.distinct_id)), events__override.person_id,
                                                          events.person_id)) AS person_id,
                                                                           nullIf(nullIf(replaceRegexpAll(nullIf(nullIf(JSONExtractRaw(events.properties,
                                                                                                                                       '$pathname'), ''), 'null'), '^"|"$',
                                                                                                                                                                   ''), ''), 'null') AS dimension_value,
                                                                                                                                                                                   events__session.session_id AS session_id,
                                                                                                                                                                                   min(events__session.`$start_timestamp`) AS start_timestamp
  FROM events
  LEFT JOIN (
  SELECT toString(reinterpretAsUUID(bitOr(bitShiftLeft(raw_sessions.session_id_v7,
                                                       64), bitShiftRight(raw_sessions.session_id_v7,
                                                                          64)))) AS session_id,
                                                                               min(toTimeZone(raw_sessions.min_timestamp,
                                                                                              'UTC')) AS `$start_timestamp`,
                                                                                                    raw_sessions.session_id_v7 AS session_id_v7
  FROM raw_sessions
  WHERE and(equals(raw_sessions.team_id,
                   99999), or(and(greaterOrEquals(fromUnixTimestamp(intDiv(toUInt64(bitShiftRight(raw_sessions.session_id_v7,
                                                                                                  80)), 1000)), minus(assumeNotNull(toDateTime('2025-01-22 00:00:00',
                                                                                                                                               'UTC')), toIntervalDay(3))), lessOrEquals(fromUnixTimestamp(intDiv(toUInt64(bitShiftRight(raw_sessions.session_id_v7,
                                                                                                                                                                                                                                         80)), 1000)), plus(assumeNotNull(toDateTime('2025-01-29 23:59:59',
                                                                                                                                                                                                                                                                                     'UTC')), toIntervalDay(3)))), and(greaterOrEquals(fromUnixTimestamp(intDiv(toUInt64(bitShiftRight(raw_sessions.session_id_v7,
                                                                                                                                                                                                                                                                                                                                                                                       80)), 1000)), minus(assumeNotNull(toDateTime('2025-01-15 00:00:00',
                                                                                                                                                                                                                                                                                                                                                                                                                                    'UTC')), toIntervalDay(3))), lessOrEquals(fromUnixTimestamp(intDiv(toUInt64(bitShiftRight(raw_sessions.session_id_v7,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              80)), 1000)), plus(assumeNotNull(toDateTime('2025-01-22 23:59:59',
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          'UTC')), toIntervalDay(3))))))
  GROUP BY raw_sessions.session_id_v7) AS events__session ON equals(events.`$session_id_uuid`,
                                                                    events__session.session_id_v7)
  LEFT OUTER JOIN (
  SELECT tupleElement(argMax(tuple(person_distinct_id_overrides.person_id), person_distinct_id_overrides.version), 1) AS person_id,
                                                                                                                   person_distinct_id_overrides.distinct_id AS distinct_id
  FROM person_distinct_id_overrides
  WHERE equals(person_distinct_id_overrides.team_id,
