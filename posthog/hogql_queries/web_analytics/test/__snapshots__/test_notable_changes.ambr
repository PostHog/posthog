                                                                                                                                                                                                                                                                                                                              'UTC'), assumeNotNull(toDateTime('2025-01-22 23:59:59',
                                                                                                                                                                                                                                                                                                                                                               'UTC'))))), 1))
  GROUP BY events__session.session_id,
