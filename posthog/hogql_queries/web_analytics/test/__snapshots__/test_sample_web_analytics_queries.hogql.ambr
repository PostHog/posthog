     GROUP BY session_id,
              breakdown_value)
  GROUP BY `context.columns.breakdown_value`
  HAVING and(notEquals(tupleElement(`context.columns.breakdown_value`, 1), NULL), notEquals(tupleElement(`context.columns.breakdown_value`, 2), NULL), notEquals(tupleElement(`context.columns.breakdown_value`, 1), 0), notEquals(tupleElement(`context.columns.breakdown_value`, 2), 0))
  ORDER BY `context.columns.visitors` DESC,
