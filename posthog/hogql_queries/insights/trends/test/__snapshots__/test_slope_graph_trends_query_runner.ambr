              FROM numbers(dateDiff('day', minus(toStartOfInterval(assumeNotNull(toDateTime('2024-05-01 00:00:00', 'UTC')), toIntervalDay(1)), toIntervalDay(7)), assumeNotNull(toDateTime('2024-05-14 23:59:59', 'UTC')))) AS numbers) AS d
