                     optimize_rewrite_aggregate_function_with_if=0,
                     optimize_min_inequality_conjunction_chain_length=4294967295,
                     allow_experimental_join_condition=1,
                     use_hive_partitioning=0
  '''
# ---
# name: TestSessionsTimelineQueryRunner.test_formal_sessions_global[new_events_schema]
  '''
  SELECT e.uuid AS uuid,
         e.timestamp AS timestamp,
         e.event AS event,
         e.properties AS properties,
         e.property_paths AS property_paths,
         e.distinct_id AS distinct_id,
         e.elements_chain AS elements_chain,
         e.session_id AS formal_session_id,
         first_value(e.uuid) OVER (PARTITION BY tuple(e.person_id, e.session_id_flip_index)
                                   ORDER BY toInt64(e.timestamp) ASC RANGE BETWEEN 1800 PRECEDING AND CURRENT ROW) AS informal_session_uuid,
         dateDiff('s', sre.start_time, sre.end_time) AS recording_duration_s
  FROM
    (SELECT uuid AS uuid,
                    person_id AS person_id,
                    timestamp AS timestamp,
                    event AS event,
                    properties AS properties,
                    property_paths AS property_paths,
                    distinct_id AS distinct_id,
                    elements_chain AS elements_chain,
                    session_id AS session_id,
                    sum(if(ifNull(equals(session_id, prev_session_id), isNull(session_id)
                                  and isNull(prev_session_id)), 0, 1)) OVER (PARTITION BY person_id
                                                                             ORDER BY timestamp ASC ROWS UNBOUNDED PRECEDING) AS session_id_flip_index
     FROM
       (SELECT event_source.uuid AS uuid,
               if(not(empty(event_source__override.distinct_id)), event_source__override.person_id, event_source.person_id) AS person_id,
               toTimeZone(event_source.timestamp, 'UTC') AS timestamp,
               event_source.event AS event,
               toJSONString(event_source.properties) AS properties,
               arrayConcat(arrayFilter(path -> not(has(['$active_feature_flags', '$ai_experiment_id', '$ai_http_status', '$ai_is_error', '$ai_model', '$ai_parent_id', '$ai_prompt_name', '$ai_provider', '$ai_session_id', '$ai_span_id', '$ai_total_cost_usd', '$ai_trace_id', '$anon_distinct_id', '$app_build', '$app_namespace', '$app_version', '$browser', '$browser_version', '$current_url', '$device', '$device_id', '$device_model', '$device_type', '$el_text', '$event_type', '$exception_fingerprint', '$exception_functions', '$exception_issue_id', '$exception_sources', '$exception_types', '$exception_values', '$feature_flag', '$feature_flag_payloads', '$feature_flag_response', '$geoip_city_name', '$geoip_country_code', '$geoip_country_name', '$geoip_subdivision_1_code', '$group_0', '$group_1', '$group_2', '$group_3', '$group_4', '$groups', '$host', '$initial_pathname', '$initial_referrer', '$initial_referring_domain', '$ip', '$is_identified', '$lib', '$lib_custom_api_host', '$lib_version', '$lib_version__minor', '$os', '$os_name', '$os_version', '$pathname', '$prev_pageview_max_content_percentage', '$prev_pageview_max_scroll_percentage', '$prev_pageview_pathname', '$process_person_profile', '$referrer', '$referring_domain', '$screen_height', '$screen_name', '$screen_width', '$sent_at', '$session_id', '$survey_id', '$survey_response', '$survey_response_1', '$time', '$user_id', '$viewport_height', '$viewport_width', '$web_vitals_CLS_value', '$web_vitals_FCP_value', '$web_vitals_INP_value', '$web_vitals_LCP_value', '$window_id'], path)), JSONAllPaths(event_source.properties)), arrayFilter(path -> notEmpty(path), [if(notEmpty(nullIf(nullIf(event_source.properties.`$active_feature_flags`, ''), 'null')), '$active_feature_flags', ''), if(isNotNull(event_source.properties.`$ai_experiment_id`), '$ai_experiment_id', ''), if(isNotNull(event_source.properties.`$ai_http_status`), '$ai_http_status', ''), if(isNotNull(event_source.properties.`$ai_is_error`), '$ai_is_error', ''), if(isNotNull(event_source.properties.`$ai_model`), '$ai_model', ''), if(isNotNull(event_source.properties.`$ai_parent_id`), '$ai_parent_id', ''), if(isNotNull(event_source.properties.`$ai_prompt_name`), '$ai_prompt_name', ''), if(isNotNull(event_source.properties.`$ai_provider`), '$ai_provider', ''), if(isNotNull(event_source.properties.`$ai_session_id`), '$ai_session_id', ''), if(isNotNull(event_source.properties.`$ai_span_id`), '$ai_span_id', ''), if(isNotNull(event_source.properties.`$ai_total_cost_usd`), '$ai_total_cost_usd', ''), if(isNotNull(event_source.properties.`$ai_trace_id`), '$ai_trace_id', ''), if(isNotNull(event_source.properties.`$anon_distinct_id`), '$anon_distinct_id', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$app_build`, ''), 'null')), '$app_build', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$app_namespace`, ''), 'null')), '$app_namespace', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$app_version`, ''), 'null')), '$app_version', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$browser`, ''), 'null')), '$browser', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$browser_version`, ''), 'null')), '$browser_version', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$current_url`, ''), 'null')), '$current_url', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$device`, ''), 'null')), '$device', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$device_id`, ''), 'null')), '$device_id', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$device_model`, ''), 'null')), '$device_model', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$device_type`, ''), 'null')), '$device_type', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$el_text`, ''), 'null')), '$el_text', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$event_type`, ''), 'null')), '$event_type', ''), if(isNotNull(event_source.properties.`$exception_fingerprint`), '$exception_fingerprint', ''), if(isNotNull(event_source.properties.`$exception_functions`), '$exception_functions', ''), if(isNotNull(event_source.properties.`$exception_issue_id`), '$exception_issue_id', ''), if(isNotNull(event_source.properties.`$exception_sources`), '$exception_sources', ''), if(isNotNull(event_source.properties.`$exception_types`), '$exception_types', ''), if(isNotNull(event_source.properties.`$exception_values`), '$exception_values', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$feature_flag`, ''), 'null')), '$feature_flag', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$feature_flag_payloads`, ''), 'null')), '$feature_flag_payloads', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$feature_flag_response`, ''), 'null')), '$feature_flag_response', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$geoip_city_name`, ''), 'null')), '$geoip_city_name', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$geoip_country_code`, ''), 'null')), '$geoip_country_code', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$geoip_country_name`, ''), 'null')), '$geoip_country_name', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$geoip_subdivision_1_code`, ''), 'null')), '$geoip_subdivision_1_code', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$group_0`, ''), 'null')), '$group_0', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$group_1`, ''), 'null')), '$group_1', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$group_2`, ''), 'null')), '$group_2', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$group_3`, ''), 'null')), '$group_3', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$group_4`, ''), 'null')), '$group_4', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$groups`, ''), 'null')), '$groups', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$host`, ''), 'null')), '$host', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$initial_pathname`, ''), 'null')), '$initial_pathname', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$initial_referrer`, ''), 'null')), '$initial_referrer', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$initial_referring_domain`, ''), 'null')), '$initial_referring_domain', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$ip`, ''), 'null')), '$ip', ''), if(isNotNull(event_source.properties.`$is_identified`), '$is_identified', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$lib`, ''), 'null')), '$lib', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$lib_custom_api_host`, ''), 'null')), '$lib_custom_api_host', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$lib_version`, ''), 'null')), '$lib_version', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$lib_version__minor`, ''), 'null')), '$lib_version__minor', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$os`, ''), 'null')), '$os', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$os_name`, ''), 'null')), '$os_name', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$os_version`, ''), 'null')), '$os_version', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$pathname`, ''), 'null')), '$pathname', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$prev_pageview_max_content_percentage`, ''), 'null')), '$prev_pageview_max_content_percentage', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$prev_pageview_max_scroll_percentage`, ''), 'null')), '$prev_pageview_max_scroll_percentage', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$prev_pageview_pathname`, ''), 'null')), '$prev_pageview_pathname', ''), if(isNotNull(event_source.properties.`$process_person_profile`), '$process_person_profile', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$referrer`, ''), 'null')), '$referrer', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$referring_domain`, ''), 'null')), '$referring_domain', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$screen_height`, ''), 'null')), '$screen_height', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$screen_name`, ''), 'null')), '$screen_name', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$screen_width`, ''), 'null')), '$screen_width', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$sent_at`, ''), 'null')), '$sent_at', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$session_id`, ''), 'null')), '$session_id', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$survey_id`, ''), 'null')), '$survey_id', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$survey_response`, ''), 'null')), '$survey_response', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$survey_response_1`, ''), 'null')), '$survey_response_1', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$time`, ''), 'null')), '$time', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$user_id`, ''), 'null')), '$user_id', ''), if(isNotNull(event_source.properties.`$viewport_height`), '$viewport_height', ''), if(isNotNull(event_source.properties.`$viewport_width`), '$viewport_width', ''), if(isNotNull(event_source.properties.`$web_vitals_CLS_value`), '$web_vitals_CLS_value', ''), if(isNotNull(event_source.properties.`$web_vitals_FCP_value`), '$web_vitals_FCP_value', ''), if(isNotNull(event_source.properties.`$web_vitals_INP_value`), '$web_vitals_INP_value', ''), if(isNotNull(event_source.properties.`$web_vitals_LCP_value`), '$web_vitals_LCP_value', ''), if(notEmpty(nullIf(nullIf(event_source.properties.`$window_id`, ''), 'null')), '$window_id', '')])) AS property_paths,
               event_source.distinct_id AS distinct_id,
               event_source.elements_chain AS elements_chain,
               event_source.`$session_id` AS session_id,
               lagInFrame(event_source.`$session_id`, 1) OVER (PARTITION BY if(not(empty(event_source__override.distinct_id)), event_source__override.person_id, event_source.person_id)
                                                               ORDER BY toTimeZone(event_source.timestamp, 'UTC') ASC) AS prev_session_id
        FROM events_json AS event_source
        LEFT OUTER JOIN
          (SELECT argMax(person_distinct_id_overrides.person_id, person_distinct_id_overrides.version) AS person_id,
                  person_distinct_id_overrides.distinct_id AS distinct_id
           FROM person_distinct_id_overrides
           WHERE equals(person_distinct_id_overrides.team_id, 99999)
           GROUP BY person_distinct_id_overrides.distinct_id
           HAVING equals(argMax(person_distinct_id_overrides.is_deleted, person_distinct_id_overrides.version), 0) SETTINGS optimize_aggregation_in_order=1) AS event_source__override ON equals(event_source.distinct_id, event_source__override.distinct_id)
        WHERE and(equals(event_source.team_id, 99999), greater(event_source.timestamp, toDateTime64('explicit_redacted_timestamp', 6, 'UTC')), less(event_source.timestamp, toDateTime64('explicit_redacted_timestamp', 6, 'UTC')))
        ORDER BY toTimeZone(event_source.timestamp, 'UTC') DESC
        LIMIT 1001)) AS e
  LEFT JOIN
    (SELECT session_replay_events.start_time AS start_time,
            session_replay_events.end_time AS end_time,
            session_replay_events.session_id AS session_id
     FROM
       (SELECT min(toTimeZone(session_replay_events.min_first_timestamp, 'UTC')) AS start_time,
               max(toTimeZone(session_replay_events.max_last_timestamp, 'UTC')) AS end_time,
               session_replay_events.session_id AS session_id
        FROM session_replay_events
        WHERE equals(session_replay_events.team_id, 99999)
        GROUP BY session_replay_events.session_id) AS session_replay_events) AS sre ON equals(e.session_id, sre.session_id)
  ORDER BY e.timestamp DESC
  LIMIT 100 SETTINGS readonly=2,
                     max_execution_time=60,
                     allow_experimental_object_type=1,
                     max_ast_elements=4000000,
                     max_expanded_ast_elements=4000000,
                     max_bytes_before_external_group_by=0,
                     transform_null_in=1,
                     optimize_min_equality_disjunction_chain_length=4294967295,
                     optimize_rewrite_aggregate_function_with_if=0,
                     optimize_min_inequality_conjunction_chain_length=4294967295,
                     allow_experimental_join_condition=1,
                     use_hive_partitioning=0
  '''
