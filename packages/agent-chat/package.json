{
    "name": "@posthog/agent-chat",
    "version": "0.0.1",
    "private": true,
    "description": "Embeddable chat dock for the PostHog agent platform. Speaks the runner's session protocol over HTTP + SSE, dispatches client-fulfilled tools to consumer-provided handlers, ships fixture data for Storybook-driven design iteration. v0 is mocked-only; v0.2 wires real session transport. Library — no runtime, no auth, no PostHog coupling.",
    "license": "MIT",
    "author": "PostHog <hey@posthog.com>",
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./fixtures": "./src/fixtures/index.ts"
    },
    "scripts": {
        "lint": "oxlint --quiet .",
        "typescript:check": "tsc --noEmit -p ."
    },
    "dependencies": {
        "@posthog/quill": "workspace:*",
        "lucide-react": "^0.577.0",
        "react-markdown": "^9.0.0",
        "remark-gfm": "^4.0.0",
        "yaml": "^2.5.1"
    },
    "devDependencies": {
        "@storybook/react": "catalog:",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "typescript": "catalog:"
    },
    "peerDependencies": {
        "react": "^18.3.1 || ^19.0.0",
        "react-dom": "^18.3.1 || ^19.0.0"
    },
    "engines": {
        "node": ">=20"
    }
}
