{
    "name": "@posthog/quill",
    "version": "0.1.0-alpha.4",
    "description": "PostHog's unified design system — primitives, components, and blocks designed to be compiled by the consumer's Tailwind v4.",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/PostHog/posthog.git",
        "directory": "packages/quill/packages/quill"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "sideEffects": [
        "*.css"
    ],
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "default": "./dist/index.js"
        },
        "./tailwind.css": "./dist/tailwind.css",
        "./base.css": "./dist/base.css",
        "./tokens.css": "./dist/tokens.css",
        "./color-system.css": "./dist/color-system.css",
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsx scripts/build-css.ts && vite build",
        "build:css": "tsx scripts/build-css.ts",
        "build:js": "vite build"
    },
    "dependencies": {
        "@base-ui/react": "^1.3.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "lucide-react": "^0.577.0",
        "react-resizable-panels": "^4.7.1",
        "tailwind-merge": "^2.2.2",
        "vaul": "^1.1.2"
    },
    "devDependencies": {
        "@posthog/quill-blocks": "workspace:*",
        "@posthog/quill-components": "workspace:*",
        "@posthog/quill-primitives": "workspace:*",
        "@posthog/quill-tokens": "workspace:*",
        "tsx": "^4.19.0",
        "vite": "^6.3.5",
        "vite-plugin-dts": "^4.5.4"
    },
    "peerDependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tailwindcss": "^4.0.0"
    },
    "engines": {
        "node": ">=20"
    }
}
