{
    "name": "@posthog/quill",
    "version": "0.1.0-alpha.0",
    "description": "PostHog's unified design system — primitives, components, and blocks with a pre-compiled stylesheet.",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/PostHog/posthog.git",
        "directory": "packages/quill/packages/quill"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "sideEffects": [
        "*.css"
    ],
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "default": "./dist/index.js"
        },
        "./styles.css": "./dist/quill.css",
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsx scripts/build-css.ts && vite build",
        "build:css": "tsx scripts/build-css.ts",
        "build:css:watch": "tailwindcss --input ./src/index.css --output ./dist/quill.css --watch",
        "build:js": "vite build"
    },
    "dependencies": {
        "@posthog/quill-blocks": "workspace:*",
        "@posthog/quill-components": "workspace:*",
        "@posthog/quill-primitives": "workspace:*",
        "@posthog/quill-tokens": "workspace:*"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.1.17",
        "@vitejs/plugin-react": "^5.1.1",
        "shadcn": "^4.0.2",
        "tailwindcss": "^4.1.17",
        "tsx": "^4.19.0",
        "tw-animate-css": "^1.4.0",
        "vite": "^6.3.5",
        "vite-plugin-dts": "^4.5.4"
    },
    "peerDependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "engines": {
        "node": ">=20"
    }
}
