{
    "compilerOptions": {
        "target": "es2022",
        "module": "esnext",
        "moduleResolution": "bundler",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "strict": true,
        "skipLibCheck": true,
        "verbatimModuleSyntax": true,
        "erasableSyntaxOnly": true,
        "outDir": "dist"
    },
    "include": ["src"]
}
