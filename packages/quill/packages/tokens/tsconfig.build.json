{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "strict": true,
        "skipLibCheck": true,
        "verbatimModuleSyntax": true,
        "outDir": "dist"
    },
    "include": ["src"],
    "exclude": ["src/build.ts"]
}
