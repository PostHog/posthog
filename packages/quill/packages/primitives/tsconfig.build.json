{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "declaration": true,
        "strict": true,
        "skipLibCheck": true,
        "verbatimModuleSyntax": true,
        "jsx": "react-jsx",
        "noEmit": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["src"],
    "exclude": ["src/**/*.stories.tsx", "src/**/*.stories.ts"]
}
