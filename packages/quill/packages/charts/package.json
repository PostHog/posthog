{
    "name": "@posthog/quill-charts",
    "version": "0.3.0-beta.16",
    "description": "Canvas-based charting library for trends, dashboards, and any chart that needs to render thousands of points smoothly. D3 (scale/shape/color/array sub-packages) powers the scales; the canvas does the drawing; React handles overlays.",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/PostHog/posthog.git",
        "directory": "packages/quill/packages/charts"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "vite build"
    },
    "dependencies": {
        "@floating-ui/react": "^0.27.19",
        "d3-array": "^3.2.4",
        "d3-color": "^3.1.0",
        "d3-scale": "^4.0.2",
        "d3-shape": "^3.2.0",
        "dayjs": "1.11.11",
        "simple-statistics": "^7.8.3"
    },
    "devDependencies": {
        "@posthog/quill-tokens": "workspace:*",
        "@storybook/react": "catalog:",
        "@testing-library/dom": ">=9.3.4",
        "@testing-library/react": "^14.3.1",
        "@types/d3-array": "^3.2.1",
        "@types/d3-color": "^3.1.3",
        "@types/d3-scale": "^4.0.8",
        "@types/d3-shape": "^3.1.6",
        "@types/jest": "catalog:",
        "@types/react": "^18.3.27",
        "@types/react-dom": "^18.3.7",
        "@vitejs/plugin-react": "catalog:",
        "jest": "^29.7.0",
        "typescript": "catalog:",
        "vite": "catalog:",
        "vite-plugin-dts": "^4.5.4"
    },
    "peerDependencies": {
        "react": "^18.3.1 || ^19.0.0",
        "react-dom": "^18.3.1 || ^19.0.0"
    }
}
