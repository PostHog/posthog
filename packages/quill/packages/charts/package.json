{
    "name": "@posthog/quill-charts",
    "version": "0.0.0",
    "private": true,
    "description": "Internal workspace package (private, not published). Canvas-based charting library used for trends, dashboards, and any in-app chart that needs to render thousands of points smoothly. D3 (scale/shape/color/array sub-packages) powers the scales; the canvas does the drawing; React handles overlays.",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/PostHog/posthog.git",
        "directory": "packages/quill/packages/charts"
    },
    "type": "module",
    "main": "./src/index.ts",
    "module": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./testing": "./src/testing/index.ts",
        "./story-helpers": "./src/story-helpers.tsx",
        "./package.json": "./package.json"
    },
    "dependencies": {
        "@floating-ui/react": "^0.27.19",
        "d3-array": "^3.2.4",
        "d3-color": "^3.1.0",
        "d3-scale": "^4.0.2",
        "d3-shape": "^3.2.0",
        "dayjs": "1.11.11",
        "simple-statistics": "^7.8.3"
    },
    "devDependencies": {
        "@storybook/react": "catalog:",
        "@testing-library/react": "^14.3.1",
        "@types/d3-array": "^3.2.1",
        "@types/d3-color": "^3.1.3",
        "@types/d3-scale": "^4.0.8",
        "@types/d3-shape": "^3.1.6",
        "@types/jest": "catalog:",
        "@types/react": "^18.3.27",
        "@types/react-dom": "^18.3.7",
        "jest": "^29.7.0"
    },
    "peerDependencies": {
        "react": "^18.3.1 || ^19.0.0",
        "react-dom": "^18.3.1 || ^19.0.0"
    }
}
