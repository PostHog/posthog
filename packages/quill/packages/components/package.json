{
    "name": "@posthog/quill-components",
    "version": "0.1.0-alpha.0",
    "private": true,
    "description": "Internal workspace package. The public surface lives in @posthog/quill.",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/PostHog/posthog.git",
        "directory": "packages/quill/packages/components"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "vite build"
    },
    "dependencies": {
        "@posthog/quill-primitives": "workspace:^",
        "@posthog/quill-tokens": "workspace:^"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.1.17",
        "@vitejs/plugin-react": "^5.1.1",
        "vite": "^6.3.5",
        "vite-plugin-dts": "^4.5.4"
    },
    "peerDependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    }
}
