{
    "name": "@posthog/quill-storybook",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "test:visual:ci:update": "pnpm exec test-storybook -u --junit --no-index-json --maxWorkers=1",
