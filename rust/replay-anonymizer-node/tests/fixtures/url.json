[
  {
    "name": "keeps allow-listed path segments, masks numbers",
    "allow": {
      "text": [],
      "url": [
        "users",
        "profile"
      ]
    },
    "input": "https://example.com/users/42/profile",
    "treatHostAsFirstParty": false,
    "expected": "https://example.com/users/$$/profile"
  },
  {
    "name": "redacts non-allow-listed path segments",
    "allow": {
      "text": [],
      "url": []
    },
    "input": "/foo/bar?x=1",
    "treatHostAsFirstParty": false,
    "expected": "/[redacted]/[redacted]"
  },
  {
    "name": "query param survives on allow-listed key, number value masked",
    "allow": {
      "text": [],
      "url": [
        "page"
      ]
    },
    "input": "https://example.com/?page=2&secret=abc",
    "treatHostAsFirstParty": false,
    "expected": "https://example.com/?page=$"
  },
  {
    "name": "allow-listed fragment kept",
    "allow": {
      "text": [],
      "url": [
        "section"
      ]
    },
    "input": "https://example.com/#section",
    "treatHostAsFirstParty": false,
    "expected": "https://example.com/#section"
  },
  {
    "name": "treatHostAsFirstParty drops the port and keeps an allow-listed subdomain",
    "allow": {
      "text": [],
      "url": [
        "us",
        "path"
      ]
    },
    "input": "https://user:pw@us.example.org:8080/path",
    "treatHostAsFirstParty": true,
    "expected": "https://us.example.com/path"
  },
  {
    "name": "treatHostAsFirstParty collapses a two-label host to example.com",
    "allow": {
      "text": [],
      "url": []
    },
    "input": "https://example.com/u/42",
    "treatHostAsFirstParty": true,
    "expected": "https://example.com/[redacted]/$$"
  },
  {
    "name": "query param with an allow-listed key and empty value survives",
    "allow": {
      "text": [],
      "url": [
        "ok"
      ]
    },
    "input": "https://example.com/?ok=&x=1",
    "treatHostAsFirstParty": false,
    "expected": "https://example.com/?ok="
  },
  {
    "name": "bare (valueless) query flag survives only when allow-listed",
    "allow": {
      "text": [],
      "url": [
        "ok"
      ]
    },
    "input": "https://example.com/?ok&drop",
    "treatHostAsFirstParty": false,
    "expected": "https://example.com/?ok"
  },
  {
    "name": "numeric fragment is dropped",
    "allow": {
      "text": [],
      "url": []
    },
    "input": "https://example.com/#42",
    "treatHostAsFirstParty": false,
    "expected": "https://example.com/"
  },
  {
    "name": "relative-path safe segments (. and ..) are preserved",
    "allow": {
      "text": [],
      "url": []
    },
    "input": "/a/../b",
    "treatHostAsFirstParty": false,
    "expected": "/[redacted]/../[redacted]"
  },
  {
    "name": "multiple surviving query params keep their order",
    "allow": {
      "text": [],
      "url": [
        "a",
        "b",
        "x",
        "y"
      ]
    },
    "input": "https://example.com/?a=x&b=y",
    "treatHostAsFirstParty": false,
    "expected": "https://example.com/?a=x&b=y"
  },
  {
    "name": "passthrough url literals survive even with authority scrubbing: about:blank",
    "allow": {
      "text": [],
      "url": []
    },
    "input": "about:blank",
    "treatHostAsFirstParty": true,
    "expected": "about:blank"
  },
  {
    "name": "passthrough url literals survive even with authority scrubbing: about:srcdoc",
    "allow": {
      "text": [],
      "url": []
    },
    "input": "about:srcdoc",
    "treatHostAsFirstParty": true,
    "expected": "about:srcdoc"
  },
  {
    "name": "userinfo is stripped even without authority scrubbing",
    "allow": {
      "text": [],
      "url": []
    },
    "input": "https://user:hunter2@app.example.com/settings",
    "treatHostAsFirstParty": false,
    "firstPartyHosts": [
      "customer-site.test"
    ],
    "expected": "https://app.example.com/[redacted]"
  },
  {
    "name": "without first-party host patterns every host collapses",
    "allow": {
      "text": [],
      "url": []
    },
    "input": "https://app.acme.test/dashboard",
    "treatHostAsFirstParty": false,
    "expected": "https://example.com/[redacted]"
  },
  {
    "name": "scheme without slashes keeps the protocol and redacts the rest: tel",
    "allow": {
      "text": [],
      "url": []
    },
    "input": "tel:+15551234567",
    "treatHostAsFirstParty": false,
    "expected": "tel:[redacted]"
  },
  {
    "name": "scheme without slashes keeps the protocol and redacts the rest: mailto",
    "allow": {
      "text": [],
      "url": []
    },
    "input": "mailto:john.fakename@example.com?subject=hello%20there",
    "treatHostAsFirstParty": true,
    "expected": "mailto:[redacted]"
  },
  {
    "name": "first-party base domain collapses subdomain and port",
    "allow": {
      "text": [],
      "url": []
    },
    "firstPartyHosts": [
      "customer-site.test"
    ],
    "input": "https://app.customer-site.test:5000/settings/billing",
    "treatHostAsFirstParty": false,
    "expected": "https://example.com/[redacted]/[redacted]"
  },
  {
    "name": "first-party base domain collapses the apex host itself",
    "allow": {
      "text": [],
      "url": []
    },
    "firstPartyHosts": [
      "customer-site.test"
    ],
    "input": "https://customer-site.test/pricing",
    "treatHostAsFirstParty": false,
    "expected": "https://example.com/[redacted]"
  },
  {
    "name": "third-party host keeps its hostname despite first-party patterns",
    "allow": {
      "text": [],
      "url": []
    },
    "firstPartyHosts": [
      "customer-site.test"
    ],
    "input": "https://js.payment-vendor.test/v3",
    "treatHostAsFirstParty": false,
    "expected": "https://js.payment-vendor.test/[redacted]"
  },
  {
    "name": "external cdn host masks the tenant labels and keeps the provider suffix",
    "allow": {
      "text": [],
      "url": []
    },
    "firstPartyHosts": [
      "customer-site.test"
    ],
    "input": "https://d3k9x1abc.cloudfront.net/assets/hero.png",
    "treatHostAsFirstParty": false,
    "expected": "https://[redacted].cloudfront.net/[redacted]/[redacted]"
  },
  {
    "name": "external s3 bucket host masks every label before the provider suffix",
    "allow": {
      "text": [],
      "url": []
    },
    "firstPartyHosts": [
      "customer-site.test"
    ],
    "input": "https://acme-uploads.s3.eu-west-1.amazonaws.com/reports/2024.pdf",
    "treatHostAsFirstParty": false,
    "expected": "https://[redacted].s3.eu-west-1.amazonaws.com/[redacted]/[redacted]"
  },
  {
    "name": "first-party cdn host still collapses to example.com",
    "allow": {
      "text": [],
      "url": []
    },
    "firstPartyHosts": [
      "d3k9x1abc.cloudfront.net"
    ],
    "input": "https://d3k9x1abc.cloudfront.net/index.html",
    "treatHostAsFirstParty": false,
    "expected": "https://example.com/[redacted]"
  },
  {
    "name": "lookalike suffix host is not treated as first-party",
    "allow": {
      "text": [],
      "url": []
    },
    "firstPartyHosts": [
      "customer-site.test"
    ],
    "input": "https://evil-customer-site.test/x",
    "treatHostAsFirstParty": false,
    "expected": "https://evil-customer-site.test/[redacted]"
  },
  {
    "name": "unknown token before a colon is not treated as a scheme",
    "allow": {
      "text": [],
      "url": []
    },
    "input": "john.fakename:secret-chat",
    "treatHostAsFirstParty": false,
    "expected": "[redacted]"
  },
  {
    "name": "app deep-link scheme survives with its value scrubbed",
    "allow": {
      "text": [],
      "url": []
    },
    "input": "spotify:track:4uLU6hMCjMI75M1A2tKUQC",
    "treatHostAsFirstParty": false,
    "expected": "spotify:[redacted]"
  },
  {
    "name": "unencoded ? in userinfo cannot smuggle credentials as a host",
    "allow": {
      "text": [],
      "url": []
    },
    "input": "https://user:pa?ss@acme-corp.test/path",
    "treatHostAsFirstParty": false,
    "expected": "https://[redacted]"
  },
  {
    "name": "free text before an embedded :// is not kept as a scheme",
    "allow": {
      "text": [],
      "url": []
    },
    "input": "javascript:mail(\"john.fakename@example.com\",\"https://tracker.test/1\")",
    "treatHostAsFirstParty": false,
    "expected": "javascript:[redacted]//[redacted]/[redacted]"
  },
  {
    "name": "external psl-private hosting host masks the tenant label",
    "allow": {
      "text": [],
      "url": []
    },
    "firstPartyHosts": [
      "customer-site.test"
    ],
    "input": "https://acme-corp.github.io/docs/setup",
    "treatHostAsFirstParty": false,
    "expected": "https://[redacted].github.io/[redacted]/[redacted]"
  }
]
