[
  {
    "name": "domain, port, path, query and fragment pass through",
    "allow": { "text": [], "url": [] },
    "input": "https://app.example.com:8080/settings/user?page=2&tab=billing#section",
    "expected": "https://app.example.com:8080/settings/user?page=2&tab=billing#section"
  },
  {
    "name": "relative path passes through",
    "allow": { "text": [], "url": [] },
    "input": "/settings/user?x=1",
    "expected": "/settings/user?x=1"
  },
  {
    "name": "userinfo is stripped from the authority",
    "allow": { "text": [], "url": [] },
    "input": "https://user:hunter2@app.example.com/settings",
    "expected": "https://app.example.com/settings"
  },
  {
    "name": "userinfo is stripped from a protocol-relative url",
    "allow": { "text": [], "url": [] },
    "input": "//user:hunter2@app.example.com/settings",
    "expected": "//app.example.com/settings"
  },
  {
    "name": "unencoded ? in userinfo cannot smuggle credentials as a host or query",
    "allow": { "text": [], "url": [] },
    "input": "https://user:pa?ss@acme-corp.test/path",
    "expected": "https://[redacted]"
  },
  {
    "name": "mailto email is redacted",
    "allow": { "text": [], "url": [] },
    "input": "mailto:john.fakename@example.com?subject=hello%20there",
    "expected": "mailto:*************************?subject=hello%20there"
  },
  {
    "name": "email in a query parameter is redacted",
    "allow": { "text": [], "url": [] },
    "input": "https://app.example.com/unsubscribe?email=john.fakename@example.com",
    "expected": "https://app.example.com/unsubscribe?email=*************************"
  },
  {
    "name": "tel link passes through",
    "allow": { "text": [], "url": [] },
    "input": "tel:+15551234567",
    "expected": "tel:+15551234567"
  },
  {
    "name": "about:blank passes through",
    "allow": { "text": [], "url": [] },
    "input": "about:blank",
    "expected": "about:blank"
  }
]
