[
  {
    "name": "registrable domain reduction",
    "input": "app.customer-x.com",
    "expected": "customer-x.com"
  },
  {
    "name": "case normalized",
    "input": "APP.Customer-X.COM",
    "expected": "customer-x.com"
  },
  {
    "name": "multi-part public suffix kept",
    "input": "www.acme.co.uk",
    "expected": "acme.co.uk"
  },
  {
    "name": "private suffix keeps the tenant label",
    "input": "myapp.vercel.app",
    "expected": "myapp.vercel.app"
  },
  {
    "name": "localhost kept whole",
    "input": "localhost",
    "expected": "localhost"
  },
  {
    "name": "ipv4 kept whole",
    "input": "127.0.0.1",
    "expected": "127.0.0.1"
  },
  {
    "name": "port stripped",
    "input": "app.example.com:5000",
    "expected": "example.com"
  },
  {
    "name": "bare public suffix rejected",
    "input": "com",
    "expected": null
  },
  {
    "name": "empty rejected",
    "input": "",
    "expected": null
  },
  {
    "name": "invalid characters rejected",
    "input": "not a host!",
    "expected": null
  },
  {
    "name": "url entry: subdomain and scheme dropped",
    "input": "https://www.example.com",
    "expected": "example.com"
  },
  {
    "name": "url entry: wildcard reduces to its base",
    "input": "https://*.example.com",
    "expected": "example.com"
  },
  {
    "name": "url entry: port and path dropped",
    "input": "https://app.example.com:5000/welcome",
    "expected": "example.com"
  },
  {
    "name": "url entry: opaque scheme host kept",
    "input": "capacitor://LocalHost",
    "expected": "localhost"
  },
  {
    "name": "url entry: userinfo stripped",
    "input": "https://user:pw@app.example.com",
    "expected": "example.com"
  },
  {
    "name": "url entry: bare wildcard rejected",
    "input": "*",
    "expected": null
  },
  {
    "name": "url entry: bare public suffix wildcard rejected",
    "input": "https://*.com",
    "expected": null
  }
]
